    return false;
  }

  function updateDrawerFallback(sectionHtml) {
    if (!sectionHtml) return;

    const parsed = new DOMParser().parseFromString(sectionHtml, 'text/html');
    const freshMain = parsed.querySelector('#CartDrawer');
    const currentMain = document.querySelector('#CartDrawer');

    if (currentMain && freshMain) {
      currentMain.innerHTML = freshMain.innerHTML;
    }

    const drawer = document.querySelector('cart-drawer');
    if (drawer) {
      drawer.classList.remove('is-empty');
      const inner = drawer.querySelector('.drawer__inner');
      if (inner) inner.classList.remove('is-empty');
    }
  }

  function openDrawerFallback() {
    const drawer = document.querySelector('cart-drawer');
    if (!drawer) return;

    drawer.classList.remove('is-empty');
    const inner = drawer.querySelector('.drawer__inner');
    if (inner) inner.classList.remove('is-empty');

    if (typeof drawer.open === 'function') {
      drawer.open();
    } else {
      drawer.classList.add('animate', 'active');
      document.body.classList.add('overflow-hidden');
    }
  }

  async function refreshCartUI(addData, triggerButton) {
    const sections = addData && addData.sections ? addData.sections : null;

    if (sections && sections['cart-icon-bubble']) {
      updateCartBubble(sections['cart-icon-bubble']);
    }

    const renderedByDawn = updateDrawerWithDawn(addData, triggerButton);

    if (!renderedByDawn) {
      if (sections && sections['cart-drawer']) {
        updateDrawerFallback(sections['cart-drawer']);
      } else {
        try {
          const r = await fetch(root + '?section_id=cart-drawer', {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
          });
          updateDrawerFallback(await r.text());
        } catch (e) {
          console.warn('[Book Shelf] drawer fetch failed:', e);
