  function applyZoom() {
    if (!lightboxImg) return;
    lightboxImg.style.transform = 'translate(' + zoomX + 'px, ' + zoomY + 'px) scale(' + zoomScale + ')';
    lightboxImg.classList.toggle('is-zoomed', zoomScale > 1);
