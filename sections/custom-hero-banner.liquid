        #{{ sid }} {
        margin-top: -84px;  /* match your mobile header height */
        }
        @media screen and (min-width: 750px) {
        #{{ sid }} {
            margin-top: -112px;  /* match your desktop header height */
        }
        }
  </style>

  <script>
    (function() {
      const section = document.getElementById('{{ sid }}');
      if (!section) return;

      const slides = Array.from(section.querySelectorAll('[data-slide]'));
      const prevBtn = section.querySelector('[data-prev]');
      const nextBtn = section.querySelector('[data-next]');
      const dotBtns = Array.from(section.querySelectorAll('[data-dot]'));
      const scrollBtns = Array.from(section.querySelectorAll('[data-scroll-next]'));
      const autoplay = section.dataset.autoplay === 'true';
      const autoplaySpeed = parseInt(section.dataset.autoplaySpeed || '5000', 10);
      let current = 0;
      let timer = null;

      if (!slides.length) return;

      function refreshTextReveal() {
        if (!section.classList.contains('chs--text-anim')) return;
        slides.forEach(function(s) {
          s.classList.remove('chs-text-reveal');
        });
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            if (slides[current]) {
              slides[current].classList.add('chs-text-reveal');
            }
          });
        });
      }

      function initTextAnim() {
        if (!section.classList.contains('chs--text-anim')) return;
        function inView() {
          var r = section.getBoundingClientRect();
          var vh = window.innerHeight || document.documentElement.clientHeight;
          return r.top < vh * 0.92 && r.bottom > 0;
        }
        if (inView()) {
          section.classList.add('is-visible');
          refreshTextReveal();
          return;
        }
        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                section.classList.add('is-visible');
                refreshTextReveal();
                io.unobserve(section);
              }
            });
          }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
          io.observe(section);
        } else {
          section.classList.add('is-visible');
          refreshTextReveal();
        }
      }

      function pauseAllVideos() {
        slides.forEach((slide) => {
          slide.querySelectorAll('video').forEach((video) => {
            try { video.pause(); } catch(e) {}
          });
        });
      }

      function playActiveVideos() {
        const activeSlide = slides[current];
        if (!activeSlide) return;
        activeSlide.querySelectorAll('video').forEach((video) => {
          video.muted = true;
          video.playsInline = true;
          const playPromise = video.play();
          if (playPromise && typeof playPromise.catch === 'function') {
            playPromise.catch(() => {});
          }
        });
      }

      function updateDots() {
        dotBtns.forEach((dot, index) => {
          dot.classList.toggle('is-active', index === current);
        });
      }

      function showSlide(index) {
        slides[current].classList.remove('is-active');
        current = (index + slides.length) % slides.length;
        slides[current].classList.add('is-active');
        updateDots();
        pauseAllVideos();
        playActiveVideos();
        if (section.classList.contains('is-visible')) {
          refreshTextReveal();
        }
      }

      function nextSlide() {
        showSlide(current + 1);
      }

      function prevSlideFn() {
        showSlide(current - 1);
      }

      function startAutoplay() {
        if (!autoplay || slides.length < 2) return;
        stopAutoplay();
        timer = setInterval(nextSlide, autoplaySpeed);
      }

      function stopAutoplay() {
        if (timer) {
          clearInterval(timer);
          timer = null;
        }
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', function() {
          nextSlide();
          startAutoplay();
        });
      }

      if (prevBtn) {
        prevBtn.addEventListener('click', function() {
          prevSlideFn();
          startAutoplay();
        });
      }

      dotBtns.forEach((dot) => {
        dot.addEventListener('click', function() {
          const index = parseInt(this.getAttribute('data-dot'), 10);
          showSlide(index);
          startAutoplay();
        });
      });

      scrollBtns.forEach((btn) => {
        btn.addEventListener('click', function() {
          const nextSection = section.nextElementSibling;
          if (nextSection) {
            nextSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          } else {
            window.scrollTo({ top: window.scrollY + window.innerHeight, behavior: 'smooth' });
          }
        });
      });

      section.addEventListener('mouseenter', stopAutoplay);
      section.addEventListener('mouseleave', startAutoplay);
      section.addEventListener('focusin', stopAutoplay);
      section.addEventListener('focusout', startAutoplay);

      let startX = 0;
      let endX = 0;

      section.addEventListener('touchstart', function(e) {
        startX = e.changedTouches[0].clientX;
      }, { passive: true });

      section.addEventListener('touchend', function(e) {
        endX = e.changedTouches[0].clientX;
        if (Math.abs(endX - startX) > 40) {
          if (endX < startX) {
            nextSlide();
          } else {
            prevSlideFn();
          }
          startAutoplay();
        }
      }, { passive: true });

      playActiveVideos();
      startAutoplay();
      initTextAnim();
    })();
  </script>
</section>

