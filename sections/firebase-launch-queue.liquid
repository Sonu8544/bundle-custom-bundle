{% liquid
  assign launch_product_id = 7527275135073
  assign launch_limit = 250
  assign launch_window_minutes = 5
  assign queue_applies = false

  if product and product.id == launch_product_id
    assign queue_applies = true
  endif

  assign current_variant = product.selected_or_first_available_variant
%}

{% if queue_applies %}
<section id="firebase-launch-queue-{{ section.id }}" class="flq">
  <div class="flq__card" data-flq-root>
    <div class="flq__badge">PRODUCT LAUNCH</div>
    <h2 class="flq__title">Launch Queue</h2>
    <p class="flq__text" data-flq-message>Checking launch access…</p>

    <div class="flq__meta">
      <div class="flq__meta-item">
        <span class="flq__meta-label">Live in queue</span>
        <strong data-flq-live>0</strong>
      </div>
      <div class="flq__meta-item">
        <span class="flq__meta-label">Granted</span>
        <strong data-flq-granted>0</strong>
      </div>
      <div class="flq__meta-item">
        <span class="flq__meta-label">Limit</span>
        <strong>{{ launch_limit }}</strong>
      </div>
    </div>

    <div class="flq__timer" data-flq-timer hidden>
      Your access expires in <strong data-flq-countdown>05:00</strong>
    </div>

    <div class="flq__actions">
      <button type="button" class="flq__btn" data-flq-join>Join launch queue</button>
      <button type="button" class="flq__btn flq__btn--secondary" data-flq-refresh>Refresh status</button>
    </div>

    <div class="flq__status" data-flq-status></div>
  </div>
</section>

<style>
  .flq {
    margin: 0 0 24px;
  }

  .flq__card {
    border: 1px solid rgba(201,168,133,.24);
    border-radius: 18px;
    background: rgba(10,10,10,.75);
    color: #fff;
    padding: 22px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .flq__badge {
    font-size: 12px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #c9a885;
    margin-bottom: 10px;
  }

  .flq__title {
    margin: 0 0 8px;
    font-size: 28px;
    line-height: 1.1;
  }

  .flq__text {
    margin: 0 0 16px;
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255,255,255,.86);
  }

  .flq__meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0,1fr));
    gap: 10px;
    margin-bottom: 16px;
  }

  .flq__meta-item {
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 12px;
    padding: 12px;
    background: rgba(255,255,255,.03);
  }

  .flq__meta-label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(255,255,255,.64);
    margin-bottom: 5px;
  }

  .flq__meta-item strong {
    font-size: 18px;
    line-height: 1;
  }

  .flq__timer {
    margin-bottom: 16px;
    font-size: 14px;
    color: #c9a885;
  }

  .flq__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 14px;
  }

  .flq__btn {
    appearance: none;
    border: 0;
    border-radius: 999px;
    padding: 12px 18px;
    font-size: 14px;
    cursor: pointer;
    background: #c9a885;
    color: #111;
    font-weight: 600;
  }

  .flq__btn--secondary {
    background: rgba(255,255,255,.08);
    color: #fff;
  }

  .flq__status {
    font-size: 13px;
    color: rgba(255,255,255,.72);
  }

  .flq--locked #addToCart-{{ section.id }},
  .flq--locked [data-add-to-cart],
  .flq--locked .product-form__submit,
  .flq--locked .shopify-payment-button {
    pointer-events: none !important;
    opacity: .4 !important;
  }

  .flq--granted #addToCart-{{ section.id }},
  .flq--granted [data-add-to-cart],
  .flq--granted .product-form__submit {
    pointer-events: auto !important;
    opacity: 1 !important;
  }

  @media (max-width: 749px) {
    .flq__card {
      padding: 18px;
      border-radius: 16px;
    }

    .flq__title {
      font-size: 23px;
    }

    .flq__meta {
      grid-template-columns: 1fr;
    }

    .flq__actions {
      flex-direction: column;
    }

    .flq__btn {
      width: 100%;
    }
  }
</style>

<script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-firestore-compat.js"></script>

<script>
(function() {
  var wrap = document.getElementById('firebase-launch-queue-{{ section.id }}');
  if (!wrap) return;

  var productId = "{{ product.id }}";
  var variantId = "{{ current_variant.id }}";
  var launchLimit = {{ launch_limit | json }};
  var accessMinutes = {{ launch_window_minutes | json }};

  var messageEl = wrap.querySelector('[data-flq-message]');
  var liveEl = wrap.querySelector('[data-flq-live]');
  var grantedEl = wrap.querySelector('[data-flq-granted]');
  var statusEl = wrap.querySelector('[data-flq-status]');
  var joinBtn = wrap.querySelector('[data-flq-join]');
  var refreshBtn = wrap.querySelector('[data-flq-refresh]');
  var timerWrap = wrap.querySelector('[data-flq-timer]');
  var countdownEl = wrap.querySelector('[data-flq-countdown]');

  var sectionRoot =
    document.getElementById('exclusive-book-product-{{ section.id }}') ||
    wrap.closest('section') ||
    document.body;

  sectionRoot.classList.add('flq--locked');

  var firebaseConfig = {
    apiKey: "AIzaSyAXqNmSizbKKSb8lYYHA59g0tFM5sQyi_c",
    authDomain: "rare-biblio-493418.firebaseapp.com",
    projectId: "rare-biblio-493418",
    storageBucket: "rare-biblio-493418.firebasestorage.app",
    messagingSenderId: "386450854671",
    appId: "1:386450854671:web:9d646e4603bbb9c1a4247a",
    measurementId: "G-KN0453ME9Y"
  };

  if (!window.firebase || !firebase.apps) {
    if (statusEl) statusEl.textContent = 'Firebase SDK failed to load.';
    return;
  }

  if (!firebase.apps.length) {
    firebase.initializeApp(firebaseConfig);
  }

  var db = firebase.firestore();

  function getSessionId() {
    var key = 'flq_session_id_' + productId;
    var existing = localStorage.getItem(key);
    if (existing) return existing;
    var id = 'sess_' + Math.random().toString(36).slice(2) + Date.now();
    localStorage.setItem(key, id);
    return id;
  }

  var sessionId = getSessionId();
  var launchRef = db.collection('launches').doc(productId);
  var sessionRef = launchRef.collection('sessions').doc(sessionId);
  var countdownInterval = null;

  function setMessage(text) {
    if (messageEl) messageEl.textContent = text;
  }

  function setStatus(text) {
    if (statusEl) statusEl.textContent = text || '';
  }

  function lockBuy() {
    sectionRoot.classList.remove('flq--granted');
    sectionRoot.classList.add('flq--locked');
  }

  function unlockBuy() {
    sectionRoot.classList.remove('flq--locked');
    sectionRoot.classList.add('flq--granted');
  }

  function formatRemaining(ms) {
    var totalSeconds = Math.max(0, Math.floor(ms / 1000));
    var minutes = Math.floor(totalSeconds / 60);
    var seconds = totalSeconds % 60;
    return String(minutes).padStart(2, '0') + ':' + String(seconds).padStart(2, '0');
  }

  function startCountdown(expiresAtMillis) {
    if (countdownInterval) clearInterval(countdownInterval);
    if (timerWrap) timerWrap.hidden = false;

    function tick() {
      var diff = expiresAtMillis - Date.now();
      if (countdownEl) countdownEl.textContent = formatRemaining(diff);

      if (diff <= 0) {
        clearInterval(countdownInterval);
        if (timerWrap) timerWrap.hidden = true;
        lockBuy();
        setMessage('Your access window expired. Refresh to check availability again.');
      }
    }

    tick();
    countdownInterval = setInterval(tick, 1000);
  }

  async function ensureLaunchDoc() {
    await launchRef.set({
      productId: productId,
      limit: launchLimit,
      grantedCount: 0,
      createdAt: firebase.firestore.FieldValue.serverTimestamp()
    }, { merge: true });
  }

  async function joinQueue() {
    if (joinBtn) joinBtn.disabled = true;
    setStatus('Joining queue...');

    try {
      await ensureLaunchDoc();

      await db.runTransaction(async function(tx) {
        var launchSnap = await tx.get(launchRef);
        var sessionSnap = await tx.get(sessionRef);

        var data = launchSnap.exists ? launchSnap.data() : {};
        var grantedCount = Number(data.grantedCount || 0);
        var limit = Number(data.limit || launchLimit);

        if (sessionSnap.exists) {
          var existing = sessionSnap.data() || {};
          if (existing.status === 'granted') return;
          if (existing.status === 'waiting') return;
        }

        var now = Date.now();
        var expiresAt = now + (accessMinutes * 60 * 1000);

        if (grantedCount < limit) {
          tx.set(sessionRef, {
            sessionId: sessionId,
            productId: productId,
            variantId: variantId,
            status: 'granted',
            joinedAt: firebase.firestore.FieldValue.serverTimestamp(),
            expiresAtMillis: expiresAt
          }, { merge: true });

          tx.set(launchRef, {
            grantedCount: grantedCount + 1,
            limit: limit,
            updatedAt: firebase.firestore.FieldValue.serverTimestamp()
          }, { merge: true });
        } else {
          tx.set(sessionRef, {
            sessionId: sessionId,
            productId: productId,
            variantId: variantId,
            status: 'waiting',
            joinedAt: firebase.firestore.FieldValue.serverTimestamp()
          }, { merge: true });
        }
      });

      setStatus('Queue updated.');
    } catch (e) {
      console.error(e);
      setStatus('Could not join queue.');
    } finally {
      if (joinBtn) joinBtn.disabled = false;
    }
  }

  async function refreshStatus() {
    try {
      var launchSnap = await launchRef.get();
      var sessionSnap = await sessionRef.get();

      if (launchSnap.exists) {
        var launchData = launchSnap.data() || {};
        if (grantedEl) grantedEl.textContent = String(launchData.grantedCount || 0);
      }

      if (sessionSnap.exists) {
        var sessionData = sessionSnap.data() || {};

        if (sessionData.status === 'granted') {
          unlockBuy();
          setMessage('Access granted. Complete checkout before your timer ends.');
          startCountdown(Number(sessionData.expiresAtMillis || 0));
          setStatus('You have purchase access.');
          return;
        }

        if (sessionData.status === 'waiting') {
          lockBuy();
          if (timerWrap) timerWrap.hidden = true;
          setMessage('You are in queue. We will grant access if slots open.');
          setStatus('Waiting for availability.');
          return;
        }
      }

      lockBuy();
      if (timerWrap) timerWrap.hidden = true;
      setMessage('Join the queue to check launch access.');
      setStatus('');
    } catch (e) {
      console.error(e);
      setStatus('Could not refresh queue status.');
    }
  }

  launchRef.collection('sessions').onSnapshot(function(snapshot) {
    if (liveEl) liveEl.textContent = String(snapshot.size || 0);
  });

  launchRef.onSnapshot(function(doc) {
    var data = doc.exists ? doc.data() : {};
    if (grantedEl) grantedEl.textContent = String(data.grantedCount || 0);

    if ((data.grantedCount || 0) >= (data.limit || launchLimit)) {
      setStatus('Launch allocation is currently full.');
    }
  });

  sessionRef.onSnapshot(function(doc) {
    if (!doc.exists) return;

    var data = doc.data() || {};
    if (data.status === 'granted') {
      unlockBuy();
      setMessage('Access granted. Complete checkout before your timer ends.');
      startCountdown(Number(data.expiresAtMillis || 0));
      setStatus('You have purchase access.');
    } else if (data.status === 'waiting') {
      lockBuy();
      setMessage('You are in queue. Waiting for availability.');
      setStatus('Queue joined successfully.');
      if (timerWrap) timerWrap.hidden = true;
    }
  });

  if (joinBtn) joinBtn.addEventListener('click', joinQueue);
  if (refreshBtn) refreshBtn.addEventListener('click', refreshStatus);

  refreshStatus();
})();
</script>
{% endif %}

{% schema %}
{
  "name": "Firebase launch queue",
  "settings": [],
  "presets": [
    {
      "name": "Firebase launch queue"
    }
  ]
}
{% endschema %}