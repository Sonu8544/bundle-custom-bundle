{% liquid
  assign sid = 'exclusive-books-collection-' | append: section.id
  assign active_collection = collection
  if active_collection == blank and section.settings.fallback_collection != blank
    assign active_collection = section.settings.fallback_collection
  endif
%}

<section id="{{ sid }}" class="ebcp" style="margin-top: -112px;">
  <div class="ebcp__bg">
    {% if section.settings.hero_bg != blank %}
      {{ section.settings.hero_bg | image_url: width: 2400 | image_tag: class: 'ebcp__bg-image', loading: 'lazy', widths: '768,1200,1600,2000,2400', sizes: '100vw', alt: section.settings.heading | escape }}
    {% endif %}
    <div class="ebcp__overlay"></div>
  </div>

  <div class="ebcp__inner page-width">
    <div class="ebcp__hero">
      {% if section.settings.heading != blank %}
        <h2 class="ebcp__heading">
          {% assign heading_parts = section.settings.heading | split: section.settings.highlight_word %}
          {% if section.settings.highlight_word != blank and heading_parts.size > 1 %}
            <span class="ebcp__heading-base">{{ heading_parts[0] }}</span><span class="ebcp__heading-accent">{{ section.settings.highlight_word }}</span><span class="ebcp__heading-base">{{ heading_parts[1] }}</span>
          {% else %}
            <span class="ebcp__heading-base">{{ section.settings.heading }}</span>
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <div class="ebcp__subheading rte">{{ section.settings.subheading }}</div>
      {% endif %}

      <div class="ebcp__toolbar">
        <div class="ebcp__search-wrap">
          <label class="visually-hidden" for="{{ sid }}-search">{{ section.settings.search_placeholder }}</label>
          <input id="{{ sid }}-search" class="ebcp__search" type="search" placeholder="{{ section.settings.search_placeholder }}" data-search-input>
         <button type="button" class="ebcp__search-btn" aria-label="Search" data-search-button>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.7"/><path d="M16 16L21 21" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
          </button>
        </div>

        <button type="button" class="ebcp__filter-btn" data-filter-open aria-controls="{{ sid }}-filters" aria-expanded="false">
          {% if section.settings.filter_icon != blank %}
            {{ section.settings.filter_icon | image_url: width: 72 | image_tag: class: 'ebcp__filter-icon', loading: 'lazy', widths: '36,48,72', sizes: '50px', alt: 'Filter' }}
          {% else %}
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 5V19" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M17 5V19" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><circle cx="7" cy="9" r="2.6" stroke="currentColor" stroke-width="1.7"/><circle cx="17" cy="15" r="2.6" stroke="currentColor" stroke-width="1.7"/></svg>
          {% endif %}
        </button>
      </div>
    </div>

    <div id="{{ sid }}-filters" class="ebcp__modal" hidden data-filter-modal>
      <div class="ebcp__modal-backdrop" data-filter-close></div>
      <div class="ebcp__modal-dialog" role="dialog" aria-modal="true" aria-labelledby="{{ sid }}-filter-title">
        <div class="ebcp__modal-head">
          <h3 id="{{ sid }}-filter-title">{{ section.settings.filter_heading }}</h3>
          <button type="button" class="ebcp__modal-close" aria-label="Close" data-filter-close>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6L18 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          </button>
        </div>

        <div class="ebcp__modal-body">
          <div class="ebcp__field">
            <label for="{{ sid }}-sort">Sort by</label>
            <select id="{{ sid }}-sort" data-sort-select>
              <option value="featured">Featured</option>
              <option value="title-asc">Name A-Z</option>
              <option value="title-desc">Name Z-A</option>
              <option value="price-asc">Price low to high</option>
              <option value="price-desc">Price high to low</option>
            </select>
          </div>

          <div class="ebcp__field">
            <label for="{{ sid }}-author">Author</label>
            <select id="{{ sid }}-author" data-author-select>
              <option value="">All authors</option>
              {% if active_collection != blank %}
                {% assign authors_string = '' %}
                {% for product in active_collection.products %}
                  {% if product.vendor != blank %}
                    {% assign author_key = '|' | append: product.vendor | append: '|' %}
                    {% unless authors_string contains author_key %}
                      {% assign authors_string = authors_string | append: author_key %}
                      <option value="{{ product.vendor | escape }}">{{ product.vendor }}</option>
                    {% endunless %}
                  {% endif %}
                {% endfor %}
              {% endif %}
            </select>
          </div>

          <div class="ebcp__field-group">
            <div class="ebcp__field">
              <label for="{{ sid }}-min">Min price</label>
              <input id="{{ sid }}-min" type="number" min="0" step="1" placeholder="0" data-price-min>
            </div>
            <div class="ebcp__field">
              <label for="{{ sid }}-max">Max price</label>
              <input id="{{ sid }}-max" type="number" min="0" step="1" placeholder="99999" data-price-max>
            </div>
          </div>

          <div class="ebcp__modal-actions">
            <button type="button" class="ebcp__secondary-btn" data-filter-reset>Reset</button>
            <button type="button" class="ebcp__primary-btn" data-filter-apply>Apply filters</button>
          </div>
        </div>
      </div>
    </div>

    {% if active_collection != blank %}
      {% paginate active_collection.products by 250 %}
        <div class="ebcp__grid" data-books-grid data-shelf-image="{% if section.settings.shelf_image != blank %}{{ section.settings.shelf_image | image_url: width: 2400 }}{% endif %}">
          {% for product in active_collection.products %}
            {% assign current_variant = product.selected_or_first_available_variant %}
            <article
              class="ebcp__item"
              data-book-item
              data-title="{{ product.title | downcase | escape }}"
              data-author="{{ product.vendor | downcase | escape }}"
              data-price="{{ current_variant.price | default: product.price | money_without_currency | remove: ',' | strip }}"
              data-index="{{ forloop.index0 }}"
            >
              <div class="ebcp__row">
                <div class="ebcp__book-wrap">
                  <div class="ebcp__book">
                    <a href="{{ product.url }}" class="ebcp__book-link" aria-label="{{ product.title }}">
                      {% if product.featured_image != blank %}
                        {{ product.featured_image | image_url: width: 1200 | image_tag: class: 'ebcp__book-image', loading: 'lazy', widths: '220,320,420,520,720,920,1200', sizes: '(max-width: 767px) 42vw, (max-width: 989px) 30vw, 24vw', alt: product.title | escape }}
                      {% else %}
                        {{ 'image' | placeholder_svg_tag: 'ebcp__placeholder' }}
                      {% endif %}
                    </a>

                    {% comment %} {% if current_variant != blank %}
                      <div class="ebcp__cta">
                        <button type="button" class="ebcp__cart-btn" data-add-to-cart data-variant-id="{{ current_variant.id }}" {% unless current_variant.available %}disabled{% endunless %}>
                          {% if current_variant.available %}{{ section.settings.button_text }}{% else %}Sold out{% endif %}
                        </button>
                      </div>
                    {% endif %} {% endcomment %}
                  </div>
                </div>

                {% if section.settings.show_meta %}
                  <div class="ebcp__meta">
                    <h3 class="ebcp__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
                    {% if product.vendor != blank %}<div class="ebcp__author">{{ product.vendor }}</div>{% endif %}
                    <div class="ebcp__price">{{ current_variant.price | default: product.price | money }}</div>
                  </div>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>

        <div class="ebcp__empty" hidden style="display:none;" data-empty-state>{{ section.settings.empty_text }}</div>
      {% endpaginate %}
    {% else %}
      <div class="ebcp__empty ebcp__empty--static">Select a collection or use this section on a collection template.</div>
    {% endif %}
  </div>

  <style>
    #{{ sid }} {
      --hero-min-height-desktop: {{ section.settings.hero_height_desktop }}px;
      --hero-min-height-tablet: {{ section.settings.hero_height_tablet }}px;
      --hero-min-height-mobile: {{ section.settings.hero_height_mobile }}px;
      --heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
      --heading-size-tablet: {{ section.settings.heading_size_tablet }}px;
      --heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
      --subheading-size-desktop: {{ section.settings.subheading_size_desktop }}px;
      --subheading-size-tablet: {{ section.settings.subheading_size_tablet }}px;
      --subheading-size-mobile: {{ section.settings.subheading_size_mobile }}px;
      --content-max-width: {{ section.settings.content_max_width }}px;
      --search-width-desktop: {{ section.settings.search_width_desktop }}px;
      --search-width-mobile: {{ section.settings.search_width_mobile }}px;

      --book-width-desktop: {{ section.settings.book_width_desktop }}px;
      --book-height-desktop: {{ section.settings.book_height_desktop }}px;
      --book-width-tablet: {{ section.settings.book_width_tablet }}px;
      --book-height-tablet: {{ section.settings.book_height_tablet }}px;
      --book-width-mobile: {{ section.settings.book_width_mobile }}px;
      --book-height-mobile: {{ section.settings.book_height_mobile }}px;

      --book-top-desktop: {{ section.settings.book_top_offset_desktop }}px;
      --book-top-tablet: {{ section.settings.book_top_offset_tablet }}px;
      --book-top-mobile: {{ section.settings.book_top_offset_mobile }}px;
      --book-bottom-desktop: {{ section.settings.book_bottom_offset_desktop }}px;
      --book-bottom-tablet: {{ section.settings.book_bottom_offset_tablet }}px;
      --book-bottom-mobile: {{ section.settings.book_bottom_offset_mobile }}px;

      --gap-desktop: {{ section.settings.grid_gap_desktop }}px;
      --gap-tablet: {{ section.settings.grid_gap_tablet }}px;
      --gap-mobile: {{ section.settings.grid_gap_mobile }}px;
      --row-gap-desktop: {{ section.settings.row_gap_desktop }}px;
      --row-gap-mobile: {{ section.settings.row_gap_mobile }}px;
      --row-max-width-desktop: {{ section.settings.row_max_width_desktop }}px;
      --row-max-width-tablet: {{ section.settings.row_max_width_tablet }}px;
      --row-max-width-mobile: {{ section.settings.row_max_width_mobile }}px;

      --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
      --heading-font: {{ section.settings.heading_font_family }};
      --body-font: {{ section.settings.body_font_family }};
      --text-color: {{ section.settings.text_color }};
      --heading-base-color: {{ section.settings.heading_base_color }};
      --accent-start: {{ section.settings.heading_gradient_start }};
      --accent-end: {{ section.settings.heading_gradient_end }};
      --search-bg: {{ section.settings.search_bg }};
      --search-border: {{ section.settings.search_border }};
      --modal-bg: {{ section.settings.modal_bg }};
      --section-bg: {{ section.settings.section_bg }};
      --glow: {{ section.settings.glow_color }};
      --button-text: {{ section.settings.button_text_color }};
      --button-radius: {{ section.settings.button_radius }}px;
      --card-meta: {{ section.settings.meta_text_color }};
      --filter-btn-bg: {% if section.settings.filter_button_bg != blank %}url({{ section.settings.filter_button_bg | image_url: width: 300 }}) center/cover no-repeat{% else %}linear-gradient(180deg, #DDB85F 0%, #8A6210 100%){% endif %};
    }

    #{{ sid }}.ebcp {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at 50% 18%, var(--glow) 0%, rgba(0,0,0,0) 26%),
        var(--section-bg);
      color: var(--text-color);
      padding: 0 0 {{ section.settings.bottom_padding }}px;
    }
    #{{ sid }} .ebcp__bg,
    #{{ sid }} .ebcp__overlay { position: absolute; inset: 0; }
    #{{ sid }} .ebcp__bg-image { width: 100%; height: 100%; object-fit: cover; display: block; }
    #{{ sid }} .ebcp__overlay {
      background: linear-gradient(180deg, rgba(0,0,0,.40) 0%, rgba(0,0,0,.10) 34%, rgba(0,0,0,.92) 100%), rgba(0,0,0,var(--overlay-opacity));
      pointer-events: none;
    }
    #{{ sid }} .ebcp__inner {
      position: relative;
      z-index: 2;
      max-width: var(--content-max-width);
      margin: 0 auto;
    }
    #{{ sid }} .ebcp__hero {
      min-height: var(--hero-min-height-desktop);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: {{ section.settings.top_padding }}px 0 40px;
    }
    #{{ sid }} .ebcp__heading {
      margin: 0;
      font-family: var(--heading-font), serif;
      font-size: var(--heading-size-desktop);
      line-height: 1;
      font-weight: 400;
      color: var(--heading-base-color);
      letter-spacing: -0.01em;
    }
    #{{ sid }} .ebcp__heading-base { color: var(--heading-base-color); }
    #{{ sid }} .ebcp__heading-accent {
      background: linear-gradient(180deg, var(--accent-start) 0%, var(--accent-end) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
      padding-left: 0.18em;
    }
    #{{ sid }} .ebcp__subheading {
      margin: 18px auto 0;
      max-width: 420px;
      font-family: var(--body-font), sans-serif;
      font-size: var(--subheading-size-desktop);
      line-height: 1.3;
      color: #fff;
    }
    #{{ sid }} .ebcp__subheading p { margin: 0; }
    #{{ sid }} .ebcp__toolbar {
      margin-top: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      width: 100%;
    }
    #{{ sid }} .ebcp__search-wrap {
      width: min(100%, var(--search-width-desktop));
      min-height: 50px;
      display: flex;
      align-items: center;
      padding: 0 6px 0 20px;
      border-radius: 122px;
      border: 1px solid var(--search-border);
      background: var(--search-bg);
      backdrop-filter: blur(9px);
      -webkit-backdrop-filter: blur(9px);
    }
    #{{ sid }} .ebcp__search {
      width: 100%;
      min-width: 0;
      background: transparent;
      border: 0;
      outline: none;
      color: #fff;
      font-size: 15px;
      font-family: var(--body-font), sans-serif;
      box-shadow: none;
      padding: 14px 0;
    }
    #{{ sid }} .ebcp__search::placeholder { color: rgba(255,255,255,.74); }
    #{{ sid }} .ebcp__search-btn {
      width: 42px; height: 42px; border: 0; background: transparent; color: #fff; display: inline-flex; align-items: center; justify-content: center; cursor: pointer;
    }
    #{{ sid }} .ebcp__search-btn svg { width: 19px; height: 19px; }
    #{{ sid }} .ebcp__filter-btn {
      width: 50px; height: 50px; border: 0; border-radius: 60px; background: var(--filter-btn-bg); display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 12px 26px rgba(0,0,0,.28); cursor: pointer;
    }
    #{{ sid }} .ebcp__filter-icon { width: 22px; height: 22px; object-fit: contain; display: block; }
    #{{ sid }} .ebcp__filter-btn svg { width: 21px; height: 21px; color: #fff; }

    #{{ sid }} .ebcp__grid {
      display: flex;
      flex-direction: column;
      gap: var(--row-gap-desktop);
      align-items: stretch;
    }
    #{{ sid }} .ebcp__shelf-row {
      position: relative;
      width: 100%;
    }
    /* Books row uses fixed-width columns so column-gap directly = pixel gap between books */
    #{{ sid }} .ebcp__books-row {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, var(--book-width-desktop)));
      column-gap: var(--gap-desktop);
      justify-content: center;
      justify-items: center;
      align-items: end;
      width: 100%;
      max-width: var(--row-max-width-desktop);
      margin-left: auto;
      margin-right: auto;
      padding-top: var(--book-top-desktop);
      margin-bottom: var(--book-bottom-desktop);
    }
    #{{ sid }} .ebcp__item { min-width: 0; display: flex; justify-content: center; width: 100%; }
    #{{ sid }} .ebcp__row { position: relative; width: 100%; display: flex; justify-content: center; }
    #{{ sid }} .ebcp__book-wrap { position: relative; z-index: 2; display: flex; justify-content: center; }
    #{{ sid }} .ebcp__book {
      width: 100%;
      max-width: var(--book-width-desktop);
      height: auto;
      aspect-ratio: 316 / 400;
      max-height: none;
      position: relative;
      transition: transform .35s ease;
      transform: translateZ(0);
      backface-visibility: hidden;
      will-change: transform;
    }
    #{{ sid }} .ebcp__book:hover,
    #{{ sid }} .ebcp__book:focus-within { transform: translateY(-{{ section.settings.hover_lift }}px); }
    #{{ sid }} .ebcp__book-link { display: block; line-height: 0; position: relative; z-index: 2; width: 100%; height: 100%; }
    #{{ sid }} .ebcp__book-image,
    #{{ sid }} .ebcp__placeholder {
      width: 100%; height: 100%; display: block; object-fit: cover; filter: drop-shadow(0 18px 32px rgba(0,0,0,.55));
    }
    #{{ sid }} .ebcp__cta {
      position: absolute; left: 50%; bottom: 6%; transform: translateX(-50%) translateY(10px); width: calc(100% - 14px); max-width: 220px; opacity: 0; visibility: hidden; transition: opacity .3s ease, transform .3s ease, visibility .3s ease; z-index: 4;
    }
    #{{ sid }} .ebcp__book:hover .ebcp__cta,
    #{{ sid }} .ebcp__book:focus-within .ebcp__cta { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
    #{{ sid }} .ebcp__cart-btn {
      width: 100%; min-height: 44px; border: 0; border-radius: var(--button-radius); cursor: pointer; color: var(--button-text); font-size: 12px; letter-spacing: .08em; text-transform: uppercase; font-family: var(--body-font), sans-serif; font-weight: 500; background: {% if section.settings.button_bg != blank %}url({{ section.settings.button_bg | image_url: width: 400 }}) center/cover no-repeat{% else %}linear-gradient(180deg, #DDB85F 0%, #8A6210 100%){% endif %}; box-shadow: 0 10px 20px rgba(0,0,0,.32);
    }
    #{{ sid }} .ebcp__cart-btn[disabled] { opacity: .6; cursor: not-allowed; }
    #{{ sid }} .ebcp__shelf { position: relative; z-index: 1; line-height: 0; }
    #{{ sid }} .ebcp__shelf-image { width: 100%; height: auto; display: block; object-fit: contain; }
    #{{ sid }} .ebcp__meta { margin-top: 12px; text-align: center; color: var(--card-meta); font-family: var(--body-font), sans-serif; }
    #{{ sid }} .ebcp__title { margin: 0; font-size: 15px; line-height: 1.3; font-weight: 500; }
    #{{ sid }} .ebcp__title a { color: inherit; text-decoration: none; }
    #{{ sid }} .ebcp__author { margin-top: 4px; font-size: 13px; opacity: .82; }
    #{{ sid }} .ebcp__price { margin-top: 6px; font-size: 14px; }

    /* Empty state — only shown by JS when search/filter has zero results */
    #{{ sid }} .ebcp__empty[hidden] { display: none !important; }
    #{{ sid }} .ebcp__empty {
      display: flex; align-items: center; justify-content: center; min-height: 160px; margin-top: 12px; border: 1px solid rgba(255,255,255,.1); border-radius: 20px; background: rgba(255,255,255,.03); color: rgba(255,255,255,.76); text-align: center; padding: 24px;
    }
    #{{ sid }} .ebcp__empty--static { margin-top: 24px; }

    #{{ sid }} .ebcp__modal[hidden] { display: none !important; }
    #{{ sid }} .ebcp__modal { position: fixed; inset: 0; z-index: 30; }
    #{{ sid }} .ebcp__modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,.86); }
    #{{ sid }} .ebcp__modal-dialog {
      position: relative; z-index: 1; width: min(92vw, 640px); margin: 20vh auto 0; max-height: 84vh; overflow: auto; border-radius: 28px; background: var(--modal-bg); border: 1px solid rgba(255,255,255,.08); box-shadow: 0 28px 80px rgba(0,0,0,.42); color: #fff;
    }
    #{{ sid }} .ebcp__modal-head { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 22px 24px 18px; border-bottom: 1px solid rgba(255,255,255,.08); }
    #{{ sid }} .ebcp__modal-head h3 { margin: 0; font-family: var(--heading-font), serif; font-size: 28px; font-weight: 400; }
    #{{ sid }} .ebcp__modal-close { width: 42px; height: 42px; border: 1px solid rgba(255,255,255,.15); background: rgba(255,255,255,.05); border-radius: 999px; color: #fff; display: inline-flex; align-items: center; justify-content: center; padding: 0; cursor: pointer; }
    #{{ sid }} .ebcp__modal-close svg { width: 18px; height: 18px; }
    #{{ sid }} .ebcp__modal-body { padding: 24px; display: grid; gap: 18px; }
    #{{ sid }} .ebcp__field, #{{ sid }} .ebcp__field-group { display: grid; gap: 8px; }
    #{{ sid }} .ebcp__field-group { grid-template-columns: repeat(2, minmax(0,1fr)); gap: 14px; }
    #{{ sid }} .ebcp__field label { font-family: var(--body-font), sans-serif; font-size: 14px; color: rgba(255,255,255,.9); }
    #{{ sid }} .ebcp__field select,
    #{{ sid }} .ebcp__field input {
      min-height: 48px; border-radius: 14px; border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.04); color: #fff; padding: 0 14px; font-family: var(--body-font), sans-serif; box-shadow: none; outline: none;
    }
    #{{ sid }} .ebcp__field select option { color: #000; }
    #{{ sid }} .ebcp__modal-actions { display: flex; justify-content: flex-end; gap: 12px; padding-top: 4px; }
    #{{ sid }} .ebcp__secondary-btn,
    #{{ sid }} .ebcp__primary-btn {
      min-height: 46px; border-radius: 999px; padding: 0 20px; font-family: var(--body-font), sans-serif; cursor: pointer;
    }
    #{{ sid }} .ebcp__secondary-btn { border: 1px solid rgba(255,255,255,.14); background: rgba(255,255,255,.04); color: #fff; }
    #{{ sid }} .ebcp__primary-btn { border: 0; color: var(--button-text); background: {% if section.settings.button_bg != blank %}url({{ section.settings.button_bg | image_url: width: 400 }}) center/cover no-repeat{% else %}linear-gradient(180deg, #DDB85F 0%, #8A6210 100%){% endif %}; }

    @media screen and (max-width: 989px) {
      #{{ sid }} .ebcp__hero { min-height: var(--hero-min-height-tablet); }
      #{{ sid }} .ebcp__heading { font-size: var(--heading-size-tablet); }
      #{{ sid }} .ebcp__subheading { font-size: var(--subheading-size-tablet); }
      #{{ sid }} .ebcp__books-row {
        grid-template-columns: repeat(3, minmax(0, var(--book-width-tablet)));
        column-gap: var(--gap-tablet);
        max-width: var(--row-max-width-tablet);
        padding-top: var(--book-top-tablet);
        margin-bottom: var(--book-bottom-tablet);
      }
      #{{ sid }} .ebcp__book {
        max-width: var(--book-width-tablet);
        height: auto;
        aspect-ratio: 220 / 280;
        max-height: none;
        transform: translateZ(0);
        backface-visibility: hidden;
      }
      #{{ sid }} .ebcp__cta { opacity: 1; visibility: visible; transform: translateX(-50%); }
    }

    @media screen and (max-width: 767px) {
      #{{ sid }} .ebcp__hero {
        min-height: var(--hero-min-height-mobile);
        padding: {{ section.settings.top_padding_mobile }}px 0 28px;
      }

      #{{ sid }} .ebcp__heading {
