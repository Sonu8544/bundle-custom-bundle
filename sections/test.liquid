{%- comment -%}
  ============================================================
  RARE BOOK SHOWCASE
  Parallax slider section with countdown timer
  Place this file in: /sections/rare-book-showcase.liquid
  ============================================================
{%- endcomment -%}

<section
  class="rb-showcase"
  id="rb-{{ section.id }}"
  data-rb-root
  style="
    --rb-bg: {{ section.settings.bg_color }};
    --rb-glow: {{ section.settings.glow_color }};
    --rb-text: {{ section.settings.text_color }};
    --rb-muted: {{ section.settings.muted_color }};
    --rb-accent-1: {{ section.settings.accent_color_1 }};
    --rb-accent-2: {{ section.settings.accent_color_2 }};
    --rb-min-height: {{ section.settings.min_height }}vh;
  "
>
  <div class="rb-showcase__glow" aria-hidden="true"></div>

  <div class="rb-showcase__track" data-rb-track>
    {%- for block in section.blocks -%}
      <article
        class="rb-slide{% if forloop.first %} is-active{% endif %}"
        data-rb-slide
        data-rb-index="{{ forloop.index0 }}"
        {% if block.settings.end_date != blank %}data-rb-end="{{ block.settings.end_date }}"{% endif %}
        {{ block.shopify_attributes }}
      >
        <div class="rb-slide__content">
          {%- if block.settings.badge != blank -%}
            <span class="rb-badge">{{ block.settings.badge }}</span>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            <h2 class="rb-title">{{ block.settings.title }}</h2>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="rb-description">{{ block.settings.description }}</p>
          {%- endif -%}

          {%- if block.settings.year != blank or block.settings.binding != blank -%}
            <dl class="rb-meta">
              {%- if block.settings.year != blank -%}
                <div class="rb-meta__item">
                  <dt class="rb-meta__label">{{ block.settings.year_label }}</dt>
                  <dd class="rb-meta__value">{{ block.settings.year }}</dd>
                </div>
              {%- endif -%}
              {%- if block.settings.binding != blank -%}
                <div class="rb-meta__item">
                  <dt class="rb-meta__label">{{ block.settings.binding_label }}</dt>
                  <dd class="rb-meta__value">{{ block.settings.binding }}</dd>
                </div>
              {%- endif -%}
            </dl>
          {%- endif -%}

          {%- if block.settings.end_date != blank -%}
            <div class="rb-countdown" data-rb-countdown>
              <span class="rb-countdown__label">{{ block.settings.countdown_label }}</span>
              <div class="rb-countdown__timer" role="timer" aria-live="polite">
                <div class="rb-countdown__unit">
                  <span class="rb-countdown__value" data-rb-hours>00</span>
                  <span class="rb-countdown__name">Hours</span>
                </div>
                <span class="rb-countdown__sep" aria-hidden="true">:</span>
                <div class="rb-countdown__unit">
                  <span class="rb-countdown__value" data-rb-minutes>00</span>
                  <span class="rb-countdown__name">Minutes</span>
                </div>
                <span class="rb-countdown__sep" aria-hidden="true">:</span>
                <div class="rb-countdown__unit">
                  <span class="rb-countdown__value" data-rb-seconds>00</span>
                  <span class="rb-countdown__name">Seconds</span>
                </div>
              </div>
            </div>
          {%- endif -%}

          {%- if block.settings.button_text != blank -%}
            <a
              href="{{ block.settings.button_link | default: '#' }}"
              class="rb-button"
            >
              <span>{{ block.settings.button_text }}</span>
            </a>
          {%- endif -%}
        </div>

        <div class="rb-slide__visual" data-rb-parallax>
          <div class="rb-slide__visual-inner" data-rb-tilt>
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  class: 'rb-slide__image',
                  widths: '400, 600, 800, 1000, 1200, 1400',
                  sizes: '(min-width: 750px) 50vw, 90vw',
                  alt: block.settings.image.alt | default: block.settings.title
              }}
            {%- else -%}
              <div class="rb-slide__placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'rb-slide__placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        </div>
      </article>
    {%- else -%}
      <div class="rb-empty">Add a slide block from the theme editor to get started.</div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="rb-controls">
      <span class="rb-counter" aria-hidden="true">
        <span data-rb-current>1</span> / <span data-rb-total>{{ section.blocks.size }}</span>
      </span>
      <div class="rb-progress" aria-hidden="true">
        <span class="rb-progress__bar" data-rb-progress></span>
      </div>
      <div class="rb-nav">
        <button class="rb-nav__btn" data-rb-prev aria-label="Previous slide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 12H5M5 12l6-6M5 12l6 6"/></svg>
        </button>
        <button class="rb-nav__btn" data-rb-next aria-label="Next slide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M14 6l6 6M14 18l6-6"/></svg>
        </button>
      </div>
    </div>
  {%- endif -%}
</section>

