<script>
(function() {
  var root  = document.getElementById('scroll-{{ sid }}');
  if (!root) return;

  var shell = root.querySelector('[data-ps-shell]');
  var scene = root.querySelector('[data-ps-scene]');
  var wrap  = root.querySelector('[data-ps-wrap]');
  var paper = root.querySelector('[data-ps-paper]');
  var pIn   = root.querySelector('[data-ps-pin]');
  var txt   = root.querySelector('[data-ps-txt]');
  var hint  = root.querySelector('[data-ps-hint]');
  var topR  = root.querySelector('[data-ps-top]');
  var botR  = root.querySelector('[data-ps-bot]');

  if (!shell || !scene || !wrap || !paper || !pIn || !txt || !topR || !botR) return;

  var progress = 0;
  var ticking = false;
  var resizeTimer = null;

  function clamp(value, min, max) {
    return Math.max(min, Math.min(max, value));
  }

  function isMobile() {
    return window.innerWidth <= 749;
  }

  function getClosedHeight() {
    var styles = getComputedStyle(root);
    return parseFloat(styles.getPropertyValue(isMobile() ? '--ps-closed-h-m' : '--ps-closed-h-d')) || 40;
  }

  function getExtraScroll() {
    var styles = getComputedStyle(root);
    return parseFloat(styles.getPropertyValue(isMobile() ? '--ps-scroll-extra-m' : '--ps-scroll-extra-d')) || 240;
  }

  function getRollerHeights() {
    var topImg = topR.querySelector('img');
    var botImg = botR.querySelector('img');

    return {
      top: topImg ? topImg.getBoundingClientRect().height : 0,
      bottom: botImg ? botImg.getBoundingClientRect().height : 0
    };
  }

  function resetTextScaling() {
      txt.style.fontSize = '';
      var h2  = txt.querySelector('h2');
      var sub = txt.querySelector('.ps-sub');
      var qt  = txt.querySelector('.ps-quote');
      var st  = txt.querySelector('.ps-stamp');

      if (h2)  h2.style.fontSize = '';
      if (sub) sub.style.fontSize = '';
      if (qt)  qt.style.fontSize = '';
      if (st)  st.style.fontSize = '';
    }

  function fitTextToAvailableHeight() {
    resetTextScaling();

    var viewportH = window.innerHeight || document.documentElement.clientHeight;
    var roller = getRollerHeights();

    /* slightly more reserved space so bottom roller does not get clipped */
    var safetyGap = isMobile() ? 34 : 64;

    var availablePaperHeight = Math.max(
      180,
      viewportH - roller.top - roller.bottom - safetyGap
    );

    var baseBody = isMobile() ? 15 : 18;
    var baseTitle = isMobile() ? 32 : 65;
    var baseSub = isMobile() ? 10 : 11;
    var baseQuote = isMobile() ? 14 : 17;
    var baseStamp = isMobile() ? 10 : 12;

    txt.style.fontSize = baseBody + 'px';

    var h2  = txt.querySelector('h2');
    var sub = txt.querySelector('.ps-sub');
    var qt  = txt.querySelector('.ps-quote');
    var st  = txt.querySelector('.ps-stamp');

    if (h2)  h2.style.fontSize = baseTitle + 'px';
    if (sub) sub.style.fontSize = baseSub + 'px';
    if (qt)  qt.style.fontSize = baseQuote + 'px';
    if (st)  st.style.fontSize = baseStamp + 'px';

    var contentHeight = Math.ceil(txt.scrollHeight);

    if (contentHeight > availablePaperHeight) {
      var minScale = isMobile() ? 0.78 : 0.72;
      var scale = Math.max(availablePaperHeight / contentHeight, minScale);

      txt.style.fontSize = (baseBody * scale) + 'px';
      if (h2)  h2.style.fontSize = (baseTitle * scale) + 'px';
      if (sub) sub.style.fontSize = (baseSub * scale) + 'px';
      if (qt)  qt.style.fontSize = (baseQuote * scale) + 'px';
      if (st)  st.style.fontSize = (baseStamp * scale) + 'px';
    }
  }

  function getMetrics() {
    var closedHeight = getClosedHeight();
    var extraScroll = getExtraScroll();
    var roller = getRollerHeights();
    var contentHeight = Math.ceil(txt.scrollHeight);

    /*
      extra reveal below the text so the bottom roller is always visible
      even on tablet / larger screens / 1440+ widths
    */
    var bottomReveal = Math.max(
      isMobile() ? 56 : 90,
      Math.round(roller.bottom * (isMobile() ? 0.5 : 0.62))
    );

    var openHeight = Math.max(
      closedHeight,
      contentHeight + bottomReveal
    );

    var totalScrollDistance = Math.max(
      openHeight - closedHeight + extraScroll,
      window.innerHeight * 0.72
    );

    var shellHeight = Math.ceil(window.innerHeight + totalScrollDistance);

    return {
      closedHeight: closedHeight,
      openHeight: openHeight,
      totalScrollDistance: totalScrollDistance,
      shellHeight: shellHeight
    };
  }


  function setShellHeight(metrics) {
    root.style.setProperty('--ps-shell-h', metrics.shellHeight + 'px');
  }

  function setProgress(value) {
    progress = clamp(value, 0, 1);
    root.style.setProperty('--ps-progress', progress.toFixed(4));
  }

  function render() {
    var metrics = getMetrics();
    var currentHeight = metrics.closedHeight + ((metrics.openHeight - metrics.closedHeight) * progress);

    root.style.setProperty('--ps-open-h', currentHeight.toFixed(2) + 'px');
    pIn.style.minHeight = currentHeight.toFixed(2) + 'px';

    var deg = progress * 12;
    var lift = progress * 5;

    topR.style.transform = 'translateZ(' + lift + 'px) rotateX(' + (-deg) + 'deg)';
    botR.style.transform = 'translateZ(' + lift + 'px) rotateX(' + (deg) + 'deg)';

    var topImg = topR.querySelector('img');
    var botImg = botR.querySelector('img');
    var brightness = 1 + (progress * 0.08);

    if (topImg) topImg.style.filter = 'brightness(' + brightness + ')';
    if (botImg) botImg.style.filter = 'brightness(' + brightness + ')';
    if (hint) hint.style.opacity = progress > 0.06 ? '0' : '1';
  }

  function updateFromScroll() {
    ticking = false;

    var metrics = getMetrics();
    setShellHeight(metrics);

    var rect = shell.getBoundingClientRect();
    var traveled = clamp(-rect.top, 0, metrics.totalScrollDistance);
    var nextProgress = metrics.totalScrollDistance > 0 ? traveled / metrics.totalScrollDistance : 0;

    setProgress(nextProgress);
    render();
  }

  function requestTick() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(updateFromScroll);
  }

  function refresh() {
    fitTextToAvailableHeight();
    var metrics = getMetrics();
    setShellHeight(metrics);
    requestTick();
  }

  window.addEventListener('scroll', requestTick, { passive: true });

  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(refresh, 80);
  });

  document.addEventListener('shopify:section:load', refresh);
  document.addEventListener('shopify:section:reorder', refresh);
  document.addEventListener('shopify:block:select', refresh);
  document.addEventListener('shopify:block:deselect', refresh);

  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(function() {
      refresh();
      setTimeout(refresh, 120);
    }).catch(function() {
      refresh();
    });
  } else {
    refresh();
  }

  window.addEventListener('load', function() {
    refresh();
    setTimeout(refresh, 120);
    setTimeout(refresh, 300);
    setTimeout(refresh, 700);
  });

  refresh();
})();
</script>

{% schema %}
{
  "name": "Parchment Scroll",
  "tag": "section",
  "class": "parchment-scroll-section main-section-wrapper--",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Scroll Content" },
    { "type": "paragraph", "content": "Single heading with gradient styling." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "About Rare Biblio" },
    { "type": "checkbox", "id": "show_title_divider", "label": "Show gold divider under title", "default": true },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "-", "info": "Optional. Replace with your subtitle, or leave as a single hyphen (-) to hide." },
    { "type": "richtext", "id": "body_text", "label": "Body text", "default": "<p>Welcome to Rare Biblio, the premier destination for bibliophiles and book lovers who appreciate the art of bookmaking. As a rare books store, we specialize in handcrafted leather-bound books, personalization &amp; customization services, and restoration of valuable old books, antiquarian books, and manuscripts.</p>" },
    { "type": "text", "id": "quote_text", "label": "Quote", "default": "-", "info": "Optional. Leave as a single hyphen (-) to hide." },
    { "type": "text", "id": "footer_text", "label": "Footer stamp", "default": "-", "info": "Optional. Leave as a single hyphen (-) to hide." },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "max_scroll_width", "label": "Max scroll width", "min": 400, "max": 1000, "step": 20, "default": 680, "unit": "px" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#0a0804" },
    { "type": "color", "id": "text_color", "label": "Body text color", "default": "#17130f" },
    { "type": "color", "id": "heading_color", "label": "Heading dark tone", "default": "#121212" },
    { "type": "color", "id": "accent_color", "label": "Gold accent tone", "default": "#a87e0a" },

    { "type": "header", "content": "Scroll Images" },
    { "type": "paragraph", "content": "Upload custom scroll images, or leave empty to use default assets (scroll-top.png, scroll-mid.png, scroll-bot.png)." },
    { "type": "image_picker", "id": "img_top", "label": "Top roller image" },
    { "type": "image_picker", "id": "img_mid", "label": "Middle paper tile" },
    { "type": "image_picker", "id": "img_bot", "label": "Bottom roller image" }
  ],
  "presets": [
    { "name": "Parchment Scroll", "category": "Custom" }
  ]
}
{% endschema %}