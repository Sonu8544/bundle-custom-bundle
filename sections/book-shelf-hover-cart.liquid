{% endschema %} {% endcomment %}


{% liquid
  assign sid = 'book-shelf-' | append: section.id
%}

<section id="{{ sid }}" class="bshelf">
  <div class="bshelf__outer page-width">
    <div class="bshelf__inner">
      <div
        class="bshelf__grid"
        data-books-grid
        data-initial-desktop="{{ section.settings.initial_books_desktop }}"
        data-initial-1024="{{ section.settings.initial_books_1024 }}"
        data-initial-768="{{ section.settings.initial_books_768 }}"
        data-initial-425="{{ section.settings.initial_books_425 }}"
        data-initial-375="{{ section.settings.initial_books_375 }}"
        data-load-desktop="{{ section.settings.load_more_desktop }}"
        data-load-1024="{{ section.settings.load_more_1024 }}"
        data-load-768="{{ section.settings.load_more_768 }}"
        data-load-425="{{ section.settings.load_more_425 }}"
        data-load-375="{{ section.settings.load_more_375 }}"
        data-shelf-image="{% if section.settings.shelf_image != blank %}{{ section.settings.shelf_image | image_url: width: 2400 }}{% endif %}"
      >
        {% for block in section.blocks %}
          {% liquid
            assign product = block.settings.product
            assign current_variant = blank
            if product != blank
              assign current_variant = product.selected_or_first_available_variant
            endif
          %}

          <div
            class="bshelf__item{% if forloop.index > section.settings.initial_books_desktop %} is-hidden-desktop{% endif %}{% if forloop.index > section.settings.initial_books_1024 %} is-hidden-1024{% endif %}{% if forloop.index > section.settings.initial_books_768 %} is-hidden-768{% endif %}{% if forloop.index > section.settings.initial_books_425 %} is-hidden-425{% endif %}{% if forloop.index > section.settings.initial_books_375 %} is-hidden-375{% endif %}"
            data-book-item
            data-index="{{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            <div
              class="bshelf__book bshelf__book--{{ forloop.index }}"
              style="
                --book-width-desktop: {{ block.settings.book_width_desktop }}px;
                --book-width-1024: {{ block.settings.book_width_1024 }}px;
                --book-width-768: {{ block.settings.book_width_768 }}px;
                --book-width-425: {{ block.settings.book_width_425 }}px;
                --book-width-375: {{ block.settings.book_width_375 }}px;

                --book-offset-y: {{ block.settings.book_offset_y }}px;
                --book-offset-y-1024: {{ block.settings.book_offset_y_1024 }}px;
                --book-offset-y-768: {{ block.settings.book_offset_y_768 }}px;
                --book-offset-y-425: {{ block.settings.book_offset_y_425 }}px;
                --book-offset-y-375: {{ block.settings.book_offset_y_375 }}px;

                --book-rotate: {{ block.settings.book_rotate }}deg;
                --book-hover-lift: {{ block.settings.hover_lift }}px;
                --shadow-width: {{ block.settings.shadow_width }}%;
                --shadow-height: {{ block.settings.shadow_height }}px;
                --shadow-blur: {{ block.settings.shadow_blur }}px;
                --shadow-opacity: {{ block.settings.shadow_opacity | divided_by: 100.0 }};
                --shadow-offset-y: {{ block.settings.shadow_offset_y }}px;
                --book-z: {{ block.settings.book_z_index }};
              "
            >
              <div class="bshelf__book-wrap">
                <div class="bshelf__shadow"></div>

                <div class="bshelf__media">
                  {% if product != blank %}
                    <a href="{{ product.url }}" class="bshelf__link" aria-label="{{ product.title | escape }}">
                  {% endif %}

                  {% if block.settings.book_image != blank %}
                    {{
                      block.settings.book_image
                      | image_url: width: 1200
                      | image_tag:
                        class: 'bshelf__img',
                        loading: 'lazy',
                        widths: '240,360,480,720,960,1200'
                    }}
                  {% elsif product != blank and product.featured_image != blank %}
                    {{
                      product.featured_image
                      | image_url: width: 1200
                      | image_tag:
                        class: 'bshelf__img',
                        loading: 'lazy',
                        widths: '240,360,480,720,960,1200'
                    }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'bshelf__placeholder' }}
                  {% endif %}

                  {% if product != blank %}
                    </a>
                  {% endif %}

                  {% if product != blank and current_variant != blank %}
                    <div class="bshelf__cta">
                      <button
                        type="button"
                        class="bshelf__btn"
                        data-book-add
                        data-variant-id="{{ current_variant.id }}"
                        {% unless current_variant.available %}disabled{% endunless %}
                      >
                        {% if current_variant.available %}
                          {{ block.settings.button_text }}
                        {% else %}
                          SOLD OUT
                        {% endif %}
                      </button>
                    </div>
                  {% endif %}
                </div>

                {% if section.settings.show_product_title and product != blank %}
                  <div class="bshelf__meta">
                    <a href="{{ product.url }}" class="bshelf__title-link">
                      <div class="bshelf__title">{{ product.title }}</div>
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="bshelf__loadmore-wrap">
          <button type="button" class="bshelf__loadmore" data-load-more>
            {{ section.settings.load_more_label }}
          </button>
        </div>
      {% endif %}
    </div>
  </div>

  <style>
    #{{ sid }} {
      --bg-color: {{ section.settings.bg_color }};
      --glow-color: {{ section.settings.glow_color }};
      --content-max-width: {{ section.settings.content_max_width }}px;

      --section-pad-top-desktop: {{ section.settings.padding_top_desktop }}px;
      --section-pad-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;

      --section-pad-top-1024: {{ section.settings.padding_top_1024 }}px;
      --section-pad-bottom-1024: {{ section.settings.padding_bottom_1024 }}px;

      --section-pad-top-768: {{ section.settings.padding_top_768 }}px;
      --section-pad-bottom-768: {{ section.settings.padding_bottom_768 }}px;

      --section-pad-top-425: {{ section.settings.padding_top_425 }}px;
      --section-pad-bottom-425: {{ section.settings.padding_bottom_425 }}px;

      --section-pad-top-375: {{ section.settings.padding_top_375 }}px;
      --section-pad-bottom-375: {{ section.settings.padding_bottom_375 }}px;

      --books-gap-desktop: {{ section.settings.books_gap_desktop }}px;
      --books-gap-1024: {{ section.settings.books_gap_1024 }}px;
      --books-gap-768: {{ section.settings.books_gap_768 }}px;
      --books-gap-425: {{ section.settings.books_gap_425 }}px;
      --books-gap-375: {{ section.settings.books_gap_375 }}px;

      --row-gap-desktop: {{ section.settings.row_gap_desktop }}px;
      --row-gap-1024: {{ section.settings.row_gap_1024 }}px;
      --row-gap-768: {{ section.settings.row_gap_768 }}px;
      --row-gap-425: {{ section.settings.row_gap_425 }}px;
      --row-gap-375: {{ section.settings.row_gap_375 }}px;

      --books-bottom-desktop: {{ section.settings.books_bottom_desktop }}px;
      --books-bottom-1024: {{ section.settings.books_bottom_1024 }}px;
      --books-bottom-768: {{ section.settings.books_bottom_768 }}px;
      --books-bottom-425: {{ section.settings.books_bottom_425 }}px;
      --books-bottom-375: {{ section.settings.books_bottom_375 }}px;

      --btn-text: {{ section.settings.button_text_color }};
      --btn-radius: {{ section.settings.button_radius }}px;
      --btn-font-size: {{ section.settings.button_font_size }}px;
      --btn-py: {{ section.settings.button_padding_y }}px;
      --btn-px: {{ section.settings.button_padding_x }}px;

      --title-color: {{ section.settings.title_color }};
      --loadmore-bg: {{ section.settings.load_more_bg }};
      --loadmore-text: {{ section.settings.load_more_text }};
      --loadmore-border: {{ section.settings.load_more_border }};
    }

    #{{ sid }}.bshelf {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at 50% 35%, var(--glow-color) 0%, rgba(0, 0, 0, 0) 38%),
        var(--bg-color);
      padding-top: var(--section-pad-top-desktop);
      padding-bottom: var(--section-pad-bottom-desktop);
    }

    #{{ sid }} .bshelf__outer {
      max-width: var(--content-max-width);
      margin: 0 auto;
    }

    #{{ sid }} .bshelf__inner {
      position: relative;
    }

    #{{ sid }} .bshelf__grid {
      display: flex;
      flex-direction: column;
      gap: var(--row-gap-desktop);
    }

    #{{ sid }} .bshelf__shelf-row {
      position: relative;
      width: 100%;
    }

    #{{ sid }} .bshelf__books-row {
      position: relative;
      z-index: 5;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      column-gap: var(--books-gap-desktop);
      align-items: end;
      margin-bottom: calc(var(--books-bottom-desktop) * -1);
      min-height: 120px;
    }

    #{{ sid }} .bshelf__shelf-row-image {
      position: relative;
      z-index: 2;
      line-height: 0;
      width: 100%;
    }

    #{{ sid }} .bshelf__shelf-row-image img {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
      user-select: none;
      pointer-events: none;
    }

    #{{ sid }} .bshelf__item {
      min-width: 0;
      display: flex;
      justify-content: center;
    }

    #{{ sid }} .bshelf__item.is-hidden-desktop,
    #{{ sid }} .bshelf__item.is-hidden-1024,
    #{{ sid }} .bshelf__item.is-hidden-768,
    #{{ sid }} .bshelf__item.is-hidden-425,
    #{{ sid }} .bshelf__item.is-hidden-375 {
      display: none;
    }

    #{{ sid }} .bshelf__book {
      position: relative;
      width: var(--book-width-desktop);
      max-width: 100%;
      flex: 0 0 auto;
      transform: translateY(var(--book-offset-y)) rotate(var(--book-rotate));
      transition: transform 0.35s ease, z-index 0.2s ease;
      z-index: var(--book-z);
    }

    #{{ sid }} .bshelf__book:hover,
    #{{ sid }} .bshelf__book:focus-within {
      transform: translateY(calc(var(--book-offset-y) - var(--book-hover-lift))) rotate(var(--book-rotate));
      z-index: 30;
    }

    #{{ sid }} .bshelf__book-wrap {
      position: relative;
      overflow: visible;
    }

    #{{ sid }} .bshelf__shadow {
      position: absolute;
      left: 50%;
      bottom: calc(var(--shadow-offset-y) * -1);
      width: var(--shadow-width);
      height: var(--shadow-height);
      transform: translateX(-50%);
      border-radius: 999px;
      background: rgba(0, 0, 0, var(--shadow-opacity));
      filter: blur(var(--shadow-blur));
      z-index: 1;
      pointer-events: none;
      transition: all 0.35s ease;
    }

    #{{ sid }} .bshelf__book:hover .bshelf__shadow,
    #{{ sid }} .bshelf__book:focus-within .bshelf__shadow {
      transform: translateX(-50%) scale(1.08);
    }

    #{{ sid }} .bshelf__media {
      position: relative;
      z-index: 3;
      overflow: visible;
    }

    #{{ sid }} .bshelf__link {
      display: block;
      position: relative;
      z-index: 2;
      line-height: 0;
    }

    #{{ sid }} .bshelf__img,
    #{{ sid }} .bshelf__placeholder {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
      filter: drop-shadow(0 12px 22px rgba(0, 0, 0, 0.26));
    }

    #{{ sid }} .bshelf__cta {
      position: absolute;
      left: 50%;
      bottom: 10%;
      transform: translateX(-50%) translateY(12px);
      width: calc(100% - 16px);
      max-width: 220px;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      z-index: 50;
      transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
    }

    #{{ sid }} .bshelf__book:hover .bshelf__cta,
    #{{ sid }} .bshelf__book:focus-within .bshelf__cta {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }

    #{{ sid }} .bshelf__btn {
      width: 100%;
      border: 0;
      height: 50px;
      appearance: none;
      cursor: pointer;
      border-radius: var(--btn-radius);
      padding: var(--btn-py) var(--btn-px);
      background-repeat: no-repeat;
      background-size: cover;
      background-position: center;
      background-image: url('https://cdn.shopify.com/s/files/1/0589/1719/1777/files/f89b1c50a8a368abe48fc6793fd85a8999a3c0ca.png?v=1775475634');
      color: var(--btn-text);
      font-size: var(--btn-font-size);
      line-height: 1;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-family: inherit;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.24);
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    #{{ sid }} .bshelf__btn:hover {
      transform: translateY(-1px);
    }

    #{{ sid }} .bshelf__btn[disabled] {
      opacity: 0.6;
      cursor: not-allowed;
    }

    #{{ sid }} .bshelf__meta {
      margin-top: 10px;
      text-align: center;
    }

    #{{ sid }} .bshelf__title-link {
      display: block;
      text-decoration: none;
    }

    #{{ sid }} .bshelf__title-link:hover .bshelf__title {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    #{{ sid }} .bshelf__title {
      color: var(--title-color);
      font-size: 14px;
      line-height: 1.35;
    }

    #{{ sid }} .bshelf__loadmore-wrap {
      margin-top: 40px;
      text-align: center;
    }

    #{{ sid }} .bshelf__loadmore {
      appearance: none;
      border: 1px solid var(--loadmore-border);
      background: var(--loadmore-bg);
      color: var(--loadmore-text);
      border-radius: 999px;
      padding: 14px 28px;
      cursor: pointer;
      line-height: 1;
      font-family: inherit;
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    #{{ sid }} .bshelf__loadmore:hover {
      transform: translateY(-1px);
    }

    #{{ sid }} .bshelf__loadmore.is-hidden {
      display: none;
    }

    @media screen and (max-width: 1024px) {
      #{{ sid }}.bshelf {
        padding-top: var(--section-pad-top-1024);
        padding-bottom: var(--section-pad-bottom-1024);
      }

      #{{ sid }} .bshelf__grid {
        gap: var(--row-gap-1024);
      }

      #{{ sid }} .bshelf__books-row {
        grid-template-columns: repeat(3, minmax(0, 1fr));
