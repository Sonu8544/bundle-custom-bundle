{% comment %} {% liquid
  assign sid = 'rb-scroll-' | append: section.id
%}

<section
  id="{{ sid }}"
  class="rb-scroll-section"
  style="
    --rb-bg: {{ section.settings.section_bg }};
    --rb-text: {{ section.settings.text_color }};
    --rb-accent: {{ section.settings.accent_color }};
    --rb-maxw-d: {{ section.settings.max_width_desktop }}px;
    --rb-maxw-m: {{ section.settings.max_width_mobile }}px;
    --rb-min-body-d: {{ section.settings.min_body_height_desktop }}px;
    --rb-max-body-d: {{ section.settings.max_body_height_desktop }}px;
    --rb-min-body-m: {{ section.settings.min_body_height_mobile }}px;
    --rb-max-body-m: {{ section.settings.max_body_height_mobile }}px;
    --rb-content-w-d: {{ section.settings.content_width_desktop }}%;
    --rb-content-w-m: {{ section.settings.content_width_mobile }}%;
    --rb-pad-x-d: {{ section.settings.content_pad_x_desktop }}px;
    --rb-pad-y-d: {{ section.settings.content_pad_y_desktop }}px;
    --rb-pad-x-m: {{ section.settings.content_pad_x_mobile }}px;
    --rb-pad-y-m: {{ section.settings.content_pad_y_mobile }}px;
    --rb-head-size-d: {{ section.settings.heading_size_desktop }}px;
    --rb-head-size-m: {{ section.settings.heading_size_mobile }}px;
    --rb-body-size-d: {{ section.settings.body_size_desktop }}px;
    --rb-body-size-m: {{ section.settings.body_size_mobile }}px;
    --rb-line-d: {{ section.settings.body_line_height_desktop | times: 0.1 }};
    --rb-line-m: {{ section.settings.body_line_height_mobile | times: 0.1 }};
    --rb-section-pt-d: {{ section.settings.padding_top_desktop }}px;
    --rb-section-pb-d: {{ section.settings.padding_bottom_desktop }}px;
    --rb-section-pt-m: {{ section.settings.padding_top_mobile }}px;
    --rb-section-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --rb-shadow-opacity: {{ section.settings.shadow_opacity | divided_by: 100.0 }};
    --rb-open-range: {{ section.settings.scroll_open_distance }}px;
    --rb-tilt-top: {{ section.settings.top_roll_degrees }}deg;
    --rb-tilt-bottom: {{ section.settings.bottom_roll_degrees }}deg;
    --rb-roller-gap: {{ section.settings.roller_overlap }}px;
    --rb-paper-radius: {{ section.settings.paper_radius }}px;
  "
>
  <div class="rb-scroll-shell page-width {% if section.settings.full_width %}rb-scroll-shell--full{% endif %}">
    <div class="rb-scroll-stage" data-scroll-stage>
      <div class="rb-scroll-wrap" data-scroll-wrap>
        <div class="rb-scroll-roller rb-scroll-roller--top" data-top-roller>
          <div class="rb-scroll-roller__img rb-scroll-roller__img--desktop">
            {% if section.settings.top_roller_desktop != blank %}
              {{
                section.settings.top_roller_desktop
                | image_url: width: 2400
                | image_tag:
                  loading: 'lazy',
                  widths: '500, 800, 1100, 1400, 1800, 2200, 2400',
                  class: 'rb-scroll-roller__asset',
                  alt: section.settings.heading_plain
              }}
            {% endif %}
          </div>
          <div class="rb-scroll-roller__img rb-scroll-roller__img--mobile">
            {% if section.settings.top_roller_mobile != blank %}
              {{
                section.settings.top_roller_mobile
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  widths: '360, 540, 720, 960, 1200, 1400',
                  class: 'rb-scroll-roller__asset',
                  alt: section.settings.heading_plain
              }}
            {% elsif section.settings.top_roller_desktop != blank %}
              {{
                section.settings.top_roller_desktop
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  widths: '360, 540, 720, 960, 1200, 1400',
                  class: 'rb-scroll-roller__asset',
                  alt: section.settings.heading_plain
              }}
            {% endif %}
          </div>
          <span class="rb-scroll-roller__shadow"></span>
        </div>

        <div class="rb-scroll-paper" data-paper>
          <div class="rb-scroll-paper__bg rb-scroll-paper__bg--desktop">
            {% if section.settings.paper_body_desktop != blank %}
              {{
                section.settings.paper_body_desktop
                | image_url: width: 2000
                | image_tag:
                  loading: 'lazy',
                  widths: '500, 800, 1100, 1400, 1800, 2000',
                  class: 'rb-scroll-paper__bg-image',
                  alt: section.settings.heading_plain
              }}
            {% endif %}
          </div>

          <div class="rb-scroll-paper__bg rb-scroll-paper__bg--mobile">
            {% if section.settings.paper_body_mobile != blank %}
              {{
                section.settings.paper_body_mobile
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  widths: '360, 540, 720, 960, 1200, 1400',
                  class: 'rb-scroll-paper__bg-image',
                  alt: section.settings.heading_plain
              }}
            {% elsif section.settings.paper_body_desktop != blank %}
              {{
                section.settings.paper_body_desktop
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  widths: '360, 540, 720, 960, 1200, 1400',
                  class: 'rb-scroll-paper__bg-image',
                  alt: section.settings.heading_plain
              }}
            {% endif %}
          </div>

          {% if section.settings.paper_overlay_texture != blank %}
            <div class="rb-scroll-paper__texture">
              {{
                section.settings.paper_overlay_texture
                | image_url: width: 1800
                | image_tag:
                  loading: 'lazy',
                  widths: '400, 800, 1200, 1600, 1800',
                  class: 'rb-scroll-paper__texture-image',
                  alt: ''
              }}
            </div>
          {% endif %}

          <div class="rb-scroll-content" data-content>
            {% if section.settings.eyebrow != blank %}
              <p class="rb-scroll-content__eyebrow">{{ section.settings.eyebrow }}</p>
            {% endif %}

            {% if section.settings.heading_plain != blank or section.settings.heading_accent != blank %}
              <h2 class="rb-scroll-content__heading">
                <span>{{ section.settings.heading_plain }}</span>
                {% if section.settings.heading_accent != blank %}
                  <span class="rb-scroll-content__heading-accent"> {{ section.settings.heading_accent }}</span>
                {% endif %}
              </h2>
            {% endif %}

            {% if section.settings.divider_image != blank %}
              <div class="rb-scroll-content__divider rb-scroll-content__divider--image">
                {{
                  section.settings.divider_image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    widths: '200, 400, 600, 800',
                    class: 'rb-scroll-content__divider-image',
                    alt: ''
                }}
              </div>
            {% elsif section.settings.show_default_divider %}
              <div class="rb-scroll-content__divider rb-scroll-content__divider--default" aria-hidden="true">
                <span></span>
              </div>
            {% endif %}

            {% if section.settings.body != blank %}
              <div class="rb-scroll-content__body rte">
                {{ section.settings.body }}
              </div>
            {% endif %}
          </div>
        </div>

        <div class="rb-scroll-roller rb-scroll-roller--bottom" data-bottom-roller>
          <span class="rb-scroll-roller__shadow"></span>
          <div class="rb-scroll-roller__img rb-scroll-roller__img--desktop">
            {% if section.settings.bottom_roller_desktop != blank %}
              {{
                section.settings.bottom_roller_desktop
                | image_url: width: 2400
                | image_tag:
                  loading: 'lazy',
                  widths: '500, 800, 1100, 1400, 1800, 2200, 2400',
                  class: 'rb-scroll-roller__asset',
                  alt: section.settings.heading_plain
              }}
            {% endif %}
          </div>
          <div class="rb-scroll-roller__img rb-scroll-roller__img--mobile">
            {% if section.settings.bottom_roller_mobile != blank %}
              {{
                section.settings.bottom_roller_mobile
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  widths: '360, 540, 720, 960, 1200, 1400',
                  class: 'rb-scroll-roller__asset',
                  alt: section.settings.heading_plain
              }}
            {% elsif section.settings.bottom_roller_desktop != blank %}
              {{
                section.settings.bottom_roller_desktop
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  widths: '360, 540, 720, 960, 1200, 1400',
                  class: 'rb-scroll-roller__asset',
                  alt: section.settings.heading_plain
              }}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    #{{ sid }}{
      background: var(--rb-bg);
      padding-top: var(--rb-section-pt-d);
      padding-bottom: var(--rb-section-pb-d);
      overflow: clip;
    }

    #{{ sid }} .rb-scroll-shell{
      position: relative;
    }

    #{{ sid }} .rb-scroll-shell--full{
      max-width: 100%;
      padding-left: 0;
      padding-right: 0;
    }

    #{{ sid }} .rb-scroll-stage{
      position: relative;
      width: min(100%, var(--rb-maxw-d));
      margin: 0 auto;
      perspective: 1400px;
      perspective-origin: 50% 45%;
    }

    #{{ sid }} .rb-scroll-wrap{
      position: relative;
      width: 100%;
      transform-style: preserve-3d;
      --scroll-progress: 0;
    }

    #{{ sid }} .rb-scroll-roller{
      position: relative;
      z-index: 5;
      width: 100%;
      transform-style: preserve-3d;
      will-change: transform;
      transition: transform 0.16s linear;
    }

    #{{ sid }} .rb-scroll-roller--top{
      margin-bottom: calc(var(--rb-roller-gap) * -1);
      transform-origin: center center;
      transform: translate3d(0, 0, 30px) rotateX(calc(var(--scroll-progress) * var(--rb-tilt-top)));
    }

    #{{ sid }} .rb-scroll-roller--bottom{
      margin-top: calc(var(--rb-roller-gap) * -1);
      transform-origin: center center;
      transform: translate3d(0, 0, 30px) rotateX(calc(var(--scroll-progress) * var(--rb-tilt-bottom)));
    }

    #{{ sid }} .rb-scroll-roller__img{
      display: block;
      line-height: 0;
    }

    #{{ sid }} .rb-scroll-roller__img--mobile{
      display: none;
    }

    #{{ sid }} .rb-scroll-roller__asset{
      display: block;
      width: 100%;
      height: auto;
    }

    #{{ sid }} .rb-scroll-roller__shadow{
      position: absolute;
      left: 8%;
      right: 8%;
      height: 22px;
      pointer-events: none;
      opacity: calc(var(--scroll-progress) * var(--rb-shadow-opacity));
      background: radial-gradient(ellipse at center, rgba(0,0,0,0.58) 0%, rgba(0,0,0,0.18) 48%, rgba(0,0,0,0) 78%);
      transition: opacity 0.16s linear;
    }

    #{{ sid }} .rb-scroll-roller--top .rb-scroll-roller__shadow{
      bottom: -10px;
    }

    #{{ sid }} .rb-scroll-roller--bottom .rb-scroll-roller__shadow{
      top: -10px;
    }

    #{{ sid }} .rb-scroll-paper{
      position: relative;
      z-index: 2;
      width: 100%;
      min-height: var(--rb-min-body-d);
      height: var(--rb-min-body-d);
      overflow: hidden;
      border-radius: var(--rb-paper-radius);
      will-change: height, transform;
      transition: height 0.22s ease, transform 0.16s linear;
      transform: translate3d(0, 0, 0) scaleY(calc(0.92 + (var(--scroll-progress) * 0.08)));
      box-shadow: 0 18px 50px rgba(0,0,0,0.16);
    }

    #{{ sid }} .rb-scroll-paper__bg,
    #{{ sid }} .rb-scroll-paper__texture{
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    #{{ sid }} .rb-scroll-paper__bg--mobile{
      display: none;
    }

    #{{ sid }} .rb-scroll-paper__bg-image,
    #{{ sid }} .rb-scroll-paper__texture-image{
      width: 100%;
      height: 100%;
      display: block;
      object-fit: fill;
    }

    #{{ sid }} .rb-scroll-paper__texture{
      mix-blend-mode: multiply;
      opacity: 0.28;
    }

    #{{ sid }} .rb-scroll-content{
      position: relative;
      z-index: 2;
      width: min(var(--rb-content-w-d), 100%);
      margin: 0 auto;
      padding: var(--rb-pad-y-d) var(--rb-pad-x-d);
      color: var(--rb-text);
      text-align: center;
    }

    #{{ sid }} .rb-scroll-content__eyebrow{
      margin: 0 0 12px;
      font-size: 14px;
      line-height: 1;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--rb-accent);
    }

    #{{ sid }} .rb-scroll-content__heading{
      margin: 0;
      font-size: var(--rb-head-size-d);
      line-height: 1.04;
      font-weight: 400;
      color: var(--rb-text);
    }

    #{{ sid }} .rb-scroll-content__heading-accent{
      color: var(--rb-accent);
    }

    #{{ sid }} .rb-scroll-content__divider{
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 24px auto 28px;
    }

    #{{ sid }} .rb-scroll-content__divider--default span{
      display: block;
      width: min(180px, 45vw);
      height: 1px;
      background: linear-gradient(90deg, transparent 0%, rgba(164,124,58,0.4) 20%, rgba(164,124,58,0.95) 50%, rgba(164,124,58,0.4) 80%, transparent 100%);
      position: relative;
    }

    #{{ sid }} .rb-scroll-content__divider--default span::before,
    #{{ sid }} .rb-scroll-content__divider--default span::after{
      content: "";
      position: absolute;
      top: 50%;
      width: 8px;
      height: 8px;
      border: 1px solid rgba(164,124,58,0.7);
      border-radius: 50%;
      transform: translateY(-50%);
    }

    #{{ sid }} .rb-scroll-content__divider--default span::before{
      left: -14px;
    }

    #{{ sid }} .rb-scroll-content__divider--default span::after{
      right: -14px;
    }

    #{{ sid }} .rb-scroll-content__divider-image{
      display: block;
      width: auto;
      max-width: min(240px, 65%);
      height: auto;
    }

    #{{ sid }} .rb-scroll-content__body{
      font-size: var(--rb-body-size-d);
      line-height: var(--rb-line-d);
      color: var(--rb-text);
      max-width: 100%;
      margin: 0 auto;
    }

    #{{ sid }} .rb-scroll-content__body p{
      margin: 0 0 14px;
    }

    #{{ sid }} .rb-scroll-content__body p:last-child{
      margin-bottom: 0;
    }

    #{{ sid }} .rb-scroll-content__body strong{
      font-weight: 700;
    }

    #{{ sid }} .rb-scroll-content__body a{
      color: inherit;
    }

    @media screen and (max-width: 989px){
      #{{ sid }}{
        padding-top: var(--rb-section-pt-m);
        padding-bottom: var(--rb-section-pb-m);
      }

      #{{ sid }} .rb-scroll-stage{
        width: min(100%, var(--rb-maxw-m));
      }

      #{{ sid }} .rb-scroll-roller__img--desktop,
      #{{ sid }} .rb-scroll-paper__bg--desktop{
        display: none;
      }

      #{{ sid }} .rb-scroll-roller__img--mobile,
      #{{ sid }} .rb-scroll-paper__bg--mobile{
        display: block;
      }

      #{{ sid }} .rb-scroll-paper{
        min-height: var(--rb-min-body-m);
        height: var(--rb-min-body-m);
      }

      #{{ sid }} .rb-scroll-content{
        width: min(var(--rb-content-w-m), 100%);
        padding: var(--rb-pad-y-m) var(--rb-pad-x-m);
      }

      #{{ sid }} .rb-scroll-content__eyebrow{
        font-size: 12px;
        margin-bottom: 10px;
      }

      #{{ sid }} .rb-scroll-content__heading{
        font-size: var(--rb-head-size-m);
      }

      #{{ sid }} .rb-scroll-content__divider{
        margin: 18px auto 22px;
      }

      #{{ sid }} .rb-scroll-content__body{
        font-size: var(--rb-body-size-m);
        line-height: var(--rb-line-m);
      }

      #{{ sid }} .rb-scroll-roller__shadow{
        left: 10%;
        right: 10%;
        height: 18px;
      }
    }
  </style>

  <script>
    (() => {
      const section = document.getElementById('{{ sid }}');
      if (!section) return;

      const wrap = section.querySelector('[data-scroll-wrap]');
      const paper = section.querySelector('[data-paper]');
      const content = section.querySelector('[data-content]');
      if (!wrap || !paper || !content) return;

      let ticking = false;
      let lastProgress = -1;

      function getIsMobile() {
        return window.matchMedia('(max-width: 989px)').matches;
      }

      function clamp(value, min, max) {
        return Math.max(min, Math.min(max, value));
      }

      function getTargetBodyHeight() {
        const styles = getComputedStyle(section);
        const isMobile = getIsMobile();

        const minHeight = parseFloat(styles.getPropertyValue(isMobile ? '--rb-min-body-m' : '--rb-min-body-d')) || 0;
        const maxHeight = parseFloat(styles.getPropertyValue(isMobile ? '--rb-max-body-m' : '--rb-max-body-d')) || 9999;

        const contentHeight = Math.ceil(content.scrollHeight);
        const target = contentHeight;

        return clamp(target, minHeight, maxHeight);
      }

      function applyHeight(progress) {
        const styles = getComputedStyle(section);
        const isMobile = getIsMobile();

        const minHeight = parseFloat(styles.getPropertyValue(isMobile ? '--rb-min-body-m' : '--rb-min-body-d')) || 0;
        const targetHeight = getTargetBodyHeight();
        const openHeight = minHeight + ((targetHeight - minHeight) * progress);

        paper.style.height = openHeight.toFixed(2) + 'px';
      }

      function updateProgress() {
        ticking = false;

        const rect = section.getBoundingClientRect();
        const styles = getComputedStyle(section);
        const openRange = parseFloat(styles.getPropertyValue('--rb-open-range')) || window.innerHeight;

        const viewportTrigger = window.innerHeight * 0.82;
        const distance = viewportTrigger - rect.top;
        const progress = clamp(distance / openRange, 0, 1);

        if (Math.abs(progress - lastProgress) < 0.002) return;
        lastProgress = progress;

        wrap.style.setProperty('--scroll-progress', progress.toFixed(4));
        applyHeight(progress);
      }

      function requestUpdate() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(updateProgress);
      }

      function refresh() {
        applyHeight(lastProgress > -1 ? lastProgress : 0);
        requestUpdate();
      }

      window.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener('resize', refresh);

      document.addEventListener('shopify:section:load', refresh);
      document.addEventListener('shopify:section:reorder', refresh);
      document.addEventListener('shopify:block:select', refresh);
      document.addEventListener('shopify:block:deselect', refresh);

      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(refresh).catch(() => refresh());
      } else {
        refresh();
      }

      setTimeout(refresh, 80);
      setTimeout(refresh, 300);
    })();
  </script>
</section>

{% schema %}
{
  "name": "Rare Biblio Scroll",
  "tag": "section",
  "class": "section rare-biblio-scroll",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Use full width container",
      "default": false
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#17130f"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#8f722f"
    },

    {
      "type": "header",
      "content": "Desktop assets"
    },
    {
      "type": "image_picker",
      "id": "top_roller_desktop",
      "label": "Top roller image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "paper_body_desktop",
      "label": "Paper body image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "bottom_roller_desktop",
      "label": "Bottom roller image (desktop)"
    },

    {
      "type": "header",
      "content": "Mobile assets"
    },
    {
      "type": "image_picker",
      "id": "top_roller_mobile",
      "label": "Top roller image (mobile)"
    },
    {
      "type": "image_picker",
      "id": "paper_body_mobile",
      "label": "Paper body image (mobile)"
    },
    {
      "type": "image_picker",
      "id": "bottom_roller_mobile",
      "label": "Bottom roller image (mobile)"
    },
    {
      "type": "image_picker",
      "id": "paper_overlay_texture",
      "label": "Optional parchment texture overlay"
    },

    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "About us"
    },
    {
      "type": "text",
      "id": "heading_plain",
      "label": "Heading first part",
      "default": "About Rare"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent part",
      "default": "Biblio"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Welcome to Rare Biblio, the premier destination for bibliophiles and book lovers who appreciate the art of bookmaking. As a rare books store, we specialize in handcrafted leather-bound books, personalization and customization services, and restoration of valuable old books, antiquarian books, and manuscripts.</p>"
    },
    {
      "type": "image_picker",
      "id": "divider_image",
      "label": "Custom divider image"
    },
    {
      "type": "checkbox",
      "id": "show_default_divider",
      "label": "Show default divider if no image is uploaded",
      "default": true
    },

    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width_desktop",
      "label": "Max width desktop",
      "min": 700,
      "max": 1600,
      "step": 10,
      "default": 980
    },
    {
      "type": "range",
      "id": "max_width_mobile",
      "label": "Max width mobile",
      "min": 260,
      "max": 700,
      "step": 10,
      "default": 520
    },
    {
      "type": "range",
      "id": "content_width_desktop",
      "label": "Content width desktop",
      "min": 35,
      "max": 90,
      "step": 1,
      "default": 64
    },
    {
      "type": "range",
      "id": "content_width_mobile",
      "label": "Content width mobile",
      "min": 70,
      "max": 96,
      "step": 1,
      "default": 84
    },
    {
      "type": "range",
      "id": "content_pad_x_desktop",
      "label": "Content side padding desktop",
      "min": 10,
      "max": 120,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "content_pad_y_desktop",
      "label": "Content top-bottom padding desktop",
      "min": 20,
      "max": 180,
      "step": 2,
      "default": 64
    },
    {
      "type": "range",
      "id": "content_pad_x_mobile",
      "label": "Content side padding mobile",
      "min": 8,
      "max": 60,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "content_pad_y_mobile",
      "label": "Content top-bottom padding mobile",
      "min": 16,
      "max": 100,
      "step": 2,
      "default": 34
    },
    {
      "type": "range",
      "id": "min_body_height_desktop",
      "label": "Closed paper height desktop",
      "min": 40,
      "max": 240,
