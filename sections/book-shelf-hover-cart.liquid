  }

  function updateDrawerWithDawn(addData, triggerButton) {
    const drawer = document.querySelector('cart-drawer');
    if (!drawer || !addData || !addData.sections) return false;

    if (typeof drawer.renderContents === 'function') {
      try {
        drawer.renderContents({
          id: addData.key,
          sections: addData.sections,
          items: addData.items || [],
          product_id: addData.product_id || null
        });

        if (triggerButton && typeof drawer.setActiveElement === 'function') {
          drawer.setActiveElement(triggerButton);
