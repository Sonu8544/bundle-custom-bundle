{% comment %} 

{{ 'exclusive-book-product.css' | asset_url | stylesheet_tag }}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Satoshi:wght@300;400;500&display=swap" rel="stylesheet">

<section
  id="exclusive-book-product-{{ section.id }}"
  class="exclusive-book-product"
  style="
    --section-bg: {{ section.settings.background_color }};
    --gradient-start: {{ section.settings.gradient_start }};
    --gradient-mid: {{ section.settings.gradient_mid }};
    --gradient-end: {{ section.settings.gradient_end }};
    --gradient-angle: {{ section.settings.gradient_angle }}deg;
    --accent-gold: #C9A885;
    --accent-gold-deep: #8E7025;
    --text-primary: #FFFFFF;
    --text-muted: #A89880;
  "
>
  {%- if section.settings.background_type == 'gradient' -%}
    <div class="section-bg-gradient"></div>
  {%- elsif section.settings.background_type == 'image' -%}
    <div class="section-bg-image">
      {%- if section.settings.bg_image_desktop != blank -%}
        <img
          src="{{ section.settings.bg_image_desktop | image_url: width: 1920 }}"
          alt=""
          class="bg-img bg-img--desktop"
          loading="lazy"
          width="1920"
          height="1080"
        >
      {%- endif -%}
      {%- if section.settings.bg_image_mobile != blank -%}
        <img
          src="{{ section.settings.bg_image_mobile | image_url: width: 768 }}"
          alt=""
          class="bg-img bg-img--mobile"
          loading="lazy"
          width="768"
          height="1024"
        >
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="exclusive-book-product__inner">

    {%- comment %} LEFT — Product Gallery {%- endcomment %}
    <div class="product-gallery" id="productGallery-{{ section.id }}">
      <div class="product-gallery__main">
        <button class="gallery-zoom-btn" aria-label="Zoom image">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35M11 8v6M8 11h6"/>
          </svg>
        </button>

        {%- if product != blank -%}
          {%- assign featured_image = product.featured_image -%}
          {%- for image in product.images limit: 4 -%}
            <div
              class="gallery-slide {% if forloop.first %}gallery-slide--active{% endif %}"
              data-index="{{ forloop.index0 }}"
            >
              <img
                src="{{ image | image_url: width: 700 }}"
                alt="{{ image.alt | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="700"
                height="900"
              >
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- assign image_keys = 'product_image_1,product_image_2,product_image_3,product_image_4' | split: ',' -%}
          {%- for image_key in image_keys -%}
            <div class="gallery-slide {% if forloop.first %}gallery-slide--active{% endif %}" data-index="{{ forloop.index0 }}">
              {%- assign slide_image = section.settings[image_key] -%}
              {%- if slide_image != blank -%}
                <img
                  src="{{ slide_image | image_url: width: 700 }}"
                  alt="{{ section.settings.product_title | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="700"
                  height="900"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="product-gallery__thumbs" role="list">
        {%- if product != blank -%}
          {%- for image in product.images limit: 4 -%}
            <button
              class="thumb {% if forloop.first %}thumb--active{% endif %}"
              data-target="{{ forloop.index0 }}"
              aria-label="View image {{ forloop.index }}"
              role="listitem"
            >
              <img
                src="{{ image | image_url: width: 120 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="120"
                height="150"
              >
            </button>
          {%- endfor -%}
        {%- else -%}
          {%- assign thumb_keys = 'product_image_1,product_image_2,product_image_3,product_image_4' | split: ',' -%}
          {%- for thumb_key in thumb_keys -%}
            <button
              class="thumb {% if forloop.first %}thumb--active{% endif %}"
              data-target="{{ forloop.index0 }}"
              aria-label="View image {{ forloop.index }}"
              role="listitem"
            >
              {%- assign thumb_image = section.settings[thumb_key] -%}
              {%- if thumb_image != blank -%}
                <img
                  src="{{ thumb_image | image_url: width: 120 }}"
                  alt=""
                  loading="lazy"
                  width="120"
                  height="150"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg thumb-placeholder' }}
              {%- endif -%}
            </button>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment %} RIGHT — Product Info {%- endcomment %}
    <div class="product-info">

      {%- comment %} Exclusive Badge {%- endcomment %}
      <div class="exclusive-badge">
        <span class="exclusive-badge__text">{{ section.settings.badge_text | default: 'EXCLUSIVE' }}</span>
      </div>

      {%- comment %} Title + Wishlist {%- endcomment %}
      <div class="product-title-row">
        <h1 class="product-title">
          {%- if product != blank -%}
            {{ product.title }}
          {%- else -%}
            {{ section.settings.product_title | default: 'Voyage au centre de la terre' }}
          {%- endif -%}
        </h1>
        {% comment %} <button class="wishlist-btn" aria-label="Add to wishlist">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </button> {% endcomment %}
      </div>

      {%- comment %} Author {%- endcomment %}
      <p class="product-author">
        {%- if product != blank -%}
          {{ product.vendor }}
        {%- else -%}
          {{ section.settings.product_author | default: 'JK Rowling' | upcase }}
        {%- endif -%}
      </p>

      {%- comment %} Signed Copies Badge {%- endcomment %}
      <div class="signed-copies-badge">
       <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
<path d="M21.7497 15.75H5.9866C6.23597 15.2587 6.48628 14.7534 6.7366 14.2397C8.14285 14.3944 9.79097 13.4166 11.6735 11.3203C12.1422 12.5822 13.0282 14.22 14.5403 14.25C15.3897 14.2669 16.2382 13.7625 17.111 12.7153C17.7475 13.4766 19.0591 14.25 21.7497 14.25C21.9486 14.25 22.1394 14.171 22.2801 14.0303C22.4207 13.8897 22.4997 13.6989 22.4997 13.5C22.4997 13.3011 22.4207 13.1103 22.2801 12.9697C22.1394 12.829 21.9486 12.75 21.7497 12.75C18.8969 12.75 18.0532 11.7703 17.9997 11.2397C18.0082 11.0787 17.9623 10.9196 17.8695 10.7879C17.7766 10.6561 17.6423 10.5593 17.4878 10.5131C17.3274 10.4649 17.1556 10.4709 16.9989 10.53C16.8422 10.5891 16.7093 10.6982 16.6207 10.8403C15.4891 12.5784 14.8038 12.7556 14.5657 12.75C13.7913 12.735 13.0038 10.92 12.7338 9.61688C12.705 9.47731 12.637 9.34883 12.5378 9.2465C12.4386 9.14417 12.3123 9.07222 12.1737 9.03907C12.0351 9.00592 11.8899 9.01294 11.7552 9.05932C11.6204 9.1057 11.5017 9.18951 11.4128 9.30094C9.5191 11.6766 8.24972 12.4762 7.45941 12.6834C8.25535 10.9144 8.84972 9.36094 9.23035 8.05313C9.86972 5.85563 9.9166 4.31906 9.37191 3.35625C9.09066 2.85187 8.49628 2.25 7.30378 2.25C5.79816 2.25 4.61035 3.67313 4.0441 6.15469C3.70753 7.6275 3.65222 9.26813 3.89222 10.6547C4.13222 12.0413 4.63003 13.05 5.35378 13.6491C5.0041 14.3728 4.64785 15.0797 4.30097 15.75H2.24972C2.05081 15.75 1.86004 15.829 1.71939 15.9697C1.57874 16.1103 1.49972 16.3011 1.49972 16.5C1.49972 16.6989 1.57874 16.8897 1.71939 17.0303C1.86004 17.171 2.05081 17.25 2.24972 17.25H3.50691C2.44566 19.2188 1.62066 20.5913 1.60753 20.6138C1.55406 20.6982 1.51802 20.7925 1.50151 20.8911C1.485 20.9897 1.48837 21.0906 1.51141 21.1878C1.53445 21.2851 1.5767 21.3768 1.63568 21.4575C1.69466 21.5382 1.76918 21.6063 1.85486 21.6578C1.94053 21.7093 2.03564 21.7431 2.13458 21.7573C2.23352 21.7715 2.33431 21.7658 2.43101 21.7405C2.52772 21.7152 2.61839 21.6709 2.6977 21.61C2.77701 21.5492 2.84336 21.4731 2.89285 21.3862C2.90691 21.3619 3.94941 19.6247 5.20847 17.25H21.7497C21.9486 17.25 22.1394 17.171 22.2801 17.0303C22.4207 16.8897 22.4997 16.6989 22.4997 16.5C22.4997 16.3011 22.4207 16.1103 22.2801 15.9697C22.1394 15.829 21.9486 15.75 21.7497 15.75ZM5.5066 6.48844C5.87972 4.85063 6.60253 3.75 7.30378 3.75C7.80347 3.75 7.96941 3.92437 8.06597 4.09406C8.34722 4.59375 8.67722 6.36187 6.03535 12.1931C5.26097 11.1356 4.99753 8.71875 5.5066 6.48844Z" fill="#C9A885"/>
</svg>
        <span class="signed-copies-badge__text">{{ section.settings.signed_copies_text | default: 'Only 250 Signed Copies' }}</span>
      </div>

      {%- comment %} Price {%- endcomment %}
      <div class="product-price">
        {%- if product != blank -%}
          {%- assign selected_variant = product.selected_or_first_available_variant -%}
          {%- if product.price_varies -%}
            <span class="price-label">From</span>
          {%- endif -%}
          <span
            class="price-amount"
            data-unit-price="{{ selected_variant.price }}"
            data-currency="{{ cart.currency.symbol | default: shop.currency }}"
          >{{ selected_variant.price | money_with_currency }}</span>
          {%- if selected_variant.compare_at_price > selected_variant.price -%}
            <span class="price-compare">{{ selected_variant.compare_at_price | money_with_currency }}</span>
          {%- endif -%}
        {%- else -%}
          <span class="price-amount">{{ section.settings.product_price | default: 'USD 129.00' }}</span>
        {%- endif -%}
      </div>

      {%- comment %} Variant Selector {%- endcomment %}
      {%- if product != blank and product.variants.size > 1 -%}
        <div class="variant-selector">
          {%- for option in product.options_with_values -%}
            <div class="variant-option">
              <label class="variant-option__label">{{ option.name }}</label>
              <div class="variant-option__values">
                {%- for value in option.values -%}
                  <button
                    class="variant-value-btn"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value | escape }}"
                  >{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment %} Quantity + CTA {%- endcomment %}
      <div class="product-actions">
        <div class="quantity-control">
          <button class="qty-btn qty-btn--minus" aria-label="Decrease quantity">
            <svg width="14" height="2" viewBox="0 0 14 2" fill="none"><path d="M1 1H13" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <input
            type="number"
            class="qty-input"
            id="qty-{{ section.id }}"
            name="quantity"
            value="1"
            min="1"
            max="250"
            aria-label="Quantity"
          >
          <button class="qty-btn qty-btn--plus" aria-label="Increase quantity">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1V13M1 7H13" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </div>

        {%- if product != blank -%}
          <button
            type="button"
            class="cta-btn"
            id="addToCart-{{ section.id }}"
            data-product-id="{{ product.id }}"
            data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
          >
            {%- if product.selected_or_first_available_variant.available -%}
              {{ section.settings.cta_label | default: 'PRE ORDER NOW' }}
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        {%- else -%}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="cta-btn">
            {{ section.settings.cta_label | default: 'PRE ORDER NOW' }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>

  {%- comment %} Lightbox / Zoom overlay {%- endcomment %}
  <div class="gallery-lightbox" id="lightbox-{{ section.id }}" aria-hidden="true">
    <button class="lightbox-close" aria-label="Close zoom">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    <div class="lightbox-img-wrap">
      <img src="" alt="" class="lightbox-img" id="lightboxImg-{{ section.id }}">
    </div>
  </div>
</section>

<style>
/* =============================================
   EXCLUSIVE BOOK PRODUCT — SECTION STYLES
   ============================================= */

/* Font imports (fallback to serif for Bethany Ellington) */
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Satoshi:wght@300;400;500&display=swap');

/* Custom font declaration - Bethany Ellington must be uploaded to Shopify assets */
@font-face {
  font-family: 'Bethany Ellington';
  src: url('{{ "BethanyEllington.woff2" | asset_url }}') format('woff2'),
       url('{{ "BethanyEllington.woff" | asset_url }}') format('woff');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

/* Fallback stack if Bethany Ellington is not uploaded */
:root {
  --font-display: 'Bethany Ellington', 'Cormorant Garamond', 'Playfair Display', Georgia, serif;
  --font-body: 'Satoshi', 'DM Sans', system-ui, sans-serif;
}

#exclusive-book-product-{{ section.id }} {
  position: relative;
  background-color: var(--section-bg, #0D0D0B);
  min-height: 100vh;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Background layers */
.section-bg-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    var(--gradient-angle, 135deg),
    var(--gradient-start, #0D0D0B) 0%,
    var(--gradient-mid, #1A1510) 50%,
    var(--gradient-end, #0D0D0B) 100%
  );
  pointer-events: none;
  z-index: 0;
}

.section-bg-image {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}
.section-bg-image .bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
.section-bg-image .bg-img--mobile { display: none; }

/* Inner layout */
.exclusive-book-product__inner {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: 80px 40px;
  align-items: center;
}

/* ── Gallery ────────────────── */
.product-gallery {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.product-gallery__main {
  position: relative;
  width: 100%;
  aspect-ratio: 0.75 / 1;
  border-radius: 4px;
  overflow: hidden;
  background: #111;
}

.gallery-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}
.gallery-slide--active {
  opacity: 1;
  pointer-events: auto;
}
.gallery-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Placeholder SVG fill */
.gallery-slide .placeholder-svg,
.thumb-placeholder {
  width: 100%;
  height: 100%;
  fill: #2A2520;
  color: #5A4A3A;
}

.gallery-zoom-btn {
  position: absolute;
  top: 14px;
  left: 14px;
  z-index: 2;
  width: 40px;
  height: 40px;
  border-radius: 6px;
  background: rgba(255,255,255,0.92);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #222;
  transition: background 0.2s;
}
.gallery-zoom-btn:hover { background: #fff; }

.product-gallery__thumbs {
  display: flex;
  gap: 14px;
}

.thumb {
  width: 25%;
  aspect-ratio: 0.78 / 1;
  border-radius: 3px;
  overflow: hidden;
  background: #111;
  border: 1px solid transparent;
  cursor: pointer;
  padding: 0;
  transition: border-color 0.2s;
}
.thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.thumb--active {
  border-color: var(--accent-gold);
}
.thumb:hover:not(.thumb--active) {
  border-color: rgba(201, 168, 133, 0.4);
}

/* ── Product Info ────────────── */
.product-info {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 100px;
}

/* Exclusive badge */
.exclusive-badge {
    margin-bottom:20px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0px;
gap: 30px;
  width: 172px;
height: 39px;
  padding: 10px 22px;
  border-radius: 4px;
  color: #fff8e7;
 background: linear-gradient(270deg, rgba(142, 112, 37, 0) 0%, rgba(142, 112, 37, 0.854796) 78.75%, rgba(142, 112, 37, 0) 100%);
  box-shadow: 0 10px 32px rgba(0,0,0,.24);
  font-family: "Bethany Elingston", serif;
  font-size: 18px;
  line-height: 1;
  letter-spacing: 0;
}

.exclusive-badge__text {
  font-family: var(--font-display);
  font-weight: 400;
  font-style: normal;
  font-size: 14px;
  line-height: 22px;
  letter-spacing: 0.12em;
  color: #F5E6CF;
  text-transform: uppercase;
}

/* Title row */
.product-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 16px;
}

.product-title {
  font-family: var(--font-display);
  font-weight: 400;
  font-style: normal;
  font-size: 60px;
  line-height: 71px;
  letter-spacing: 0;
  color: var(--text-primary);
  margin: 0;
  flex: 1;
  margin-top: 25px;
}
{% comment %} 
.wishlist-btn {
  flex-shrink: 0;
  width: 46px;
  height: 46px;
  border-radius: 50%;
  border: 1.5px solid rgba(255,255,255,0.25);
  background: transparent;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  margin-top: 8px;
  transition: border-color 0.2s, background 0.2s;
}
.wishlist-btn:hover {
  border-color: var(--accent-gold);
  color: var(--accent-gold);
}
.wishlist-btn.active svg { fill: var(--accent-gold); stroke: var(--accent-gold); } {% endcomment %}

/* Author */
.product-author {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 16px;
  line-height: 30px;
  letter-spacing: 0.20em;
  text-transform: uppercase;
  text-decoration: underline;
  text-underline-offset: 4px;
  text-decoration-thickness: 1px;
  color: #C9A885;
  margin: 0 0 22px 0;
}

/* Signed copies badge */
.signed-copies-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 10px 18px;
  border: 1px solid #C9A885;
  border-radius: 4px;
  width: fit-content;
  margin-bottom: 32px;
}

.signed-copies-badge__text {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 18px;
  line-height: 1;
  letter-spacing: 0;
  color: #C9A885;
  text-align: center;
}

/* Price */
.product-price {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 32px;
}

.price-label {
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--text-muted);
}

.price-amount {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 36px;
  line-height: 1;
  color: var(--accent-gold);
  letter-spacing: -0.01em;
}

.price-compare {
  font-family: var(--font-body);
  font-size: 20px;
  color: var(--text-muted);
  text-decoration: line-through;
}

/* Variant selector */
.variant-selector {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 28px;
}
.variant-option__label {
  font-family: var(--font-body);
  font-size: 13px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8px;
}
.variant-option__values {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.variant-value-btn {
  padding: 8px 18px;
  border: 1px solid rgba(201,168,133,0.35);
  background: transparent;
  color: white;
  font-family: var(--font-body);
  font-size: 14px;
  cursor: pointer;
  border-radius: 3px;
  transition: border-color 0.2s, background 0.2s;
}
.variant-value-btn:hover,
.variant-value-btn.active {
  border-color: var(--accent-gold);
  background: rgba(201,168,133,0.1);
}

/* Actions row */
.product-actions {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

/* Quantity control */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 0;
  
  border-radius: 50px;
  padding: 0 6px;
