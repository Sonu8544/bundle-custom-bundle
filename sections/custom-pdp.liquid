  async function queueEnsureLaunchDoc() {
    var variant = findVariantByOptions();
    var dynamicLimit = variant && typeof variant.inventory_quantity !== 'undefined'
      ? Math.max(0, Number(variant.inventory_quantity || 0))
      : launchLimit;

    var snap = await launchRef.get();

    if (!snap.exists) {
      await launchRef.set({
        productId: productIdForQueue,
        limit: dynamicLimit,
        grantedCount: 0,
        createdAt: firebase.firestore.FieldValue.serverTimestamp(),
        updatedAt: firebase.firestore.FieldValue.serverTimestamp()
      });
    } else {
      await launchRef.set({
        limit: dynamicLimit,
        updatedAt: firebase.firestore.FieldValue.serverTimestamp()
      }, { merge: true });
    }

    if (limitEl) limitEl.textContent = String(dynamicLimit);
  }

  async function queueJoin() {
    if (!queueEnabled || !firebaseDb || !joinBtn) return;

    joinBtn.disabled = true;
    queueSetStatus('Joining virtual queue...');

    try {
      await queueEnsureLaunchDoc();

      await firebaseDb.runTransaction(async function(tx) {
        var launchSnap = await tx.get(launchRef);
        var sessionSnap = await tx.get(sessionRef);

        var data = launchSnap.exists ? launchSnap.data() : {};
        var grantedCount = Number(data.grantedCount || 0);
        var limit = Number(data.limit || launchLimit);

        if (sessionSnap.exists) {
          var existing = sessionSnap.data() || {};
          if (existing.status === 'granted' || existing.status === 'waiting') return;
        }

        var now = Date.now();
        var expiresAt = now + (accessMinutes * 60 * 1000);

        if (grantedCount < limit) {
          tx.set(sessionRef, {
            sessionId: sessionId,
            productId: productIdForQueue,
            variantId: cartBtn ? cartBtn.getAttribute('data-variant-id') : null,
            status: 'granted',
            joinedAt: firebase.firestore.FieldValue.serverTimestamp(),
            expiresAtMillis: expiresAt
          }, { merge: true });

          tx.update(launchRef, {
            grantedCount: grantedCount + 1,
            updatedAt: firebase.firestore.FieldValue.serverTimestamp()
          });
        } else {
          tx.set(sessionRef, {
            sessionId: sessionId,
            productId: productIdForQueue,
            variantId: cartBtn ? cartBtn.getAttribute('data-variant-id') : null,
            status: 'waiting',
            joinedAt: firebase.firestore.FieldValue.serverTimestamp()
          }, { merge: true });
        }
      });

      queueSetStatus('Queue updated.');
    } catch (e) {
      console.error(e);
      queueSetStatus('Could not join queue.');
    } finally {
      joinBtn.disabled = false;
    }
  }

  async function queueRefreshStatus() {
    if (!queueEnabled || !firebaseDb) return;

    try {
      var launchSnap = await launchRef.get();
      var sessionSnap = await sessionRef.get();

      if (launchSnap.exists) {
        var launchData = launchSnap.data() || {};
        if (grantedEl) grantedEl.textContent = String(launchData.grantedCount || 0);
        if (limitEl) limitEl.textContent = String(launchData.limit || launchLimit);
      }

      if (sessionSnap.exists) {
        var sessionData = sessionSnap.data() || {};

        if (sessionData.status === 'granted') {
          queueUnlockBuy();
          queueSetMessage('Access granted. Complete checkout before your timer ends.');
          queueStartCountdown(Number(sessionData.expiresAtMillis || 0));
          queueSetStatus('You have purchase access.');
          return;
        }

        if (sessionData.status === 'waiting') {
          queueLockBuy();
          if (timerWrap) timerWrap.hidden = true;
          queueSetMessage('You are in queue. Waiting for availability.');
          queueSetStatus('Waiting for availability.');
          return;
        }
      }

      queueLockBuy();
      if (timerWrap) timerWrap.hidden = true;
      queueSetMessage('Join the queue to check launch access.');
      queueSetStatus('');
    } catch (e) {
      console.error(e);
      queueSetStatus('Could not refresh queue status.');
    }
  }

  function queueBindRealtime() {
    if (!queueEnabled || !launchRef || !sessionRef) return;

    launchRef.collection('sessions').onSnapshot(function(snapshot) {
      if (liveEl) liveEl.textContent = String(snapshot.size || 0);
    });

    launchRef.onSnapshot(function(docSnap) {
      var data = docSnap.exists ? docSnap.data() : {};
      if (grantedEl) grantedEl.textContent = String(data.grantedCount || 0);
      if (limitEl) limitEl.textContent = String(data.limit || launchLimit);

      if ((data.grantedCount || 0) >= (data.limit || launchLimit)) {
        queueSetStatus('Launch allocation is currently full.');
      }
    });

    sessionRef.onSnapshot(function(docSnap) {
      if (!docSnap.exists) return;

      var data = docSnap.data() || {};
      if (data.status === 'granted') {
        queueUnlockBuy();
        queueSetMessage('Access granted. Complete checkout before your timer ends.');
        queueStartCountdown(Number(data.expiresAtMillis || 0));
        queueSetStatus('You have purchase access.');
      } else if (data.status === 'waiting') {
        queueLockBuy();
        queueSetMessage('You are in queue. Waiting for availability.');
        queueSetStatus('Queue joined successfully.');
        if (timerWrap) timerWrap.hidden = true;
      }
    });
  }


