{% comment %} {% liquid
  assign sid = 'scroll-letter-' | append: section.id
  assign parchment = section.settings.parchment_image
%}

<section
  id="{{ sid }}"
  class="slr-section"
  style="
    --slr-section-height: {{ section.settings.scroll_height }}vh;
    --slr-max-width: {{ section.settings.max_width }}px;
    --slr-roll-height-desktop: {{ section.settings.roll_height_desktop }}px;
    --slr-roll-height-mobile: {{ section.settings.roll_height_mobile }}px;
    --slr-open-height-desktop: {{ section.settings.open_height_desktop }}px;
    --slr-open-height-mobile: {{ section.settings.open_height_mobile }}px;
    --slr-text-width: {{ section.settings.text_width }}px;
    --slr-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --slr-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --slr-body-size-desktop: {{ section.settings.body_size_desktop }}px;
    --slr-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --slr-title-color: {{ section.settings.title_color }};
    --slr-body-color: {{ section.settings.body_color }};
    --slr-bg: {{ section.settings.section_bg }};
    --slr-overlay: {{ section.settings.overlay_color }};
    --slr-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --slr-top-offset: {{ section.settings.sticky_top_offset }}px;
    --slr-progress: 0;
  "
  data-slr-section
>
  <div class="slr-stage">
    <div class="slr-sticky">
      <div class="slr-backdrop"></div>

      <div class="slr-scroll" data-slr-scroll>
        <div class="slr-scroll__frame">
          <div class="slr-scroll__top"></div>

          <div class="slr-scroll__paper">
            <div class="slr-scroll__paper-inner">
              {% if section.settings.eyebrow != blank %}
                <div class="slr-eyebrow">{{ section.settings.eyebrow }}</div>
              {% endif %}

              {% if section.settings.heading != blank %}
                <h2 class="slr-heading">{{ section.settings.heading }}</h2>
              {% endif %}

              {% if section.settings.show_divider %}
                <div class="slr-divider" aria-hidden="true">
                  <span></span>
                </div>
              {% endif %}

              {% if section.settings.body != blank %}
                <div class="slr-body rte">
                  {{ section.settings.body }}
                </div>
              {% endif %}

              {% if section.settings.button_label != blank and section.settings.button_link != blank %}
                <div class="slr-actions">
                  <a class="slr-button" href="{{ section.settings.button_link }}">
                    {{ section.settings.button_label }}
                  </a>
                </div>
              {% endif %}
            </div>
          </div>

          <div class="slr-scroll__bottom"></div>
        </div>
      </div>
    </div>
  </div>

  <style>
    #{{ sid }} {
      position: relative;
      background: var(--slr-bg);
      overflow: clip;
    }

    #{{ sid }} .slr-stage {
      position: relative;
      height: var(--slr-section-height);
    }

    #{{ sid }} .slr-sticky {
      position: sticky;
      top: var(--slr-top-offset);
      min-height: calc(100vh - var(--slr-top-offset));
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    #{{ sid }} .slr-backdrop {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(
          to bottom,
          color-mix(in srgb, var(--slr-overlay) calc(var(--slr-overlay-opacity) * 100%), transparent),
          transparent 20%,
          transparent 80%,
          color-mix(in srgb, var(--slr-overlay) calc(var(--slr-overlay-opacity) * 100%), transparent)
        );
      pointer-events: none;
    }

    #{{ sid }} .slr-scroll {
      position: relative;
      width: min(92vw, var(--slr-max-width));
      display: flex;
      align-items: center;
      justify-content: center;
      transform:
        translateY(calc((1 - var(--slr-progress)) * 60px))
        scale(calc(0.82 + (var(--slr-progress) * 0.18)));
      opacity: calc(0.35 + (var(--slr-progress) * 0.65));
      transition: transform 0.12s linear, opacity 0.12s linear;
      will-change: transform, opacity;
    }

    #{{ sid }} .slr-scroll__frame {
      position: relative;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      filter: drop-shadow(0 30px 45px rgba(0,0,0,0.22));
    }

    #{{ sid }} .slr-scroll__top,
    #{{ sid }} .slr-scroll__bottom,
    #{{ sid }} .slr-scroll__paper {
      width: 100%;
      background-repeat: no-repeat;
      background-position: center;
      background-size: 100% 100%;
    }

    {% if parchment != blank %}
      #{{ sid }} .slr-scroll__top,
      #{{ sid }} .slr-scroll__bottom,
      #{{ sid }} .slr-scroll__paper {
        background-image: url('{{ parchment | image_url: width: 2200 }}');
      }
    {% else %}
      #{{ sid }} .slr-scroll__top,
      #{{ sid }} .slr-scroll__bottom,
      #{{ sid }} .slr-scroll__paper {
        background: #e8d2a7;
      }
    {% endif %}

    #{{ sid }} .slr-scroll__top {
      height: var(--slr-roll-height-desktop);
      background-position: center top;
      background-size: 100% auto;
      z-index: 3;
      transform: translateY(calc((1 - var(--slr-progress)) * 115px));
      transition: transform 0.12s linear;
      will-change: transform;
    }

    #{{ sid }} .slr-scroll__bottom {
      height: var(--slr-roll-height-desktop);
      background-position: center bottom;
      background-size: 100% auto;
      z-index: 3;
      transform: translateY(calc((var(--slr-progress) - 1) * 115px));
      transition: transform 0.12s linear;
      will-change: transform;
    }

    #{{ sid }} .slr-scroll__paper {
      position: relative;
      overflow: hidden;
      width: calc(100% - 7%);
      min-height: 8px;
      height: calc(16px + (var(--slr-progress) * var(--slr-open-height-desktop)));
      margin-top: calc(var(--slr-roll-height-desktop) * -0.30);
      margin-bottom: calc(var(--slr-roll-height-desktop) * -0.30);
      background-position: center center;
      background-size: 100% 100%;
      transition: height 0.12s linear;
      will-change: height;
      z-index: 2;
    }

    #{{ sid }} .slr-scroll__paper::before {
      content: "";
      position: absolute;
      inset: 0;
     
      pointer-events: none;
    }

    #{{ sid }} .slr-scroll__paper-inner {
      position: relative;
      z-index: 2;
      width: min(78%, var(--slr-text-width));
      margin: 0 auto;
      text-align: center;
      padding:
        calc(34px + (var(--slr-progress) * 54px))
        20px
        calc(26px + (var(--slr-progress) * 44px));
      opacity: clamp(0, calc((var(--slr-progress) - 0.28) * 2.4), 1);
      transform: translateY(calc((1 - var(--slr-progress)) * 28px));
      transition: opacity 0.12s linear, transform 0.12s linear;
      will-change: opacity, transform;
      pointer-events: none;
    }

    #{{ sid }} .slr-eyebrow {
      margin-bottom: 10px;
      font-size: 14px;
      line-height: 1.2;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--slr-title-color);
      opacity: 0.75;
    }

    #{{ sid }} .slr-heading {
      margin: 0;
      color: var(--slr-title-color);
      font-size: var(--slr-heading-size-desktop);
      line-height: 1.08;
      font-weight: 400;
    }

    #{{ sid }} .slr-divider {
      display: flex;
      justify-content: center;
      margin: 18px 0 22px;
    }

    #{{ sid }} .slr-divider span {
      display: block;
      width: min(180px, 44%);
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(115,83,33,0.55), transparent);
      position: relative;
    }

    #{{ sid }} .slr-divider span::before {
      content: "❦";
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -54%);
      padding: 0 10px;
      background: transparent;
      color: rgba(115,83,33,0.72);
      font-size: 18px;
      line-height: 1;
    }

    #{{ sid }} .slr-body,
    #{{ sid }} .slr-body p {
      margin: 0;
      color: var(--slr-body-color);
      font-size: var(--slr-body-size-desktop);
      line-height: 1.72;
      font-weight: 400;
    }

    #{{ sid }} .slr-body p + p {
      margin-top: 12px;
    }

    #{{ sid }} .slr-actions {
      margin-top: 24px;
      pointer-events: auto;
    }

    #{{ sid }} .slr-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 150px;
      padding: 12px 22px;
      border-radius: 999px;
      text-decoration: none;
      color: #fff;
      background: #2a2117;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    #{{ sid }} .slr-button:hover {
      transform: translateY(-1px);
      opacity: 0.92;
    }

    @media (max-width: 989px) {
      #{{ sid }} .slr-scroll {
        width: min(94vw, 760px);
      }

      #{{ sid }} .slr-scroll__top,
      #{{ sid }} .slr-scroll__bottom {
        height: var(--slr-roll-height-mobile);
      }

      #{{ sid }} .slr-scroll__paper {
        width: calc(100% - 9%);
        height: calc(12px + (var(--slr-progress) * var(--slr-open-height-mobile)));
        margin-top: calc(var(--slr-roll-height-mobile) * -0.28);
        margin-bottom: calc(var(--slr-roll-height-mobile) * -0.28);
      }

      #{{ sid }} .slr-scroll__paper-inner {
        width: min(82%, 540px);
        padding:
          calc(26px + (var(--slr-progress) * 34px))
          14px
          calc(22px + (var(--slr-progress) * 28px));
      }

      #{{ sid }} .slr-heading {
        font-size: var(--slr-heading-size-mobile);
      }

      #{{ sid }} .slr-body,
      #{{ sid }} .slr-body p {
        font-size: var(--slr-body-size-mobile);
        line-height: 1.65;
      }
    }

    @media (max-width: 767px) {
      #{{ sid }} .slr-stage {
        height: max(var(--slr-section-height), 220vh);
      }

      #{{ sid }} .slr-sticky {
        top: 0;
        min-height: 100vh;
      }

      #{{ sid }} .slr-scroll {
        width: min(96vw, 620px);
      }

      #{{ sid }} .slr-scroll__paper-inner {
        width: min(84%, 440px);
      }

      #{{ sid }} .slr-divider {
        margin: 14px 0 18px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #{{ sid }} .slr-scroll,
      #{{ sid }} .slr-scroll__top,
      #{{ sid }} .slr-scroll__bottom,
      #{{ sid }} .slr-scroll__paper,
      #{{ sid }} .slr-scroll__paper-inner {
        transition: none !important;
      }
    }
  </style>

  <script>
    (() => {
      const section = document.getElementById('{{ sid }}');
      if (!section) return;

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

      const updateProgress = () => {
        const rect = section.getBoundingClientRect();
        const total = Math.max(section.offsetHeight - window.innerHeight, 1);
        const scrolled = clamp(-rect.top, 0, total);
        const progress = prefersReduced ? 1 : clamp(scrolled / total, 0, 1);
        section.style.setProperty('--slr-progress', progress.toFixed(4));
      };

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          updateProgress();
          ticking = false;
        });
      };

      updateProgress();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      document.addEventListener('shopify:section:load', onScroll);
      document.addEventListener('shopify:section:reorder', onScroll);
      document.addEventListener('shopify:section:select', onScroll);
    })();
  </script>

  {% schema %}
  {
    "name": "Scroll letter reveal",
    "settings": [
      {
        "type": "image_picker",
        "id": "parchment_image",
        "label": "Parchment image"
      },
      {
        "type": "text",
        "id": "eyebrow",
        "label": "Eyebrow",
        "default": "Ancient Letter"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "About Rare Biblio"
      },
      {
        "type": "richtext",
        "id": "body",
        "label": "Content",
        "default": "<p>Welcome to Rare Biblio, the premier destination for bibliophiles and book lovers who appreciate the art of bookmaking.</p>"
      },
      {
        "type": "checkbox",
        "id": "show_divider",
        "label": "Show divider",
        "default": true
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button label"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button link"
      },
      {
        "type": "header",
        "content": "Layout"
      },
      {
        "type": "range",
        "id": "scroll_height",
        "label": "Scroll animation height (vh)",
        "min": 180,
        "max": 420,
        "step": 10,
        "default": 260
      },
      {
        "type": "range",
        "id": "max_width",
        "label": "Max scroll width",
        "min": 500,
        "max": 1200,
        "step": 20,
        "default": 760
      },
      {
        "type": "range",
        "id": "open_height_desktop",
        "label": "Open paper height desktop",
        "min": 260,
        "max": 760,
        "step": 10,
        "default": 470
      },
      {
        "type": "range",
        "id": "open_height_mobile",
        "label": "Open paper height mobile",
        "min": 220,
        "max": 620,
        "step": 10,
        "default": 360
      },
      {
        "type": "range",
        "id": "roll_height_desktop",
        "label": "Roll height desktop",
        "min": 80,
        "max": 240,
        "step": 10,
        "default": 140
      },
      {
        "type": "range",
        "id": "roll_height_mobile",
        "label": "Roll height mobile",
        "min": 60,
        "max": 180,
        "step": 10,
        "default": 100
      },
      {
        "type": "range",
        "id": "text_width",
        "label": "Text width",
        "min": 260,
        "max": 700,
        "step": 10,
        "default": 430
      },
      {
        "type": "range",
        "id": "sticky_top_offset",
        "label": "Sticky top offset",
        "min": 0,
        "max": 120,
        "step": 4,
        "default": 0
      },
      {
        "type": "header",
        "content": "Typography"
      },
      {
        "type": "color",
        "id": "title_color",
        "label": "Heading color",
        "default": "#2b2116"
      },
      {
        "type": "color",
        "id": "body_color",
        "label": "Body color",
        "default": "#2f261d"
      },
      {
        "type": "range",
        "id": "heading_size_desktop",
        "label": "Heading size desktop",
        "min": 24,
        "max": 72,
        "step": 2,
        "default": 46
      },
      {
        "type": "range",
        "id": "heading_size_mobile",
        "label": "Heading size mobile",
        "min": 20,
        "max": 48,
        "step": 2,
        "default": 30
      },
      {
        "type": "range",
        "id": "body_size_desktop",
        "label": "Body size desktop",
        "min": 14,
        "max": 28,
        "step": 1,
        "default": 18
      },
      {
        "type": "range",
        "id": "body_size_mobile",
        "label": "Body size mobile",
        "min": 13,
        "max": 24,
        "step": 1,
        "default": 16
      },
      {
        "type": "header",
        "content": "Background"
      },
      {
        "type": "color",
        "id": "section_bg",
        "label": "Section background",
        "default": "#050505"
      },
      {
        "type": "color",
        "id": "overlay_color",
        "label": "Overlay color",
        "default": "#000000"
      },
      {
        "type": "range",
        "id": "overlay_opacity",
        "label": "Overlay opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "default": 35
      }
    ],
    "presets": [
      {
        "name": "Scroll letter reveal"
      }
    ]
  }
  {% endschema %}
</section> {% endcomment %}


