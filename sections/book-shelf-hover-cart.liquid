  function replaceBubbleSection(htmlString) {
  if (!htmlString) return;

  const parsed = parseHTML(htmlString);
  const sourceBubble = parsed.querySelector('#cart-icon-bubble');
  const targetBubble = document.querySelector('#cart-icon-bubble');

  if (sourceBubble && targetBubble) {
    targetBubble.innerHTML = sourceBubble.innerHTML;
  }
}

  function rebindDrawerOverlay() {
    const drawer = document.querySelector('cart-drawer');
    const overlay = document.querySelector('#CartDrawer-Overlay');

    if (!drawer || !overlay) return;

    const newOverlay = overlay.cloneNode(true);
    overlay.parentNode.replaceChild(newOverlay, overlay);

    newOverlay.addEventListener('click', function() {
      if (typeof drawer.close === 'function') {
        drawer.close();
      } else {
        drawer.classList.remove('active');
        document.body.classList.remove('overflow-hidden');
      }
    });
  }

  function rebindCartIconBubble() {
    const drawer = document.querySelector('cart-drawer');
    const bubble = document.querySelector('#cart-icon-bubble');

    if (!drawer || !bubble) return;

    const newBubble = bubble.cloneNode(true);
    bubble.parentNode.replaceChild(newBubble, bubble);

    newBubble.setAttribute('role', 'button');
    newBubble.setAttribute('aria-haspopup', 'dialog');

    newBubble.addEventListener('click', function(event) {
      event.preventDefault();
      if (typeof drawer.open === 'function') {
        drawer.open(newBubble);
      } else {
        drawer.classList.add('animate', 'active');
        document.body.classList.add('overflow-hidden');
      }
    });

    newBubble.addEventListener('keydown', function(event) {
      if (event.code && event.code.toUpperCase() === 'SPACE') {
        event.preventDefault();
        if (typeof drawer.open === 'function') {
          drawer.open(newBubble);
        } else {
          drawer.classList.add('animate', 'active');
          document.body.classList.add('overflow-hidden');
        }
      }
    });
  }

  function openDrawer(triggerEl) {
    const drawer = document.querySelector('cart-drawer');
    if (!drawer) return;

    drawer.classList.remove('is-empty');

    const inner = drawer.querySelector('.drawer__inner');
    if (inner) inner.classList.remove('is-empty');

    if (typeof drawer.open === 'function') {
      drawer.open(triggerEl || section.querySelector('[data-book-add]'));
    } else {
      drawer.classList.add('animate', 'active');
      document.body.classList.add('overflow-hidden');
    }
  }

  async function refreshCartUI(addData, triggerButton) {
    const sections = addData && addData.sections ? addData.sections : null;
    if (!sections) return;

    if (sections['cart-drawer']) {
      replaceDrawerSection(sections['cart-drawer']);
    }

    if (sections['cart-icon-bubble']) {
      replaceBubbleSection(sections['cart-icon-bubble']);
    }

    rebindDrawerOverlay();
    rebindCartIconBubble();
    openDrawer(triggerButton);

    const drawer = document.querySelector('cart-drawer');
    if (drawer) {
      drawer.classList.remove('is-empty');
    }
  }

  async function addToCart(variantId, button) {
    if (!variantId || !button || button.disabled) return;

    const originalText = button.textContent;
    button.disabled = true;
    button.textContent = 'Adding...';

    try {
      const addData = await addItem(variantId);
      await refreshCartUI(addData, button);

      button.textContent = 'Added';

      setTimeout(function() {
        button.textContent = originalText;
        button.disabled = false;
      }, 1200);
    } catch (error) {
      console.error('[Book Shelf] Add to cart error:', error);
      button.textContent = 'Error';

      setTimeout(function() {
        button.textContent = originalText;
        button.disabled = false;
      }, 1400);
    }
  }

  section.addEventListener('click', function(event) {
    const btn = event.target.closest('[data-book-add]');
    if (!btn) return;

    event.preventDefault();
    event.stopPropagation();

    addToCart(btn.getAttribute('data-variant-id'), btn);
  });
})();
