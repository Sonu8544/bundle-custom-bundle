{% comment %}
  Parchment Scroll Section
  ========================
  Interactive scroll that unrolls on wheel/swipe/keyboard input.
  3D rotating wooden rollers, auto-fitting text, spring physics.

  SETUP:
  1. Upload scroll-top.png, scroll-mid.png, scroll-bot.png to your theme's Assets folder
  2. Add this file to your theme's Sections folder
  3. Add the section to any page/template via the theme editor

  Or use the image_picker settings to upload custom scroll images.
{% endcomment %}







{% comment %} 
{% comment %}
  Parchment Scroll Section — Interactive scroll with 3D rollers
  Smooth scroll pass-through: only captures when actively opening/closing.
  Fully open or closed → page scrolls normally.
{% endcomment %}

{%- liquid
  assign sid = section.id
  assign heading = section.settings.heading
  assign heading_lead = section.settings.heading_lead
  assign heading_accent = section.settings.heading_accent
  assign subtitle = section.settings.subtitle | strip
  if subtitle == '-'
    assign subtitle = ''
  endif
  assign body_text = section.settings.body_text
  assign quote_text = section.settings.quote_text | strip
  if quote_text == '-'
    assign quote_text = ''
  endif
  assign footer_text = section.settings.footer_text | strip
  if footer_text == '-'
    assign footer_text = ''
  endif
  assign bg_color = section.settings.bg_color
  assign section_height = section.settings.section_height
  assign max_scroll_width = section.settings.max_scroll_width
  assign full_screen = section.settings.full_screen
  assign show_title_divider = section.settings.show_title_divider

  if section.settings.img_top != blank
    assign img_top = section.settings.img_top | image_url: width: 1098
  else
    assign img_top = 'scroll-top.png' | asset_url
  endif
  if section.settings.img_mid != blank
    assign img_mid = section.settings.img_mid | image_url: width: 1098
  else
    assign img_mid = 'scroll-mid.png' | asset_url
  endif
  if section.settings.img_bot != blank
