{% liquid
  assign section_id = 'rare-biblio-heading-' | append: section.id
%}

<section
  id="{{ section_id }}"
  class="rbh-section"
  style="
    --rbh-bg-color: {{ section.settings.section_bg }};
    --rbh-title-max-width: {{ section.settings.title_max_width }}px;
    --rbh-content-max-width: {{ section.settings.content_max_width }}px;
    --rbh-padding-top: {{ section.settings.padding_top }}px;
    --rbh-padding-bottom: {{ section.settings.padding_bottom }}px;
    --rbh-title-size: {{ section.settings.title_size_desktop }}px;
    --rbh-title-line-height: {{ section.settings.title_line_height_desktop }}%;
    --rbh-text-size: {{ section.settings.text_size_desktop }}px;
    --rbh-text-line-height: {{ section.settings.text_line_height_desktop }}px;
    --rbh-title-color-start: {{ section.settings.title_gradient_start }};
    --rbh-title-color-end: {{ section.settings.title_gradient_end }};
    --rbh-text-color: {{ section.settings.text_color }};
    --rbh-inner-gap: {{ section.settings.inner_gap }}px;
    --rbh-anim-distance-title: {{ section.settings.anim_distance_title }}px;
    --rbh-anim-distance-text: {{ section.settings.anim_distance_text }}px;
    --rbh-anim-duration: {{ section.settings.anim_duration }}ms;
  "
>
  <div class="rbh-section__wrap page-width{% if section.settings.full_width %} rbh-section__wrap--full{% endif %}">
    <div class="rbh-section__content{% if section.settings.enable_scroll_animation %} rbh-section__content--animated{% endif %}">
      {% if section.settings.heading != blank %}
        <h2 class="rbh-section__title{% if section.settings.enable_scroll_animation %} rbh-animate-title{% endif %}" style="padding-top:10px">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="rbh-section__description rte{% if section.settings.enable_scroll_animation %} rbh-animate-text{% endif %}">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #{{ section_id }} {
    background: var(--rbh-bg-color);
    padding-top: var(--rbh-padding-top);
    padding-bottom: var(--rbh-padding-bottom);
    overflow: hidden;
  }

  #{{ section_id }} .rbh-section__wrap {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
    box-sizing: border-box;
  }

  #{{ section_id }} .rbh-section__wrap--full {
    max-width: 100%;
  }

  #{{ section_id }} .rbh-section__content {
    max-width: var(--rbh-content-max-width);
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--rbh-inner-gap);
    align-items: center;
    justify-content: center;
  }

  #{{ section_id }} .rbh-section__title {
    margin: 0;
    max-width: var(--rbh-title-max-width);
    width: 100%;
    font-family: "Bethany Elingston", serif;
    font-style: normal;
    font-weight: 400;
    font-size: var(--rbh-title-size);
    line-height: var(--rbh-title-line-height);
    text-align: center;
    letter-spacing: 0;
    background: radial-gradient(
      84.35% 106.04% at 104.49% 58.65%,
      var(--rbh-title-color-start) 0%,
      var(--rbh-title-color-end) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  #{{ section_id }} .rbh-section__description {
    margin: 0;
    max-width: 1016px;
    width: 100%;
    color: var(--rbh-text-color);
    font-family: "Satoshi", sans-serif;
    font-style: normal;
    font-weight: 400;
    font-size: var(--rbh-text-size);
    line-height: var(--rbh-text-line-height);
    letter-spacing: 0;
    text-align: center;
  }

  #{{ section_id }} .rbh-section__description p {
    margin: 0;
    color: inherit;
    font: inherit;
  }

  #{{ section_id }} .rbh-animate-title,
  #{{ section_id }} .rbh-animate-text {
    opacity: 0;
    will-change: transform, opacity;
    transition:
      transform var(--rbh-anim-duration) cubic-bezier(0.22, 1, 0.36, 1),
      opacity var(--rbh-anim-duration) ease;
  }

  /* title starts slightly upward */
  #{{ section_id }} .rbh-animate-title {
    transform: translate3d(0, calc(var(--rbh-anim-distance-title) * -1), 0);
  }

  /* text starts slightly downward */
  #{{ section_id }} .rbh-animate-text {
    transform: translate3d(0, var(--rbh-anim-distance-text), 0);
    transition-delay: .08s;
  }

  #{{ section_id }}.is-visible .rbh-animate-title,
  #{{ section_id }}.is-visible .rbh-animate-text {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @media screen and (max-width: 1200px) {
    #{{ section_id }} {
      --rbh-title-size: {{ section.settings.title_size_tablet }}px;
      --rbh-title-line-height: {{ section.settings.title_line_height_tablet }}%;
      --rbh-text-size: {{ section.settings.text_size_tablet }}px;
      --rbh-text-line-height: {{ section.settings.text_line_height_tablet }}px;
    }
  }

  @media screen and (max-width: 767px) {
    #{{ section_id }} {
      --rbh-padding-top: {{ section.settings.padding_top_mobile }}px;
      --rbh-padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      --rbh-title-size: {{ section.settings.title_size_mobile }}px;
      --rbh-title-line-height: {{ section.settings.title_line_height_mobile }}%;
      --rbh-text-size: {{ section.settings.text_size_mobile }}px;
      --rbh-text-line-height: {{ section.settings.text_line_height_mobile }}px;
      --rbh-inner-gap: {{ section.settings.inner_gap_mobile }}px;
    }

    #{{ section_id }} .rbh-section__wrap {
      padding-left: 16px;
      padding-right: 16px;
    }

    #{{ section_id }} .rbh-section__content,
    #{{ section_id }} .rbh-section__title,
    #{{ section_id }} .rbh-section__description {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .rbh-animate-title,
    #{{ section_id }} .rbh-animate-text {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

{% if section.settings.enable_scroll_animation %}
  <script>
    (function() {
      var section = document.getElementById('{{ section_id }}');
      if (!section) return;

      var initialized = false;

      function showSection() {
        section.classList.add('is-visible');
      }

      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting && !initialized) {
              initialized = true;
              showSection();
              observer.unobserve(section);
            }
          });
        }, {
          threshold: 0.22,
          rootMargin: '0px 0px -6% 0px'
        });

        observer.observe(section);
      } else {
        showSection();
      }
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Rare Biblio Heading",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
