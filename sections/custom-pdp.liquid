  function zoomTo(newScale, clientX, clientY) {
    if (!lightboxWrap || !lightboxImg) return;

    var rect = lightboxWrap.getBoundingClientRect();
    var centerX = rect.left + rect.width / 2;
    var centerY = rect.top + rect.height / 2;

    var targetX = typeof clientX === 'number' ? clientX : centerX;
    var targetY = typeof clientY === 'number' ? clientY : centerY;

    var scale = Math.max(1, Math.min(maxZoom, newScale));
    zoomScale = scale;

    if (scale === 1) {
      zoomX = 0;
      zoomY = 0;
    } else {
      zoomX += (centerX - targetX) * 0.12;
      zoomY += (centerY - targetY) * 0.12;
    }

    applyZoom();
  }

  function openLightbox() {
