      if (zoomScale <= 1) return;
      isDragging = true;
      dragStartX = e.clientX;
      dragStartY = e.clientY;
      startZoomX = zoomX;
      startZoomY = zoomY;
      lightboxImg.classList.add('is-dragging');
      e.preventDefault();
