  <script>
    (function() {
      const section = document.getElementById('{{ section_id }}');
      if (!section) return;

      const drawerToggle = section.querySelector('[data-drawer-toggle]');
      const drawer = section.querySelector('[data-drawer]');
      const modal = section.querySelector('[data-filter-modal]');
      const openFilter = section.querySelector('[data-filter-open]');
      const closeButtons = section.querySelectorAll('[data-filter-close]');

      if (drawerToggle && drawer) {
        drawerToggle.addEventListener('click', function() {
          const open = drawer.classList.toggle('is-open');
          drawerToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        });

        document.addEventListener('click', function(event) {
          if (!section.contains(event.target)) {
            drawer.classList.remove('is-open');
            drawerToggle.setAttribute('aria-expanded', 'false');
          }
        });
      }

      function setModalState(open) {
        if (!modal) return;
        if (open) {
          modal.hidden = false;
          document.documentElement.style.overflow = 'hidden';
          openFilter && openFilter.setAttribute('aria-expanded', 'true');
        } else {
          modal.hidden = true;
          document.documentElement.style.overflow = '';
          openFilter && openFilter.setAttribute('aria-expanded', 'false');
        }
      }

      if (openFilter) {
        openFilter.addEventListener('click', function() {
          setModalState(true);
        });
      }

      closeButtons.forEach(function(button) {
        button.addEventListener('click', function() {
          setModalState(false);
        });
      });

      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape') {
          setModalState(false);
        }
      });
    })();
  </script>
</section>

