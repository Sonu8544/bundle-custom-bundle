    if (!bubble || !sectionHtml) return;

    const parsed = new DOMParser().parseFromString(sectionHtml, 'text/html');
    const source = parsed.querySelector('#shopify-section-cart-icon-bubble') || parsed.querySelector('.shopify-section');

    if (source) {
      bubble.innerHTML = source.innerHTML;
    } else {
      bubble.innerHTML = sectionHtml;
