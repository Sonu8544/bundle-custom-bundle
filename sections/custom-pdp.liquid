</style>



<script>
(function() {
  var sectionId = '{{ section.id }}';
  var section = document.getElementById('exclusive-book-product-' + sectionId);
  if (!section) return;

  var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root)
    ? window.Shopify.routes.root
    : '/';

  var variants = {{ product.variants | json }};
  var initialVariantId = {{ product.selected_or_first_available_variant.id | json }};
  var buttonDefaultText = {{ section.settings.button_text | default: 'Pre Order Now' | json }};

  var slides = Array.prototype.slice.call(section.querySelectorAll('.gallery-slide'));
  var thumbs = Array.prototype.slice.call(section.querySelectorAll('.thumb'));
  var lightbox = document.getElementById('lightbox-' + sectionId);
  var lightboxImg = document.getElementById('lightboxImg-' + sectionId);
  var zoomBtn = section.querySelector('.gallery-zoom-btn');
  var closeBtn = section.querySelector('.lightbox-close');

  var qtyInput = section.querySelector('.qty-input');
  var minusBtn = section.querySelector('.qty-btn--minus');
  var plusBtn = section.querySelector('.qty-btn--plus');
  var priceEl = section.querySelector('.price-amount');
  var compareEl = section.querySelector('.price-compare');
  var cartBtn = section.querySelector('#addToCart-' + sectionId);
  var variantBtns = Array.prototype.slice.call(section.querySelectorAll('.variant-value-btn'));
  var productForm = section.querySelector('form[action*="/cart/add"]');

  var currentSlide = 0;
  var isAdding = false;

  function activateSlide(index, updateLightbox) {
    if (!slides.length) return;

    if (index < 0) index = 0;
    if (index > slides.length - 1) index = slides.length - 1;

    currentSlide = index;

    slides.forEach(function(slide, i) {
      slide.classList.toggle('gallery-slide--active', i === index);
    });

    thumbs.forEach(function(thumb, i) {
      thumb.classList.toggle('thumb--active', i === index);
    });

    if (updateLightbox !== false) {
      setLightboxImage(index);
    }
  }

  function setLightboxImage(index) {
    if (!lightboxImg || !slides[index]) return;
    var img = slides[index].querySelector('img');
    if (!img) return;
    lightboxImg.src = img.src;
    lightboxImg.alt = img.alt || '';
  }

  function openLightbox() {
    if (!lightbox || !lightboxImg) return;
    setLightboxImage(currentSlide);
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  thumbs.forEach(function(thumb, index) {
    thumb.addEventListener('click', function() {
      activateSlide(index, true);
    });
  });

  if (zoomBtn) {
    zoomBtn.addEventListener('click', function(e) {
      e.preventDefault();
      openLightbox();
    });
  }

  if (closeBtn) {
    closeBtn.addEventListener('click', function(e) {
      e.preventDefault();
      closeLightbox();
    });
  }

  if (lightbox) {
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) closeLightbox();
    });
  }

  document.addEventListener('keydown', function(e) {
    if (!section || !document.body.contains(section)) return;

    if (lightbox && lightbox.classList.contains('is-open')) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft' && currentSlide > 0) activateSlide(currentSlide - 1, true);
      if (e.key === 'ArrowRight' && currentSlide < slides.length - 1) activateSlide(currentSlide + 1, true);
    }
  });

  function formatMoney(cents) {
    if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
      return window.Shopify.formatMoney(cents, window.Shopify.money_format);
    }
    return 'Rs. ' + (Number(cents || 0) / 100).toFixed(2);
  }

  function getQty() {
    var qty = parseInt(qtyInput ? qtyInput.value : '1', 10);
    if (isNaN(qty) || qty < 1) qty = 1;
    return qty;
  }

  function setQty(qty) {
    if (!qtyInput) return;
    var safeQty = parseInt(qty, 10);
    if (isNaN(safeQty) || safeQty < 1) safeQty = 1;
    qtyInput.value = safeQty;
  }

  function getSelectedOptions() {
    var options = [];
    var groups = section.querySelectorAll('.variant-option__values');

    groups.forEach(function(group) {
      var active = group.querySelector('.variant-value-btn.active');
      if (active) {
        options.push(active.getAttribute('data-value'));
      }
    });

    return options;
  }

  function findVariantByOptions() {
    if (!variants || !variants.length) return null;

    var selectedOptions = getSelectedOptions();
    if (!selectedOptions.length) {
      return variants.find(function(v) { return Number(v.id) === Number(initialVariantId); }) || variants[0];
    }

    for (var i = 0; i < variants.length; i++) {
      var variant = variants[i];
      var matched = true;

      for (var j = 0; j < selectedOptions.length; j++) {
        if ((variant['option' + (j + 1)] || '') !== selectedOptions[j]) {
          matched = false;
          break;
        }
      }

      if (matched) return variant;
    }

    return null;
  }

  function updateDisplayedPrice(variant) {
    if (!priceEl || !variant) return;

    var qty = getQty();
    var unitPrice = Number(variant.price || 0);
    var comparePrice = Number(variant.compare_at_price || 0);

    priceEl.textContent = formatMoney(unitPrice * qty);
    priceEl.setAttribute('data-unit-price', unitPrice);

    if (compareEl) {
      if (comparePrice > unitPrice) {
        compareEl.textContent = formatMoney(comparePrice * qty);
        compareEl.style.display = '';
      } else {
        compareEl.textContent = '';
        compareEl.style.display = 'none';
      }
    }
  }

  function syncVariantState() {
    var variant = findVariantByOptions();
    if (!variant) return;

    if (cartBtn) {
      cartBtn.setAttribute('data-variant-id', variant.id);
      cartBtn.disabled = !variant.available || isAdding;
      cartBtn.textContent = variant.available ? buttonDefaultText : 'Sold out';
      cartBtn.setAttribute('type', 'button');
    }

    if (productForm) {
      var idInput = productForm.querySelector('input[name="id"]');
      if (idInput) idInput.value = variant.id;
    }

    updateDisplayedPrice(variant);
  }

  if (minusBtn) {
    minusBtn.addEventListener('click', function(e) {
      e.preventDefault();
      setQty(getQty() - 1);
      syncVariantState();
    });
  }

  if (plusBtn) {
    plusBtn.addEventListener('click', function(e) {
      e.preventDefault();
      setQty(getQty() + 1);
      syncVariantState();
    });
  }

  if (qtyInput) {
    qtyInput.addEventListener('change', function() {
      setQty(getQty());
      syncVariantState();
    });
  }

  variantBtns.forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();

      var optionIndex = this.getAttribute('data-option-index');
      section.querySelectorAll('.variant-value-btn[data-option-index="' + optionIndex + '"]').forEach(function(item) {
        item.classList.remove('active');
      });

      this.classList.add('active');
      syncVariantState();
    });
  });

  function getCartDrawer() {
    return document.querySelector('cart-drawer');
  }

  function getCartDrawerMain() {
    return document.getElementById('CartDrawer');
  }

  function getCartBubble() {
    return document.getElementById('cart-icon-bubble');
  }

  function replaceDrawerMarkup(sectionHtml) {
    var parsed = new DOMParser().parseFromString(sectionHtml, 'text/html');
    var freshMain = parsed.getElementById('CartDrawer');
    var currentMain = getCartDrawerMain();

    if (currentMain && freshMain) {
      currentMain.innerHTML = freshMain.innerHTML;
    }

    var drawer = getCartDrawer();
    if (drawer) {
      drawer.classList.remove('is-empty');
      var inner = drawer.querySelector('.drawer__inner');
      if (inner) inner.classList.remove('is-empty');
    }
  }

  function replaceBubbleMarkup(sectionHtml) {
    var parsed = new DOMParser().parseFromString(sectionHtml, 'text/html');
    var freshBubble = parsed.getElementById('cart-icon-bubble');
    var currentBubble = getCartBubble();

    if (currentBubble && freshBubble) {
      currentBubble.innerHTML = freshBubble.innerHTML;
      return;
    }

    var freshSection = parsed.querySelector('.shopify-section');
    if (currentBubble && freshSection) {
      currentBubble.innerHTML = freshSection.innerHTML;
    }
  }

  function openDrawer() {
    var drawer = getCartDrawer();
    if (!drawer) return;

    drawer.classList.remove('is-empty');
    var inner = drawer.querySelector('.drawer__inner');
    if (inner) inner.classList.remove('is-empty');

    if (typeof drawer.open === 'function') {
      drawer.open();
    } else {
      drawer.classList.add('animate', 'active');
      document.body.classList.add('overflow-hidden');
    }
  }

  async function addItem(variantId, quantity) {
    var response = await fetch(root + 'cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({
        items: [{ id: Number(variantId), quantity: Number(quantity || 1) }],
        sections: ['cart-drawer', 'cart-icon-bubble'],
        sections_url: window.location.pathname
      })
    });

    var data = await response.json();
    if (!response.ok || data.status) {
      throw new Error(data.description || data.message || 'Failed to add to cart');
    }

    return data;
  }

  async function refreshCartUI(addData) {
    var sections = addData && addData.sections;

    if (sections) {
      if (sections['cart-icon-bubble']) replaceBubbleMarkup(sections['cart-icon-bubble']);
      if (sections['cart-drawer']) replaceDrawerMarkup(sections['cart-drawer']);
    } else {
      try {
        var bubbleResponse = await fetch(root + '?section_id=cart-icon-bubble', {
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        replaceBubbleMarkup(await bubbleResponse.text());
      } catch (e) {
        console.warn('[Exclusive Book] bubble fetch failed:', e);
      }

      try {
        var drawerResponse = await fetch(root + '?section_id=cart-drawer', {
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        replaceDrawerMarkup(await drawerResponse.text());
      } catch (e) {
        console.warn('[Exclusive Book] drawer fetch failed:', e);
      }
    }

    setTimeout(openDrawer, 60);

    if (typeof window.publish === 'function' && window.PUB_SUB_EVENTS && window.PUB_SUB_EVENTS.cartUpdate) {
      window.publish(window.PUB_SUB_EVENTS.cartUpdate, { source: 'exclusive-book-product' });
    }

    document.dispatchEvent(new CustomEvent('cart:refresh', {
      bubbles: true,
      detail: { source: 'exclusive-book-product' }
    }));

    document.dispatchEvent(new CustomEvent('cart:updated', {
      bubbles: true,
      detail: { source: 'exclusive-book-product' }
    }));

    document.dispatchEvent(new CustomEvent('dispatch:cart-update', {
      bubbles: true
    }));
  }

  async function handleAddToCart(button) {
    if (!button || isAdding || button.disabled) return;

    var variantId = button.getAttribute('data-variant-id');
    if (!variantId) return;

    var qty = getQty();
    var originalText = button.getAttribute('data-original-text') || button.textContent.trim();

    if (!button.getAttribute('data-original-text')) {
      button.setAttribute('data-original-text', originalText);
    }

    isAdding = true;
    button.disabled = true;
    button.textContent = 'Adding...';

    var prevErr = section.querySelector('.atc-error');
    if (prevErr) prevErr.textContent = '';

    try {
      var addData = await addItem(variantId, qty);
      await refreshCartUI(addData);

      button.textContent = 'Added';
      setTimeout(function() {
        isAdding = false;
        syncVariantState();
        button.textContent = originalText;
      }, 1200);
    } catch (err) {
      console.error('[Exclusive Book] Add to cart error:', err);

      var errEl = section.querySelector('.atc-error');
      if (!errEl) {
        errEl = document.createElement('p');
        errEl.className = 'atc-error';
        errEl.style.cssText = 'color:#e07070;font-size:13px;margin-top:10px;font-family:var(--font-body)';
        var actions = section.querySelector('.product-actions');
        if (actions) {
          actions.after(errEl);
        } else if (button.parentNode) {
          button.parentNode.appendChild(errEl);
        }
      }

      errEl.textContent = err.message || 'Could not add item. Please try again.';
      button.textContent = 'Error';

      setTimeout(function() {
        if (errEl) errEl.textContent = '';
        isAdding = false;
        syncVariantState();
        button.textContent = originalText;
      }, 1400);
    }
  }

  if (productForm) {
    productForm.addEventListener('submit', function(e) {
      e.preventDefault();
      e.stopPropagation();
      if (cartBtn) handleAddToCart(cartBtn);
    });
  }

  if (cartBtn) {
    cartBtn.setAttribute('type', 'button');
    cartBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      handleAddToCart(this);
    });
  }

  activateSlide(0, false);
  syncVariantState();
})();
</script>

{% schema %}
{
  "name": "Exclusive Book Product",
  "tag": "section",
  "class": "exclusive-book-product-section",
