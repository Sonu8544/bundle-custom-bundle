      "label": "Left glow opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 35
    },
    {
      "type": "range",
      "id": "edge_fade_opacity",
      "label": "Edge fade opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 45
    },
    {
      "type": "range",
      "id": "top_overlay_opacity",
      "label": "Top overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
