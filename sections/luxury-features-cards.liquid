{% liquid
  assign section_id = 'luxury-features-' | append: section.id
%}

<section
  id="{{ section_id }}"
  class="luxury-features-section"
  style="
    --lf-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --lf-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --lf-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --lf-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;

    --lf-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --lf-heading-size-tablet: {{ section.settings.heading_size_tablet }}px;
    --lf-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;

    --lf-card-radius: {{ section.settings.card_radius }}px;
    --lf-card-padding-y: {{ section.settings.card_padding_vertical }}px;
    --lf-card-padding-x: {{ section.settings.card_padding_horizontal }}px;
    --lf-card-gap: {{ section.settings.card_gap }}px;
    --lf-card-min-height: {{ section.settings.card_min_height }}px;
    --lf-card-bg: {{ section.settings.card_bg }};
    --lf-card-border-color: {{ section.settings.card_border_color }};
    --lf-card-border-opacity: {{ section.settings.card_border_opacity | divided_by: 100.0 }};
    --lf-card-shadow-opacity: {{ section.settings.card_shadow_opacity | divided_by: 100.0 }};

    --lf-icon-wrap-size: {{ section.settings.icon_circle_size }}px;
    --lf-icon-size: {{ section.settings.icon_size }}px;
    --lf-icon-radius: {{ section.settings.icon_circle_radius }}px;

    --lf-grid-gap: {{ section.settings.grid_gap }}px;
    --lf-card-width-desktop: {{ section.settings.card_width_desktop }}px;
    --lf-card-width-mobile: {{ section.settings.card_width_mobile }}px;

    --lf-content-max-width: {{ section.settings.content_max_width }}px;
    --lf-section-radius: {{ section.settings.section_radius }}px;

    --rbh-title-color-start: {{ section.settings.heading_gradient_start }};
    --rbh-title-color-end: {{ section.settings.heading_gradient_end }};
  "
>
  <div class="luxury-features-section__bg">
    {% if section.settings.bg_image_desktop != blank %}
      <div class="luxury-features-section__bg-desktop">
        {{
          section.settings.bg_image_desktop
          | image_url: width: 2400
          | image_tag:
            loading: 'lazy',
            widths: '1200, 1600, 1800, 2200, 2400',
            sizes: '100vw',
            class: 'luxury-features-section__bg-image',
            alt: section.settings.heading | escape
        }}
      </div>
    {% endif %}

    {% if section.settings.bg_image_mobile != blank %}
      <div class="luxury-features-section__bg-mobile">
        {{
          section.settings.bg_image_mobile
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            widths: '480, 640, 768, 900, 1200',
            sizes: '100vw',
            class: 'luxury-features-section__bg-image',
            alt: section.settings.heading | escape
        }}
      </div>
    {% endif %}

    <div class="luxury-features-section__overlay"></div>
  </div>

  <div class="page-width luxury-features-section__outer">
    <div class="luxury-features-section__inner">
      {% if section.settings.heading != blank %}
        <div class="luxury-features-section__head">
          <h2 class="luxury-features-section__heading" >
            {{ section.settings.heading }}
          </h2>
        </div>
      {% endif %}

      <div class="luxury-features-section__cards-wrap">
        <div class="luxury-features-section__cards" role="list">
          {% for block in section.blocks %}
            <div
              class="luxury-features-card"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              <div class="luxury-features-card__icon-wrap">
                {% if block.settings.icon_image != blank %}
                  {{
                    block.settings.icon_image
                    | image_url: width: 160
                    | image_tag:
                      loading: 'lazy',
                      widths: '80, 100, 120, 140, 160',
                      sizes: '(max-width: 767px) 72px, 100px',
                      class: 'luxury-features-card__icon-image',
                      alt: block.settings.title | escape
                      
                  }}
                {% elsif block.settings.icon_svg != blank %}
                  <div class="luxury-features-card__icon-svg">
                    {{ block.settings.icon_svg }}
                  </div>
                {% else %}
                  <div class="luxury-features-card__icon-placeholder">
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {% endif %}
              </div>

              {% if block.settings.title != blank %}
                <div class="luxury-features-card__content">
                  <div class="luxury-features-card__title">
                    {{ block.settings.title }}
                  </div>
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <style>
    #{{ section_id }} {
      position: relative;
      overflow: hidden;
      padding-top: var(--lf-pt-desktop);
      padding-bottom: var(--lf-pb-desktop);
      border-radius: var(--lf-section-radius);
      background: #050505;
      isolation: isolate;
    }

    #{{ section_id }} .luxury-features-section__bg,
    #{{ section_id }} .luxury-features-section__overlay,
    #{{ section_id }} .luxury-features-section__bg-desktop,
    #{{ section_id }} .luxury-features-section__bg-mobile {
      position: absolute;
      inset: 0;
    }

    #{{ section_id }} .luxury-features-section__bg {
      z-index: 0;
      pointer-events: none;
    }

    #{{ section_id }} .luxury-features-section__bg-desktop,
    #{{ section_id }} .luxury-features-section__bg-mobile {
      overflow: hidden;
    }

    #{{ section_id }} .luxury-features-section__bg-mobile {
      display: none;
    }

    #{{ section_id }} .luxury-features-section__bg-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      opacity: {{ section.settings.bg_image_opacity | divided_by: 100.0 }};
    }

    #{{ section_id }} .luxury-features-section__overlay {
      z-index: 1;
      background:
        radial-gradient(circle at left center, rgba(120, 84, 15, {{ section.settings.left_glow_opacity | divided_by: 100.0 }}) 0%, rgba(120, 84, 15, 0) 32%),
        linear-gradient(90deg, rgba(0, 0, 0, {{ section.settings.edge_fade_opacity | divided_by: 100.0 }}) 0%, rgba(0, 0, 0, 0) 14%, rgba(0, 0, 0, 0) 86%, rgba(0, 0, 0, {{ section.settings.edge_fade_opacity | divided_by: 100.0 }}) 100%),
        linear-gradient(180deg, rgba(0, 0, 0, {{ section.settings.top_overlay_opacity | divided_by: 100.0 }}) 0%, rgba(0, 0, 0, {{ section.settings.bottom_overlay_opacity | divided_by: 100.0 }}) 100%);
    }

    #{{ section_id }} .luxury-features-section__outer {
      position: relative;
      z-index: 2;
    }

    #{{ section_id }} .luxury-features-section__inner {
      max-width: var(--lf-content-max-width);
      margin: 0 auto;
    }

    #{{ section_id }} .luxury-features-section__head {
      margin-bottom: {{ section.settings.heading_bottom_spacing }}px;
    }

    #{{ section_id }} .luxury-features-section__heading {
      margin: 0;
      font-family: 'Bethany Elingston', serif;
      font-weight: 400;
      font-style: normal;
      font-size: var(--lf-heading-size-desktop);
      letter-spacing: 0;
      background: linear-gradient(165deg, var(--rbh-title-color-end) 0%, var(--rbh-title-color-start) 40%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
    }

    #{{ section_id }} .luxury-features-section__cards-wrap {
      position: relative;
    }

    #{{ section_id }} .luxury-features-section__cards {
      display: grid;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, var(--lf-card-width-desktop)));
      gap: var(--lf-grid-gap);
      align-items: stretch;
      justify-content: flex-start;
    }

    #{{ section_id }} .luxury-features-card {
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      gap: var(--lf-card-gap);
      min-height: var(--lf-card-min-height);
      padding: var(--lf-card-padding-y) var(--lf-card-padding-x);
      border-radius: var(--lf-card-radius);
      background: var(--lf-card-bg);
      border: 1px solid rgba(255, 255, 255, var(--lf-card-border-opacity));
      box-shadow: 0 20px 60px rgba(0, 0, 0, var(--lf-card-shadow-opacity));
      backdrop-filter: blur({{ section.settings.card_blur }}px);
      -webkit-backdrop-filter: blur({{ section.settings.card_blur }}px);
    }

    #{{ section_id }} .luxury-features-card__icon-wrap {
      width: var(--lf-icon-wrap-size);
      height: var(--lf-icon-wrap-size);
      min-width: var(--lf-icon-wrap-size);
      border-radius: var(--lf-icon-radius);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
      background:
        radial-gradient(circle at 28% 24%, #fff8d9 0%, #ebd08a 20%, #cba343 54%, #a97c18 100%);
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.16),
        0 10px 30px rgba(187, 145, 30, 0.22);
   
    }

    #{{ section_id }} .luxury-features-card__icon-wrap::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.35) 0%, rgba(255,255,255,0) 45%);
      pointer-events: none;
      
    }

    #{{ section_id }} .luxury-features-card__icon-image,
    #{{ section_id }} .luxury-features-card__icon-svg,
    #{{ section_id }} .luxury-features-card__icon-placeholder {
      width: var(--lf-icon-size);
      height: var(--lf-icon-size);
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #{{ section_id }} .luxury-features-card__icon-image {
      object-fit: contain;
      width:100px;
      height:100px;
    }

    #{{ section_id }} .luxury-features-card__icon-svg svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    #{{ section_id }} .luxury-features-card__icon-svg svg * {
      fill: #ffffff;
      stroke: #ffffff;
    }

    #{{ section_id }} .luxury-features-card__content {
      width: 100%;
      max-width: 160px;
    }

    #{{ section_id }} .luxury-features-card__title {
      margin: 0;
      font-family: "Satoshi", sans-serif;
      font-style: normal;
      font-weight: 400;
      font-size: 16px;
      line-height: 22px;
      text-align: center;
      letter-spacing: 0;
      color: #ffffff;
      word-break: break-word;
    }

    @media screen and (max-width: 1199px) {
      #{{ section_id }} .luxury-features-section__heading {
        font-size: var(--lf-heading-size-tablet);
      }

      #{{ section_id }} .luxury-features-section__cards {
        grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(0, 1fr));
      }
    }

    @media screen and (max-width: 767px) {
      #{{ section_id }} {
        padding-top: var(--lf-pt-mobile);
        padding-bottom: var(--lf-pb-mobile);
      }

      #{{ section_id }} .luxury-features-section__bg-desktop {
        display: none;
      }

      #{{ section_id }} .luxury-features-section__bg-mobile {
        display: block;
      }

      #{{ section_id }} .luxury-features-section__head {
        margin-bottom: {{ section.settings.heading_bottom_spacing_mobile }}px;
      }

      #{{ section_id }} .luxury-features-section__heading {
        font-size: var(--lf-heading-size-mobile);
      }

      #{{ section_id }} .luxury-features-section__cards-wrap {
        margin-right: calc(-1 * {{ section.settings.mobile_peek_right }}px);
      }

      #{{ section_id }} .luxury-features-section__cards {
        display: grid;
        grid-auto-flow: column;
        grid-auto-columns: var(--lf-card-width-mobile);
        grid-template-columns: none;
        gap: {{ section.settings.mobile_gap }}px;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 8px;
        padding-right: {{ section.settings.mobile_peek_right }}px;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
      }

      #{{ section_id }} .luxury-features-section__cards::-webkit-scrollbar {
        display: none;
      }

      #{{ section_id }} .luxury-features-card {
        scroll-snap-align: start;
        min-height: {{ section.settings.card_min_height_mobile }}px;
        padding: {{ section.settings.card_padding_vertical_mobile }}px {{ section.settings.card_padding_horizontal_mobile }}px;
        gap: {{ section.settings.card_gap_mobile }}px;
      }

      #{{ section_id }} .luxury-features-card__icon-wrap {
        width: {{ section.settings.icon_circle_size_mobile }}px;
        height: {{ section.settings.icon_circle_size_mobile }}px;
        min-width: {{ section.settings.icon_circle_size_mobile }}px;
      }

      #{{ section_id }} .luxury-features-card__icon-image,
      #{{ section_id }} .luxury-features-card__icon-svg,
      #{{ section_id }} .luxury-features-card__icon-placeholder {
        width: {{ section.settings.icon_size_mobile }}px;
        height: {{ section.settings.icon_size_mobile }}px;
      }

      #{{ section_id }} .luxury-features-card__content {
        max-width: 100%;
      }

      #{{ section_id }} .luxury-features-card__title {
        font-size: 16px;
        line-height: 22px;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Luxury features cards",
  "tag": "section",
  "class": "section section-luxury-features-cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Features"
    },
    {
      "type": "image_picker",
      "id": "bg_image_desktop",
      "label": "Background image desktop"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Background image mobile"
    },
    {
      "type": "range",
      "id": "bg_image_opacity",
      "label": "Background image opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 35
    },
    {
      "type": "color",
      "id": "heading_gradient_start",
      "label": "Heading gradient start",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_gradient_end",
      "label": "Heading gradient end",
      "default": "#BB911E"
    },
    {
      "type": "range",
