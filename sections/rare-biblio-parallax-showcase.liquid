{% comment %} 
{% liquid
  assign section_id = 'rb-parallax-slider-' | append: section.id
%}


<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<section
  id="{{ section_id }}"
  class="rbps"
  style="
    --rbps-bg-start: {{ section.settings.bg_start }};
    --rbps-bg-end: {{ section.settings.bg_end }};
    --rbps-border-color: {{ section.settings.border_color }};
    --rbps-heading-color: {{ section.settings.heading_color }};
    --rbps-text-color: {{ section.settings.text_color }};
    --rbps-overlay-opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
    --rbps-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --rbps-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --rbps-text-size-desktop: {{ section.settings.text_size_desktop }}px;
    --rbps-text-size-mobile: {{ section.settings.text_size_mobile }}px;
    --rbps-slide-min-height-desktop: {{ section.settings.slide_height_desktop }}px;
    --rbps-slide-min-height-mobile: {{ section.settings.slide_height_mobile }}px;
    --rbps-image-size-desktop: {{ section.settings.image_size_desktop }}px;
    --rbps-image-size-mobile: {{ section.settings.image_size_mobile }}px;
    --rbps-image-radius: {{ section.settings.image_radius }}px;
    --rbps-content-width: {{ section.settings.content_width }}px;
    --rbps-section-max-width: {{ section.settings.section_max_width }}px;
    --rbps-gap-desktop: {{ section.settings.desktop_gap }}px;
    --rbps-gap-mobile: {{ section.settings.mobile_gap }}px;
    --rbps-padding-top: {{ section.settings.padding_top }}px;
    --rbps-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
  data-rbps-section
>
  <div class="rbps__container" data-rbps-container>
    <div class="rbps__inner">
      {% for block in section.blocks %}
        {% liquid
          assign idx_mod = forloop.index0 | modulo: 2
          assign image_left = false
          if idx_mod == 0
            assign image_left = true
          endif
          assign show_content_grad = block.settings.enable_content_gradient | default: true
          assign rbps_img_loading = 'lazy'
          if forloop.first
            assign rbps_img_loading = 'eager'
          endif
        %}

        <article
          class="rbps__slide {% if image_left %}rbps__slide--image-left{% else %}rbps__slide--image-right{% endif %}"
          data-rbps-slide
          style="z-index: {{ forloop.index }};"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} 
            Counter-motion reveal structure:
            Outer moves from 100% to 0.
            Reveal (Inner) moves from -100% to 0.
          {%- endcomment -%}
          <div class="rbps__outer" data-rbps-outer>
            <div class="rbps__inner-reveal" data-rbps-reveal>
              
              <div class="rbps__slide-bg"></div>

              <div class="rbps__slide-grid">
                <div class="rbps__media-wrap">
                  <div class="rbps__media rbps__animate rbps__animate--media" data-rbps-anim="media">
                    {% if block.settings.image != blank %}
                      {{
                        block.settings.image
                        | image_url: width: 1600
                        | image_tag:
                          loading: rbps_img_loading,
                          widths: '400, 600, 800, 1000, 1200, 1400, 1600',
                          sizes: '(max-width: 749px) 78vw, 532px',
                          class: 'rbps__image',
                          alt: block.settings.heading | escape
                      }}
                    {% else %}
                      {{ 'image' | placeholder_svg_tag: 'rbps__image rbps__image--placeholder' }}
                    {% endif %}
                    <div class="rbps__image-overlay"></div>
                  </div>
                </div>

                <div class="rbps__content-wrap{% if show_content_grad %} rbps__content-wrap--grad{% endif %}">
                  <div class="rbps__content">
                    {% if block.settings.heading != blank %}
                      <h2 class="rbps__heading rbps__animate rbps__animate--heading" data-rbps-anim="heading">
                        {{ block.settings.heading }}
                      </h2>
                    {% endif %}

                    {% if block.settings.text != blank %}
                      <div class="rbps__text rte rbps__animate rbps__animate--text" data-rbps-anim="text">
                        {{ block.settings.text }}
                      </div>
                    {% endif %}

                    {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                      <div class="rbps__button-wrap rbps__animate rbps__animate--button" data-rbps-anim="button">
                        <a href="{{ block.settings.button_link }}" class="rbps__button">
                          {{ block.settings.button_label }}
                        </a>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </div>

            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #{{ section_id }} {
    position: relative;
    background: #050504;
    overflow: hidden;
  }

  #{{ section_id }} .rbps__container {
    position: relative;
    height: 100vh;
    width: 100%;
  }

  #{{ section_id }} .rbps__inner {
    width: min(100%, var(--rbps-section-max-width));
    margin: 0 auto;
    height: 100%;
    position: relative;
  }

  #{{ section_id }} .rbps__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    /* Controlled by GSAP */
    --rbps-progress: 0;
    --rbps-eased: 0;
  }

  /* First slide: full reveal before JS runs (avoids blur/low-opacity “entry” state) */
  #{{ section_id }} .rbps__slide:first-child {
    --rbps-eased: 1;
  }

  /* Counter-motion Wrappers */
  #{{ section_id }} .rbps__outer {
    width: 100%;
    height: 100%;
    overflow: hidden;
    position: absolute;
    top: 0;
    left: 0;
    will-change: transform;
  }

  #{{ section_id }} .rbps__inner-reveal {
    width: 100%;
    height: 100%;
    overflow: hidden;
    position: absolute;
    top: 0;
    left: 0;
    will-change: transform;
  }

  /* Background and Content */
  #{{ section_id }} .rbps__slide-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(77.47% 561.61% at 127.29% 73.12%, rgba(39, 29, 14, 0) 0%, #050504 100%),
      linear-gradient(180deg, var(--rbps-bg-start) 0%, var(--rbps-bg-end) 100%);
    opacity: calc(0.45 + (var(--rbps-eased) * 0.55));
    transform: scale(calc(1.15 - (var(--rbps-eased) * 0.15)));
    will-change: opacity, transform;
  }

  #{{ section_id }} .rbps__slide-grid {
    position: relative;
    z-index: 1;
    height: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    gap: var(--rbps-gap-desktop);
    padding: 48px 32px;
  }

  #{{ section_id }} .rbps__content-wrap--grad {
    align-self: stretch;
    min-height: 100%;
    background-repeat: no-repeat;
    background-size: 100% 100%;
  }

  #{{ section_id }} .rbps__slide--image-left .rbps__content-wrap--grad {
    background-image: radial-gradient(
      ellipse 73.61% 539.32% at 127.29% 73.12%,
      #271d0e 0%,
      #050504 100%
    );
  }

  #{{ section_id }} .rbps__slide--image-right .rbps__content-wrap--grad {
    background-image: radial-gradient(
      ellipse 73.61% 539.32% at -27.29% 73.12%,
      #271d0e 0%,
      #050504 100%
    );
  }

  #{{ section_id }} .rbps__slide--image-left .rbps__media-wrap { order: 1; }
  #{{ section_id }} .rbps__slide--image-left .rbps__content-wrap { order: 2; }
  #{{ section_id }} .rbps__slide--image-right .rbps__media-wrap { order: 2; }
  #{{ section_id }} .rbps__slide--image-right .rbps__content-wrap { order: 1; }

  #{{ section_id }} .rbps__media-wrap {
    align-self: center;
    display: flex;
    justify-content: center;
    align-items: center;
    perspective: 1200px;
  }

  #{{ section_id }} .rbps__media {
    position: relative;
    width: var(--rbps-image-size-desktop);
    height: var(--rbps-image-size-desktop);
    max-width: 100%;
    border-radius: var(--rbps-image-radius);
    overflow: hidden;
    background: #0a0907;
    box-shadow: 0 10px 40px rgba(0,0,0,0.35);
    will-change: transform, opacity;
  }

  #{{ section_id }} .rbps__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center center;
    transform: scale(calc(1.2 - (var(--rbps-eased) * 0.2)));
    will-change: transform;
  }

  #{{ section_id }} .rbps__image-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    border-radius: inherit;
    background: radial-gradient(
      52.48% 50% at 50% 50%,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, var(--rbps-overlay-opacity)) 100%
    );
    opacity: calc(1 - (var(--rbps-eased) * 0.3));
  }

  #{{ section_id }} .rbps__content-wrap {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
  }

  #{{ section_id }} .rbps__slide--image-left .rbps__content-wrap {
    justify-content: flex-start;
    text-align: left;
    padding-left: 40px;
  }

  #{{ section_id }} .rbps__slide--image-right .rbps__content-wrap {
    justify-content: flex-start;
    text-align: left;
    padding-left: 80px;
  }

  #{{ section_id }} .rbps__content {
    position: relative;
    z-index: 1;
    max-width: var(--rbps-content-width);
  }

  #{{ section_id }} .rbps__animate {
    will-change: transform, opacity, filter;
  }

  #{{ section_id }} .rbps__animate--media,
  #{{ section_id }} .rbps__animate--heading,
  #{{ section_id }} .rbps__animate--text,
  #{{ section_id }} .rbps__animate--button {
    opacity: calc(0.1 + (var(--rbps-eased) * 0.9));
  }

  /* Internal Parallax Animations */
  #{{ section_id }} .rbps__slide--image-left .rbps__animate--media {
    transform:
      translate3d(calc((1 - var(--rbps-eased)) * -120px), 0, 0)
      scale(calc(0.7 + (var(--rbps-eased) * 0.3)))
      rotate(calc((1 - var(--rbps-eased)) * -8deg));
  }

  #{{ section_id }} .rbps__slide--image-left .rbps__animate--heading {
    transform:
      translate3d(calc((1 - var(--rbps-eased)) * 120px), 0, 0)
      scale(calc(0.85 + (var(--rbps-eased) * 0.15)));
    filter: blur(calc((1 - var(--rbps-eased)) * 4px));
  }

  #{{ section_id }} .rbps__slide--image-left .rbps__animate--text {
    transform: translate3d(calc((1 - var(--rbps-eased)) * 90px), 0, 0);
  }

  #{{ section_id }} .rbps__slide--image-right .rbps__animate--media {
    transform:
      translate3d(calc((1 - var(--rbps-eased)) * 120px), 0, 0)
      scale(calc(0.7 + (var(--rbps-eased) * 0.3)))
      rotate(calc((1 - var(--rbps-eased)) * 8deg));
  }

  #{{ section_id }} .rbps__slide--image-right .rbps__animate--heading {
    transform:
      translate3d(calc((1 - var(--rbps-eased)) * -120px), 0, 0)
      scale(calc(0.85 + (var(--rbps-eased) * 0.15)));
    filter: blur(calc((1 - var(--rbps-eased)) * 4px));
  }

  #{{ section_id }} .rbps__heading {
    margin: 0 0 18px;
    color: var(--rbps-heading-color);
    font-family: "Bethany Elingston", serif;
    font-weight: 400;
    font-size: var(--rbps-heading-size-desktop);
    line-height: 1;
  }

  #{{ section_id }} .rbps__text,
  #{{ section_id }} .rbps__text p {
    margin: 0;
    color: var(--rbps-text-color);
    opacity: 0.7;
    font-family: "Satoshi", sans-serif;
    font-weight: 400;
    font-size: var(--rbps-text-size-desktop);
    line-height: 1.35;
  }

  #{{ section_id }} .rbps__text p + p { margin-top: 10px; }
  #{{ section_id }} .rbps__button-wrap { margin-top: 24px; }

  #{{ section_id }} .rbps__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 12px 22px;
    border-radius: 999px;
    text-decoration: none;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.16);
    background: rgba(255,255,255,0.06);
    transition: transform .3s ease, background .3s ease, border-color .3s ease;
  }

  #{{ section_id }} .rbps__button:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.24);
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} .rbps__slide-grid {
      grid-template-columns: 1fr;
      gap: var(--rbps-gap-mobile);
      padding: 32px 18px;
    }

    #{{ section_id }} .rbps__slide--image-left .rbps__content-wrap,
    #{{ section_id }} .rbps__slide--image-right .rbps__content-wrap {
      order: 2;
      justify-content: center;
      text-align: center;
      padding-left: 0;
    }

    #{{ section_id }} .rbps__media {
      width: min(100%, var(--rbps-image-size-mobile));
      height: min(calc(100vw - 36px), var(--rbps-image-size-mobile));
    }

    #{{ section_id }} .rbps__heading { font-size: var(--rbps-heading-size-mobile); }
    #{{ section_id }} .rbps__text, #{{ section_id }} .rbps__text p { font-size: var(--rbps-text-size-mobile); }

    #{{ section_id }} .rbps__slide--image-left .rbps__animate--media,
    #{{ section_id }} .rbps__slide--image-right .rbps__animate--media {
      transform:
        translate3d(0, calc((1 - var(--rbps-eased)) * 80px), 0)
        scale(calc(0.8 + (var(--rbps-eased) * 0.2)));
    }
  }
</style>

<script>
(function () {
  const SECTION_ID = '{{ section_id }}';

  function init() {
    const section = document.getElementById(SECTION_ID);
    if (!section) return;

    gsap.registerPlugin(ScrollTrigger);

    const container = section.querySelector('[data-rbps-container]');
    const outers = gsap.utils.toArray(section.querySelectorAll('[data-rbps-outer]'));
    const reveals = gsap.utils.toArray(section.querySelectorAll('[data-rbps-reveal]'));
    const slides = gsap.utils.toArray(section.querySelectorAll('[data-rbps-slide]'));
    
    if (!slides.length) return;

    // Clean up old triggers
    ScrollTrigger.getAll().forEach(t => {
      if (t.trigger && t.trigger.closest(`#${SECTION_ID}`)) t.kill();
    });

    // MASTER TIMELINE: Pins the whole container and sequences the shutter reveal
    // FIX: scrub increased from 1 → 2 for slower, more deliberate scroll feel
    let tl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        start: "top top",
        end: () => `+=${slides.length * 100}%`,
        pin: true,
        scrub: 2,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          // Pin/scroll measurement can lag first paint; keep first slide readable at section start
          if (slides[0] && self.progress < 0.14) {
            slides[0].style.setProperty('--rbps-eased', '1');
          }
        },
      }
    });

    // INITIAL STATE: Stack all shutters out of view except the first
    gsap.set(outers.slice(1), { yPercent: 100 });
    gsap.set(reveals.slice(1), { yPercent: -100 });

    // Slide 1: full “revealed” state (avoids black overlay + ~10% content opacity from --rbps-eased: 0)
    gsap.set(slides[0], { '--rbps-eased': '1', autoAlpha: 1 });
    slides[0].style.setProperty('--rbps-eased', '1');
    // Slides 2+: hidden so higher z-index siblings don’t stack on top / bleed through
    if (slides.length > 1) {
      gsap.set(slides.slice(1), { autoAlpha: 0 });
    }

    slides.forEach((slide, i) => {
      const proxy = { progress: i === 0 ? 1 : 0 };
      const revealAt = i === 1 ? 0 : '-=0.75';

      if (i > 0) {
        tl.to(slides[i], { autoAlpha: 1, duration: 0.05, ease: 'none' }, revealAt);
        tl.to([outers[i], reveals[i]], {
          yPercent: 0,
          duration: 1.8,
          ease: 'power1.inOut'
        }, revealAt);
      }

      if (i > 0) {
        tl.to(proxy, {
          progress: 1,
          duration: 1.8,
          ease: 'power1.inOut',
          onUpdate: () => {
            slide.style.setProperty('--rbps-eased', proxy.progress.toFixed(4));
          }
        }, '<');
      }

      if (i < slides.length - 1) {
        tl.to(slide, {
          autoAlpha: 0,
          scale: 0.95,
          duration: 0.5,
          ease: 'power1.inOut'
        }, '>-0.4');
      }
    });

    ScrollTrigger.refresh();

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        if (slides[0]) slides[0].style.setProperty('--rbps-eased', '1');
        ScrollTrigger.refresh();
      });
    });
  }

  document.addEventListener('shopify:section:load', init);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  window.addEventListener('resize', () => {
    ScrollTrigger.refresh();
  });
})();
</script>

