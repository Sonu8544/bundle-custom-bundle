      #{{ sid }} .slr-scroll__bottom {
        background: linear-gradient(180deg, #c8a96e 0%, #dfc08a 40%, #e8d49e 100%);
        border-radius: 8px 8px 0 0;
      }
      #{{ sid }} .slr-scroll__bottom {
        border-radius: 0 0 8px 8px;
      }
      #{{ sid }} .slr-scroll__paper {
        background: linear-gradient(180deg, #e8d49e 0%, #f0dfa8 50%, #e8d49e 100%);
      }
    {% endif %}

    /* ── Scroll top roll ── */
    #{{ sid }} .slr-scroll__top {
      height: var(--slr-roll-height-desktop);
      background-position: center top;
      background-size: 100% auto;
      z-index: 3;
      transform: translateY(calc((1 - var(--slr-progress)) * 115px));
      transition: transform 0.12s linear;
      will-change: transform;
    }

    /* ── Scroll bottom roll ── */
    #{{ sid }} .slr-scroll__bottom {
      height: var(--slr-roll-height-desktop);
      background-position: center bottom;
      background-size: 100% auto;
      z-index: 3;
      transform: translateY(calc((var(--slr-progress) - 1) * 115px));
      transition: transform 0.12s linear;
      will-change: transform;
    }

    /* ── Paper body ── */
    #{{ sid }} .slr-scroll__paper {
      position: relative;
      overflow: hidden;
      width: calc(100% - 7%);
      min-height: 8px;
      height: calc(16px + (var(--slr-progress) * var(--slr-open-height-desktop)));
      margin-top: calc(var(--slr-roll-height-desktop) * -0.30);
      margin-bottom: calc(var(--slr-roll-height-desktop) * -0.30);
      background-position: center center;
      background-size: 100% 100%;
      transition: height 0.12s linear;
      will-change: height;
      z-index: 2;
    }

    /* Subtle vignette on paper edges */
    #{{ sid }} .slr-scroll__paper::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(120, 80, 20, 0.06) 0%,
        transparent 15%,
        transparent 85%,
        rgba(120, 80, 20, 0.06) 100%
      );
      pointer-events: none;
      z-index: 1;
    }

    /* ── Paper inner content ── */
    #{{ sid }} .slr-scroll__paper-inner {
      position: relative;
      z-index: 2;
      width: min(78%, var(--slr-text-width));
      margin: 0 auto;
      text-align: center;
      padding:
        calc(34px + (var(--slr-progress) * 54px))
        20px
        calc(26px + (var(--slr-progress) * 44px));
      opacity: clamp(0, calc((var(--slr-progress) - 0.28) * 2.4), 1);
      transform: translateY(calc((1 - var(--slr-progress)) * 28px));
      transition: opacity 0.12s linear, transform 0.12s linear;
      will-change: opacity, transform;
      pointer-events: none;
    }

    /* ── Eyebrow ── */
    #{{ sid }} .slr-eyebrow {
      margin-bottom: 10px;
      font-family: 'Satoshi', Georgia, serif;
      font-size: 13px;
      font-weight: 400;
      line-height: 1.2;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--slr-title-color);
      opacity: 0.65;
    }

    /* ── Heading: Bethany Elingston + gradient on accent word ── */
    #{{ sid }} .slr-heading {
      margin: 0 0 4px;
      font-family: 'Bethany Elingston', 'Playfair Display', Georgia, serif;
      font-size: var(--slr-heading-size-desktop);
      line-height: 1.10;
      font-weight: 400;
      letter-spacing: 0;
      color: var(--slr-title-color);
    }

    #{{ sid }} .slr-heading__plain {
      color: var(--slr-title-color);
    }

    /* Figma gradient: 270.6deg, #A87E0A 9.74% → #000000 71.76% */
    #{{ sid }} .slr-heading__gradient {
      background: linear-gradient(270.6deg, #A87E0A 9.74%, #000000 71.76%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Divider ── */
    #{{ sid }} .slr-divider {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin: 16px 0 20px;
    }

    #{{ sid }} .slr-divider__line {
      display: block;
      flex: 1;
      max-width: 80px;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(115,83,33,0.45));
    }

    #{{ sid }} .slr-divider__line--right {
      background: linear-gradient(to left, transparent, rgba(115,83,33,0.45));
    }

    #{{ sid }} .slr-divider__ornament {
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }

    #{{ sid }} .slr-divider__ornament svg {
      display: block;
    }

    /* ── Body copy: Satoshi ── */
    #{{ sid }} .slr-body,
    #{{ sid }} .slr-body p {
      margin: 0;
      font-family: 'Satoshi', Georgia, serif;
      color: var(--slr-body-color);
      font-size: var(--slr-body-size-desktop);
      line-height: 1.75;
      font-weight: 400;
      letter-spacing: 0;
    }

    #{{ sid }} .slr-body p + p {
      margin-top: 14px;
    }

    /* ── CTA button ── */
    #{{ sid }} .slr-actions {
      margin-top: 28px;
      pointer-events: auto;
    }

    #{{ sid }} .slr-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 160px;
      padding: 13px 28px;
      border-radius: 999px;
      text-decoration: none;
      font-family: 'Satoshi', Georgia, serif;
      font-size: 14px;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: #fff;
      background: linear-gradient(135deg, #2a2117 0%, #4a3620 100%);
      box-shadow: 0 4px 16px rgba(0,0,0,0.25);
      transition: transform 0.22s ease, box-shadow 0.22s ease, opacity 0.22s ease;
    }

    #{{ sid }} .slr-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.32);
      opacity: 0.93;
    }

    /* ═══════════════════════════════════
       TABLET  (989px and below)
    ═══════════════════════════════════ */
    @media (max-width: 989px) {
      #{{ sid }} .slr-scroll {
        width: min(94vw, 760px);
      }

      #{{ sid }} .slr-scroll__top,
      #{{ sid }} .slr-scroll__bottom {
        height: var(--slr-roll-height-mobile);
      }

      #{{ sid }} .slr-scroll__paper {
        width: calc(100% - 9%);
        height: calc(12px + (var(--slr-progress) * var(--slr-open-height-mobile)));
        margin-top: calc(var(--slr-roll-height-mobile) * -0.28);
        margin-bottom: calc(var(--slr-roll-height-mobile) * -0.28);
      }

      #{{ sid }} .slr-scroll__paper-inner {
        width: min(82%, 540px);
        padding:
          calc(26px + (var(--slr-progress) * 34px))
          18px
          calc(22px + (var(--slr-progress) * 28px));
      }

      #{{ sid }} .slr-heading {
        font-size: var(--slr-heading-size-mobile);
        line-height: 1.12;
      }

      #{{ sid }} .slr-body,
      #{{ sid }} .slr-body p {
        font-size: var(--slr-body-size-mobile);
        line-height: 1.68;
      }
    }

    /* ═══════════════════════════════════
       MOBILE  (767px and below)
    ═══════════════════════════════════ */
    @media (max-width: 767px) {
      #{{ sid }} .slr-stage {
        height: max(var(--slr-section-height), 220vh);
      }

      #{{ sid }} .slr-sticky {
        top: 0;
        min-height: 100vh;
      }

      #{{ sid }} .slr-scroll {
        width: min(96vw, 420px);
      }

      #{{ sid }} .slr-scroll__paper-inner {
        width: min(84%, 340px);
      }

      #{{ sid }} .slr-heading {
        font-size: clamp(22px, 7vw, var(--slr-heading-size-mobile));
        line-height: 1.13;
      }

      #{{ sid }} .slr-body,
      #{{ sid }} .slr-body p {
        font-size: clamp(13px, 3.8vw, var(--slr-body-size-mobile));
        line-height: 1.65;
      }

      #{{ sid }} .slr-divider {
        margin: 12px 0 16px;
      }

      #{{ sid }} .slr-divider__ornament svg {
        width: 48px;
        height: 18px;
      }

      #{{ sid }} .slr-button {
        min-width: 140px;
        padding: 12px 22px;
        font-size: 13px;
      }
    }

    /* ═══════════════════════════════════
       REDUCED MOTION
    ═══════════════════════════════════ */
    @media (prefers-reduced-motion: reduce) {
      #{{ sid }} .slr-scroll,
      #{{ sid }} .slr-scroll__top,
      #{{ sid }} .slr-scroll__bottom,
      #{{ sid }} .slr-scroll__paper,
      #{{ sid }} .slr-scroll__paper-inner {
        transition: none !important;
      }
    }
  </style>

  <script>
    (() => {
      const section = document.getElementById('{{ sid }}');
      if (!section) return;

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const clamp = (v, mn, mx) => Math.min(Math.max(v, mn), mx);

      const updateProgress = () => {
        const rect = section.getBoundingClientRect();
        const total = Math.max(section.offsetHeight - window.innerHeight, 1);
        const scrolled = clamp(-rect.top, 0, total);
        const progress = prefersReduced ? 1 : clamp(scrolled / total, 0, 1);
        section.style.setProperty('--slr-progress', progress.toFixed(4));
      };

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => { updateProgress(); ticking = false; });
      };

      updateProgress();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      document.addEventListener('shopify:section:load', onScroll);
      document.addEventListener('shopify:section:reorder', onScroll);
      document.addEventListener('shopify:section:select', onScroll);
    })();
  </script>

