  endif
-%}

{{ 'https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap' | stylesheet_tag }}

<style>
  #scroll-{{ sid }} {
    position: relative;
    width: 100%;
    {% if full_screen %}
      height: 150vh; height: 150dvh;
    {% else %}
      height: {{ section_height }}px;
    {% endif %}
    background: {{ bg_color }};
    overflow: hidden;
    -webkit-user-select: none; user-select: none;
    font-family: 'Cormorant Garamond', 'Georgia', serif;
  }
  #scroll-{{ sid }}::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 42%, rgba(30,22,10,0.12) 0%, transparent 62%);
    z-index: 0; pointer-events: none;
  }
  #scroll-{{ sid }} .ps-scene {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    perspective: 900px; perspective-origin: 50% 50%;
    width: 77%; 
    max-width: {{ max_scroll_width }}px; z-index: 2;
  }
  #scroll-{{ sid }} .ps-wrap {
    display: flex; flex-direction: column; align-items: center;
    transform-style: preserve-3d;
  }
  #scroll-{{ sid }} .ps-roller {
    width: 100%; position: relative; z-index: 10;
    transform-style: preserve-3d; will-change: transform, filter;
  }
  #scroll-{{ sid }} .ps-roller img {
    width: 100%; height: auto; display: block;
    pointer-events: none; -webkit-user-drag: none;
  }
  #scroll-{{ sid }} .ps-paper {
    width: 100%; height: 0; overflow: hidden;
    position: relative; z-index: 1;
    margin-top: 0px; margin-bottom: 0px;
    will-change: height;
  }
  #scroll-{{ sid }} .ps-paper-inner {
    width: 100%; min-height: 100%;
    background-image: url('{{ img_mid }}');
    background-size: 100% auto;
    background-repeat: repeat-y;
    background-position: top center;
    display: flex; align-items: center; justify-content: center;
  }
  #scroll-{{ sid }} .ps-txt {
    position: relative; z-index: 2; width: 100%;
    padding: clamp(12px, 2.8vw, 22px) clamp(14%, 5vw, 20%) clamp(14px, 2.5vw, 24px);
    text-align: center; color: {{ section.settings.text_color }};
    opacity: 0; will-change: opacity;
    width: 90%;
  }
  #scroll-{{ sid }} .ps-txt h2.ps-title {
    font-family: 'Cormorant Garamond', 'Georgia', 'Times New Roman', serif;
    font-weight: 600;
    margin: 0 0 0.28em 0;
    letter-spacing: 0.02em;
    line-height: 1.18;
    padding: 0;
    text-shadow: 0 1px 0 rgba(255, 248, 235, 0.35);
  }
  #scroll-{{ sid }} .ps-txt h2.ps-title--plain {
    color: {{ section.settings.heading_color }};
  }
  #scroll-{{ sid }} .ps-txt .ps-title__lead {
    color: {{ section.settings.heading_color }};
    font-weight: 600;
  }
  #scroll-{{ sid }} .ps-txt .ps-title__accent {
    display: inline-block;
    margin-left: 0.14em;
    font-weight: 600;
    background: linear-gradient(165deg, #e8d5a8 0%, {{ section.settings.accent_color }} 38%, #6b5420 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  #scroll-{{ sid }} .ps-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35em;
    margin: 0.55em auto 0.65em;
    max-width: min(320px, 88%);
  }
  #scroll-{{ sid }} .ps-ornament__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, {{ section.settings.accent_color }}, transparent);
    opacity: 0.85;
  }
  #scroll-{{ sid }} .ps-ornament__flourish {
    flex: 0 0 auto;
    width: 10px;
    height: 10px;
    border: 1px solid {{ section.settings.accent_color }};
    transform: rotate(45deg);
    opacity: 0.9;
    box-shadow: 0 0 0 1px rgba(212, 175, 55, 0.25);
  }
  #scroll-{{ sid }} .ps-txt .ps-sub {
    font-family: 'Cinzel', serif; font-weight: 400;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    opacity: 0.75; margin: 0.4em 0 0.5em; line-height: 1.35;
    font-size: 0.88em;
  }
  #scroll-{{ sid }} .ps-txt .ps-body {
    font-family: "Satoshi", var(--font-body-family, system-ui), -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 400;
    line-height: 1.65;
    margin: 0;
    text-align: center;
    color: {{ section.settings.text_color }};
  }
  #scroll-{{ sid }} .ps-txt .ps-body p {
    margin: 0 0 0.65em 0;

    font-family: "Satoshi", sans-serif;
    font-weight: 400;
    font-size: 32px;
    line-height: 47px;
    letter-spacing: 0%;
    text-align: center;
    color: #000000;
  }
  #scroll-{{ sid }} .ps-txt .ps-body p:last-child {
    margin-bottom: 0;
  }
  #scroll-{{ sid }} .ps-txt .ps-quote {
    font-style: italic; opacity: 0.72; margin: 0.5em 0; line-height: 1.5;
    font-family: "Satoshi", var(--font-body-family, system-ui), sans-serif;
  }
  #scroll-{{ sid }} .ps-txt .ps-sep {
    border: none; border-top: 1px solid rgba(90,50,20,0.2);
    margin: 0.65em auto 0.4em; width: 42%;
  }
  #scroll-{{ sid }} .ps-txt .ps-stamp {
    font-family: 'Cinzel', serif; letter-spacing: 4px;
    text-transform: uppercase; opacity: 0.8; padding-top: 0.15em;
  }
  #scroll-{{ sid }} .ps-hint {
    position: absolute; bottom: 22px; left: 50%;
    transform: translateX(-50%);
    color: {{ section.settings.accent_color }};
    text-transform: uppercase; letter-spacing: 3px;
    font-size: 0.55rem; font-family: 'Cinzel', serif; font-weight: 700;
    z-index: 100; background: rgba(10,8,4,0.85);
    padding: 8px 22px; border-radius: 22px;
    border: 1px solid rgba(212,175,55,0.12);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    pointer-events: none; transition: opacity 0.5s;
    animation: psFloat-{{ sid }} 3s ease-in-out infinite; white-space: nowrap;
  }
  @keyframes psFloat-{{ sid }} {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%      { transform: translateX(-50%) translateY(-5px); }
  }
  #scroll-{{ sid }} .ps-pbar {
    position: absolute; right: 12px; top: 50%;
    transform: translateY(-50%);
    width: 3px; height: 80px;
    background: rgba(212,175,55,0.08);
    border-radius: 3px; z-index: 100;
    overflow: hidden; opacity: 0; transition: opacity 0.4s;
  }
  #scroll-{{ sid }} .ps-pbar-fill {
    width: 100%; height: 0%;
    background: {{ section.settings.accent_color }};
    opacity: 0.5; border-radius: 3px; transition: height 0.05s;
  }
  @media (max-width: 989px) {
    #scroll-{{ sid }} .ps-txt {
      padding: clamp(10px, 2.2vw, 18px) clamp(12%, 4.5vw, 17%) clamp(12px, 2.2vw, 20px);
    }
  }
  /* Small screens: full-bleed scroll; copy inset ~12% each side of paper (mockup: 10–15%) */
  @media (max-width: 749px) {
    #scroll-{{ sid }} .ps-scene {
      left: 0;
      right: 0;
      width: 100%;
      max-width: none;
      transform: translateY(-50%);
      padding-left: env(safe-area-inset-left, 0px);
      padding-right: env(safe-area-inset-right, 0px);
      box-sizing: border-box;
    }
    #scroll-{{ sid }} .ps-wrap {
      width: 100%;
      max-width: 100%;
    }
    #scroll-{{ sid }} .ps-paper-inner {
      min-width: 0;
      overflow-x: hidden;
      box-sizing: border-box;
    }
    #scroll-{{ sid }} .ps-paper {
      overflow-x: hidden;
    }
    #scroll-{{ sid }} .ps-txt {
      width: 100%;
      max-width: 100%;
      min-width: 0;
      box-sizing: border-box;
      padding-top: 8px;
      padding-bottom: 12px;
      /* Deckled art needs a wider inset than the flat center — % is of .ps-paper-inner */
      padding-left: max(18%, 18px, env(safe-area-inset-left, 0px));
      padding-right: max(18%, 18px, env(safe-area-inset-right, 0px));
      overflow-x: hidden;
      overflow-wrap: anywhere;
      word-break: break-word;
      font-size: 15px;
      line-height: 1.6;
    }
    #scroll-{{ sid }} .ps-txt h2.ps-title {
      word-wrap: break-word;
      overflow-wrap: anywhere;
      word-break: break-word;
      max-width: 100%;
      hyphens: auto;
      -webkit-hyphens: auto;
    }
    #scroll-{{ sid }} .ps-txt h2.ps-title .ps-title__accent {
      max-width: 100%;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    #scroll-{{ sid }} .ps-txt .ps-body {
      font-size: 1em;
      width: 100%;
      min-width: 0;
      word-wrap: break-word;
      overflow-wrap: anywhere;
      word-break: break-word;
      max-width: 100%;
      hyphens: auto;
      -webkit-hyphens: auto;
    }
    #scroll-{{ sid }} .ps-txt .ps-body p,
    #scroll-{{ sid }} .ps-txt .ps-body li,
    #scroll-{{ sid }} .ps-txt .ps-body td,
    #scroll-{{ sid }} .ps-txt .ps-body th {
      max-width: 100%;
      box-sizing: border-box;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    #scroll-{{ sid }} .ps-txt .ps-body * {
      max-width: 100%;
      box-sizing: border-box;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    #scroll-{{ sid }} .ps-txt .ps-body p {
      margin: 0 0 0.65em 0;
    }
    #scroll-{{ sid }} .ps-txt .ps-body img,
    #scroll-{{ sid }} .ps-txt .ps-body video,
    #scroll-{{ sid }} .ps-txt .ps-body iframe {
      max-width: 100%;
      height: auto;
    }
    #scroll-{{ sid }} .ps-txt .ps-body table {
      max-width: 100%;
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    #scroll-{{ sid }} .ps-txt .ps-sub,
    #scroll-{{ sid }} .ps-txt .ps-quote,
    #scroll-{{ sid }} .ps-txt .ps-stamp {
      overflow-wrap: anywhere;
      word-break: break-word;
      max-width: 100%;
    }
    #scroll-{{ sid }} .ps-ornament {
      margin: 0.45em auto 0.55em;
      width: 100%;
      max-width: min(300px, 76%);
      padding-left: 0;
      padding-right: 0;
      box-sizing: border-box;
    }
  }
  @media (max-width: 480px) {
    #scroll-{{ sid }} .ps-txt {
      padding-top: 6px;
      padding-bottom: 10px;
      padding-left: max(19%, 16px, env(safe-area-inset-left, 0px));
      padding-right: max(19%, 16px, env(safe-area-inset-right, 0px));
    }
    #scroll-{{ sid }} .ps-ornament {
      max-width: min(260px, 62%);
    }
  }
  @media (max-width: 389px) {
    #scroll-{{ sid }} .ps-txt {
      padding-left: max(20%, 14px, env(safe-area-inset-left, 0px));
      padding-right: max(20%, 14px, env(safe-area-inset-right, 0px));
    }
  }
</style>

<div id="scroll-{{ sid }}" class="main-section-wrapper--">
  {% comment %} <div class="ps-hint" data-ps-hint>Scroll · Swipe · Arrow Keys</div> {% endcomment %}
  <div class="ps-hint" data-ps-hint></div>
  <div class="ps-pbar" data-ps-pbar><div class="ps-pbar-fill" data-ps-pfill></div></div>
  <div class="ps-scene">
    <div class="ps-wrap" data-ps-wrap>
      <div class="ps-roller ps-top-r" data-ps-top>
        <img src="{{ img_top }}" alt="" draggable="false" loading="lazy" width="" height="">
      </div>
      <div class="ps-paper" data-ps-paper>
        <div class="ps-paper-inner" data-ps-pin>
          <div class="ps-txt" data-ps-txt>
            {% if heading_lead != blank or heading_accent != blank %}
              <h2 class="ps-title">
                {% if heading_lead != blank %}<span class="ps-title__lead">{{ heading_lead }}</span>{% endif %}
                {% if heading_accent != blank %}<span class="ps-title__accent">{{ heading_accent }}</span>{% endif %}
              </h2>
            {% elsif heading != blank %}
              <h2 class="ps-title ps-title--plain">{{ heading }}</h2>
            {% endif %}

            {% if show_title_divider %}
              {% if heading_lead != blank or heading_accent != blank or heading != blank %}
                <div class="ps-ornament" aria-hidden="true">
                  <span class="ps-ornament__line"></span>
                  <span class="ps-ornament__flourish"></span>
                  <span class="ps-ornament__line"></span>
                </div>
              {% endif %}
            {% endif %}

            {% if subtitle != blank %}<p class="ps-sub">{{ subtitle }}</p>{% endif %}
            {% if body_text != blank %}<div class="ps-body rte">{{ body_text }}</div>{% endif %}
            {% if quote_text != blank %}<p class="ps-quote">&ldquo;{{ quote_text }}&rdquo;</p>{% endif %}
            {% if footer_text != blank %}
              <hr class="ps-sep">
              <p class="ps-stamp">{{ footer_text }}</p>
            {% endif %}
          </div>
        </div>
      </div>
      <div class="ps-roller ps-bot-r" data-ps-bot>
        <img src="{{ img_bot }}" alt="" draggable="false" loading="lazy" width="" height="">
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var root  = document.getElementById('scroll-{{ sid }}');
  if (!root) return;

  var paper = root.querySelector('[data-ps-paper]');
  var pIn   = root.querySelector('[data-ps-pin]');
  var txt   = root.querySelector('[data-ps-txt]');
  var hint  = root.querySelector('[data-ps-hint]');
  var topR  = root.querySelector('[data-ps-top]');
  var botR  = root.querySelector('[data-ps-bot]');
  var wrap  = root.querySelector('[data-ps-wrap]');
  var pbar  = root.querySelector('[data-ps-pbar]');
  var pFill = root.querySelector('[data-ps-pfill]');

  var progress = 0, target = 0, raf = null, touched = false;
  var TOP_R = 0.2504, BOT_R = 0.2304;

  /*
   * SCROLL PASS-THROUGH STATE
   * ─────────────────────────
   * escaped = user hit an edge and scroll was released to the page.
   * We only re-capture when user scrolls back toward the scroll range
   * AND the section is centered in the viewport.
   */
  var escaped = false;
  var EDGE = 0.005;

  function maxH() {
    var rh = root.offsetHeight;
    var ww = wrap.offsetWidth;
    return Math.min(rh - TOP_R * ww - BOT_R * ww - 36, 540);
  }

  function isCentered() {
    var r  = root.getBoundingClientRect();
    var vh = window.innerHeight;
    var mid = r.top + r.height / 2;
    return mid > vh * 0.1 && mid < vh * 0.9;
  }

  /**
   * Should we capture this scroll event or let the page handle it?
   *
   * @param {number} delta - positive = scroll down, negative = scroll up
   * @returns {boolean} true = capture (preventDefault), false = pass through
   */
  function shouldCapture(delta) {
    if (!isCentered()) {
      escaped = false;
      return false;
    }

    /* Already escaped → stay escaped until user reverses into range */
    if (escaped) {
      var reEnterFromBottom = target <= EDGE && delta > 0;
      var reEnterFromTop   = target >= 1 - EDGE && delta < 0;
      if (reEnterFromBottom || reEnterFromTop) {
        escaped = false;
        return true;
      }
      return false;
    }

    /* Mid-range → always capture */
    if (target > EDGE && target < 1 - EDGE) return true;

    /* At bottom (closed, ≈ 0) */
    if (target <= EDGE) {
      if (delta > 0) return true;   /* opening → capture */
      escaped = true; return false;  /* scrolling up → release */
    }

    /* At top (fully open, ≈ 1) */
    if (target >= 1 - EDGE) {
      if (delta < 0) return true;   /* closing → capture */
      escaped = true; return false;  /* scrolling down → release */
    }

    return true;
  }

  /* ── Text auto-fit (≤749px: 15px body; wider: scale from scroll width) ── */
  function fitText() {
    var mh = maxH(), ww = wrap.offsetWidth;
    var narrow = window.innerWidth <= 749;
    var bB, bT, bS, bQ, bSt;

    if (narrow) {
      bB = 15;
      bT = Math.min(Math.max(ww * 0.058, 22), 28);
      bS = Math.min(10, Math.round(15 * 0.67));
      bQ = 13.8;
      bSt = Math.min(ww * 0.018, 8);
    } else {
      bB = Math.min(ww * 0.032, 16.5);
      bT = Math.min(ww * 0.052, 27);
      bS = Math.min(ww * 0.02, 10);
      bQ = bB * 0.92;
      bSt = Math.min(ww * 0.015, 8);
    }

    txt.style.fontSize = bB + 'px';
    var h2  = txt.querySelector('h2');
    var sub = txt.querySelector('.ps-sub');
    var qt  = txt.querySelector('.ps-quote');
    var st  = txt.querySelector('.ps-stamp');
    if (h2)  h2.style.fontSize  = bT + 'px';
    if (sub) sub.style.fontSize = bS + 'px';
    if (qt)  qt.style.fontSize  = bQ + 'px';
    if (st)  st.style.fontSize  = bSt + 'px';

    var ch = txt.scrollHeight;
    if (ch > mh - 16) {
      var minScale = narrow ? Math.max(12 / bB, 0.72) : 0.4;
      var s = Math.max((mh - 16) / ch, minScale);
      txt.style.fontSize = (bB * s) + 'px';
      if (h2)  h2.style.fontSize  = (bT * s) + 'px';
      if (sub) sub.style.fontSize = (bS * s) + 'px';
      if (qt)  qt.style.fontSize  = (bQ * s) + 'px';
      if (st)  st.style.fontSize  = (bSt * s) + 'px';
    }
  }

  /* ── Render ── */
  function render() {
    var mh = maxH(), h = progress * mh;
    paper.style.height  = h + 'px';
    pIn.style.minHeight = h + 'px';

    var deg = progress * 12, lift = progress * 4;
    topR.style.transform = 'rotateX(' + (-deg) + 'deg) translateZ(' + lift + 'px)';
    botR.style.transform = 'rotateX(' + deg + 'deg) translateZ(' + lift + 'px)';

    var br = 1 + progress * 0.08;
    topR.querySelector('img').style.filter = 'brightness(' + br + ')';
    botR.querySelector('img').style.filter = 'brightness(' + br + ')';

    txt.style.opacity  = progress > 0.18 ? Math.min((progress - 0.18) / 0.3, 1) : 0;
    hint.style.opacity = progress > 0.03 ? 0 : 1;

    if (touched) {
      pbar.style.opacity = progress > 0.01 && progress < 0.99 ? 0.8 : 0;
      pFill.style.height = (progress * 100) + '%';
    }
  }

  function animate() {
    var d = target - progress;
    if (Math.abs(d) > 0.0002) {
      progress += d * 0.13;
      render();
      raf = requestAnimationFrame(animate);
    } else {
      progress = target; render(); raf = null;
    }
  }

  function go(v) {
    target = Math.max(0, Math.min(1, v));
    if (!touched) touched = true;
    if (!raf) raf = requestAnimationFrame(animate);
  }

  /* ── WHEEL ── */
  root.addEventListener('wheel', function(e) {
    if (shouldCapture(e.deltaY)) {
      e.preventDefault();
      go(target + e.deltaY * 0.0008);
    }
  }, { passive: false });

  /* ── TOUCH ── */
  var ty0 = 0, tp0 = 0, tActive = false;
  root.addEventListener('touchstart', function(e) {
    ty0 = e.touches[0].clientY; tp0 = target; tActive = true;
  }, { passive: true });

  root.addEventListener('touchmove', function(e) {
    if (!tActive) return;
    var dy = ty0 - e.touches[0].clientY;
    if (shouldCapture(dy)) {
      e.preventDefault();
      go(tp0 + dy * 0.002);
    }
  }, { passive: false });

  root.addEventListener('touchend', function() { tActive = false; }, { passive: true });

  /* ── KEYBOARD ── */
  document.addEventListener('keydown', function(e) {
    if (!isCentered()) return;
    if (e.key === 'ArrowDown' || e.key === ' ') {
      if (shouldCapture(1)) { e.preventDefault(); go(target + 0.08); }
    } else if (e.key === 'ArrowUp') {
      if (shouldCapture(-1)) { e.preventDefault(); go(target - 0.08); }
    }
  });

  /* ── Reset escape when section re-enters viewport center ── */
  var st;
  window.addEventListener('scroll', function() {
    clearTimeout(st);
    st = setTimeout(function() {
      if (isCentered() && escaped) escaped = false;
    }, 150);
  }, { passive: true });

  window.addEventListener('resize', function() { fitText(); render(); });
  fitText(); render();
})();
</script>

{% schema %}
{
  "name": "Parchment Scroll",
  "tag": "section",
  "class": "parchment-scroll-section main-section-wrapper--",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Scroll Content" },
    { "type": "paragraph", "content": "Title: first part in dark type, second part in gold. Leave both blank to use the single heading line below." },
    { "type": "text", "id": "heading_lead", "label": "Heading (first part)", "default": "About Rare" },
    { "type": "text", "id": "heading_accent", "label": "Heading (gold part)", "default": "Biblio" },
    { "type": "text", "id": "heading", "label": "Heading (single line fallback)", "default": "About Rare Biblio", "info": "Used only if both split title fields above are empty." },
    { "type": "checkbox", "id": "show_title_divider", "label": "Show gold divider under title", "default": true },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "-", "info": "Optional. Replace with your subtitle, or leave as a single hyphen (-) to hide." },
    { "type": "richtext", "id": "body_text", "label": "Body text", "default": "<p>Welcome to Rare Biblio, the premier destination for bibliophiles and book lovers who appreciate the art of bookmaking. As a rare books store, we specialize in handcrafted leather-bound books, personalization &amp; customization services, and restoration of valuable old books, antiquarian books, and manuscripts.</p>" },
    { "type": "text", "id": "quote_text", "label": "Quote", "default": "-", "info": "Optional. Leave as a single hyphen (-) to hide." },
    { "type": "text", "id": "footer_text", "label": "Footer stamp", "default": "-", "info": "Optional. Leave as a single hyphen (-) to hide." },
    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "full_screen", "label": "Full screen height", "default": true },
    { "type": "range", "id": "section_height", "label": "Section height (when not full screen)", "min": 400, "max": 1500, "step": 50, "default": 700, "unit": "px" },
    { "type": "range", "id": "max_scroll_width", "label": "Max scroll width", "min": 400, "max": 1000, "step": 20, "default": 680, "unit": "px" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#0a0804" },
    { "type": "color", "id": "text_color", "label": "Body text color", "default": "#17130f" },
    { "type": "color", "id": "heading_color", "label": "Heading (first part) color", "default": "#121212" },
    { "type": "color", "id": "accent_color", "label": "Gold accent (title, divider, hints)", "default": "#a87e0a" },
    { "type": "header", "content": "Scroll Images" },
    { "type": "paragraph", "content": "Upload custom scroll images, or leave empty to use default assets (scroll-top.png, scroll-mid.png, scroll-bot.png)." },
    { "type": "image_picker", "id": "img_top", "label": "Top roller image" },
    { "type": "image_picker", "id": "img_mid", "label": "Middle paper tile" },
    { "type": "image_picker", "id": "img_bot", "label": "Bottom roller image" }
  ],
  "presets": [{ "name": "Parchment Scroll", "category": "Custom" }]
}
{% endschema %} {% endcomment %}




{% comment %}
  Parchment Scroll Section — Sticky centered open/close scroll
  Updated to:
  - keep scroll centered first
  - remove large empty closed-state space
  - open according to actual text height
  - release naturally to next section after fully open
  - preserve reverse closing on upward scroll
{% endcomment %}

{%- liquid
  assign sid = section.id
  assign heading = section.settings.heading
  assign subtitle = section.settings.subtitle | strip
  if subtitle == '-'
    assign subtitle = ''
  endif
  assign body_text = section.settings.body_text
  assign quote_text = section.settings.quote_text | strip
  if quote_text == '-'
    assign quote_text = ''
  endif
  assign footer_text = section.settings.footer_text | strip
  if footer_text == '-'
    assign footer_text = ''
  endif
  assign bg_color = section.settings.bg_color
  assign max_scroll_width = section.settings.max_scroll_width
  assign show_title_divider = section.settings.show_title_divider

  if section.settings.img_top != blank
    assign img_top = section.settings.img_top | image_url: width: 1400
  else
    assign img_top = 'scroll-top.png' | asset_url
  endif

  if section.settings.img_mid != blank
    assign img_mid = section.settings.img_mid | image_url: width: 1400
  else
    assign img_mid = 'scroll-mid.png' | asset_url
  endif

  if section.settings.img_bot != blank
    assign img_bot = section.settings.img_bot | image_url: width: 1400
  else
    assign img_bot = 'scroll-bot.png' | asset_url
  endif
-%}

{{ 'https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:wght@400;500;600;700&display=swap' | stylesheet_tag }}

<style>
  #scroll-{{ sid }} {
    --ps-bg: {{ bg_color }};
    --ps-text: {{ section.settings.text_color }};
    --ps-head: {{ section.settings.heading_color }};
    --ps-accent: {{ section.settings.accent_color }};
    --ps-maxw: {{ max_scroll_width }}px;

    --ps-closed-h-d: 44px;
    --ps-closed-h-m: 34px;

    --ps-side-pad-d: 17%;
    --ps-side-pad-m: 18%;

    {% comment %} --ps-scroll-extra-d: 260px;
    --ps-scroll-extra-m: 220px; {% endcomment %}

    --ps-scroll-extra-d: 320px;
--ps-scroll-extra-m: 260px;

--ps-bottom-reveal-d: 90px;
--ps-bottom-reveal-m: 70px;

    --ps-title-d: 62px;
    --ps-title-m: 36px;

    --ps-sub-d: 11px;
    --ps-sub-m: 10px;

    --ps-body-d: 18px;
    --ps-body-m: 15px;

    --ps-body-line-d: 1.55;
    --ps-body-line-m: 1.55;

    --ps-progress: 0;
    --ps-open-h: 0px;
    --ps-shell-h: 160svh;

    position: relative;
    width: 100%;
    background: var(--ps-bg);
    overflow: visible;
    -webkit-user-select: none;
    user-select: none;
    font-family: 'Cormorant Garamond', 'Georgia', serif;
  }

  #scroll-{{ sid }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 42%, rgba(30,22,10,0.14) 0%, transparent 62%);
    pointer-events: none;
    z-index: 0;
  }

  #scroll-{{ sid }} .ps-shell {
    position: relative;
    min-height: var(--ps-shell-h);
  }

  #scroll-{{ sid }} .ps-sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    display: grid;
    place-items: center;
    overflow: clip;
  }

  #scroll-{{ sid }} .ps-scene {
    position: relative;
    width: min(77%, var(--ps-maxw));
    perspective: 1100px;
    perspective-origin: 50% 50%;
    z-index: 2;
  }

  #scroll-{{ sid }} .ps-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    transform-style: preserve-3d;
  }

  #scroll-{{ sid }} .ps-roller {
    width: 100%;
    position: relative;
    z-index: 10;
    transform-style: preserve-3d;
    will-change: transform, filter;
    transition: filter 0.18s linear;
  }

  #scroll-{{ sid }} .ps-roller img {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
    -webkit-user-drag: none;
  }

  #scroll-{{ sid }} .ps-top-r {
    margin-bottom: -8px;
    transform-origin: center center;
    transform: translateZ(0) rotateX(calc(var(--ps-progress) * -12deg));
  }

  #scroll-{{ sid }} .ps-bot-r {
    margin-top: -8px;
    transform-origin: center center;
    transform: translateZ(0) rotateX(calc(var(--ps-progress) * 12deg));
  }

  #scroll-{{ sid }} .ps-paper {
    width: 100%;
    height: var(--ps-open-h);
    min-height: 0;
    overflow: hidden;
    position: relative;
    z-index: 1;
    will-change: height;
  }

  #scroll-{{ sid }} .ps-paper-inner {
    width: 100%;
    min-height: 100%;
    background-image: url('{{ img_mid }}');
    background-size: 100% auto;
    background-repeat: repeat-y;
    background-position: top center;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  #scroll-{{ sid }} .ps-txt {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 100%;
    padding:
      clamp(22px, 3vw, 30px)
      var(--ps-side-pad-d)
      clamp(24px, 3vw, 34px);
    text-align: center;
    color: var(--ps-text);
    opacity: clamp(0, calc((var(--ps-progress) - 0.08) * 2.2), 1);
    will-change: opacity;
    box-sizing: border-box;
  }

  #scroll-{{ sid }} .ps-title {
    margin: 0;
    font-family: "Bethany Elingston", var(--font-heading-family), Georgia, serif;
    font-weight: 400;
    font-style: normal;
    {% comment %} line-height: 1; {% endcomment %}
    {% comment %} letter-spacing: 0; {% endcomment %}
    text-align: center;
    text-wrap: balance;
    font-size: 65px;
    background: linear-gradient(270.6deg, #A87E0A 9.74%, #000000 71.76%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  #scroll-{{ sid }} .ps-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 18px auto 26px;
    width: 100%;
  }

  #scroll-{{ sid }} .ps-ornament__svg {
    display: block;
    width: min(379px, 82%);
    height: auto;
    max-width: 100%;
  }

  #scroll-{{ sid }} .ps-sub {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ps-head);
    opacity: 0.72;
    margin: 0 0 14px;
    line-height: 1.35;
    font-size: var(--ps-sub-d);
  }

  #scroll-{{ sid }} .ps-body {
    font-family: "Satoshi", var(--font-body-family, system-ui), -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 400;
    line-height: var(--ps-body-line-d);
    margin: 0;
    text-align: center;
    color: var(--ps-text);
    {% comment %} font-size: var(--ps-body-d); {% endcomment %}
     font-size: 26px;
  }

  @media screen and (max-width: 1024px){
    #scroll-{{ sid }} .ps-body {
      font-size: 24px;
    }
  }

  @media screen and (max-width: 768px){
    #scroll-{{ sid }} .ps-body {
      font-size: 22px;
    }
  }

  @media screen and (max-width: 600px){
    #scroll-{{ sid }} .ps-body {
      font-size: 20px !important;
    }
  }

  #scroll-{{ sid }} .ps-body p {
    margin: 0 0 0.7em;
    font-family: "Satoshi", var(--font-body-family, system-ui), sans-serif;
    font-weight: 400;
    font-size: inherit;
    line-height: inherit;
    color: inherit;
  }

  #scroll-{{ sid }} .ps-body p:last-child {
    margin-bottom: 0;
  }

  #scroll-{{ sid }} .ps-quote {
    font-style: italic;
    opacity: 0.74;
    margin: 0.8em 0 0;
    line-height: 1.5;
    font-family: "Satoshi", var(--font-body-family, system-ui), sans-serif;
    font-size: calc(var(--ps-body-d) * 0.94);
  }

  #scroll-{{ sid }} .ps-sep {
    border: none;
    border-top: 1px solid rgba(90,50,20,0.2);
    margin: 16px auto 10px;
    width: 42%;
  }

  #scroll-{{ sid }} .ps-stamp {
    font-family: 'Cinzel', serif;
    letter-spacing: 4px;
    text-transform: uppercase;
    opacity: 0.8;
    padding-top: 0.15em;
    font-size: 12px;
  }

  #scroll-{{ sid }} .ps-hint {
    position: absolute;
    bottom: 22px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--ps-accent);
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.55rem;
    font-family: 'Cinzel', serif;
    font-weight: 700;
    z-index: 20;
    background: rgba(10,8,4,0.82);
    padding: 8px 22px;
    border-radius: 22px;
    border: 1px solid rgba(212,175,55,0.12);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    pointer-events: none;
    transition: opacity 0.35s ease;
    white-space: nowrap;
    opacity: calc(1 - min(var(--ps-progress) * 5, 1));
  }

  #scroll-{{ sid }} .ps-pbar {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 90px;
    background: rgba(212,175,55,0.08);
    border-radius: 3px;
    z-index: 20;
    overflow: hidden;
    opacity: clamp(0, calc((var(--ps-progress) - 0.02) * 4), 0.8);
    transition: opacity 0.25s ease;
  }

  #scroll-{{ sid }} .ps-pbar-fill {
    width: 100%;
    height: calc(var(--ps-progress) * 100%);
    background: var(--ps-accent);
    opacity: 0.52;
    border-radius: 3px;
  }

  @media (max-width: 989px) {
    #scroll-{{ sid }} {
      --ps-title-d: var(--ps-title-m);
      --ps-sub-d: var(--ps-sub-m);
      --ps-body-d: var(--ps-body-m);
      --ps-body-line-d: var(--ps-body-line-m);
      --ps-side-pad-d: var(--ps-side-pad-m);
      --ps-scroll-extra-d: var(--ps-scroll-extra-m);
    }

    #scroll-{{ sid }} .ps-scene {
      width: min(92%, var(--ps-maxw));
    }

    #scroll-{{ sid }} .ps-txt {
      padding-top: 18px;
      padding-bottom: 20px;
    }
  }

  @media (max-width: 749px) {
    #scroll-{{ sid }} .ps-scene {
      width: 100%;
      max-width: none;
      padding-left: env(safe-area-inset-left, 0px);
      padding-right: env(safe-area-inset-right, 0px);
      box-sizing: border-box;
    }

    #scroll-{{ sid }} .ps-wrap {
      width: 100%;
      max-width: 100%;
    }

    #scroll-{{ sid }} .ps-paper,
    #scroll-{{ sid }} .ps-paper-inner {
      overflow-x: hidden;
      box-sizing: border-box;
    }

    #scroll-{{ sid }} .ps-txt {
      width: 100%;
      min-width: 0;
      max-width: 100%;
      box-sizing: border-box;
      padding-top: 14px;
      padding-bottom: 16px;
      padding-left: max(18%, 18px, env(safe-area-inset-left, 0px));
      padding-right: max(18%, 18px, env(safe-area-inset-right, 0px));
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    #scroll-{{ sid }} .ps-title,
    #scroll-{{ sid }} .ps-body,
    #scroll-{{ sid }} .ps-body *,
    #scroll-{{ sid }} .ps-sub,
    #scroll-{{ sid }} .ps-quote,
    #scroll-{{ sid }} .ps-stamp {
      max-width: 100%;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    #scroll-{{ sid }} .ps-title {
      font-size: 36px;
      {% comment %} line-height: 1; {% endcomment %}
      letter-spacing: 0;
      text-align: center;
    }

    #scroll-{{ sid }} .ps-ornament {
      margin: 14px auto 18px;
    }

    #scroll-{{ sid }} .ps-ornament__svg {
      width: min(260px, 68%);
    }

    #scroll-{{ sid }} .ps-body {
      font-size: var(--ps-body-m);
      line-height: var(--ps-body-line-m);
    }

    #scroll-{{ sid }} .ps-sub {
      font-size: var(--ps-sub-m);
    }
  }

  @media (max-width: 480px) {
    #scroll-{{ sid }} .ps-txt {
      padding-left: max(19%, 16px, env(safe-area-inset-left, 0px));
      padding-right: max(19%, 16px, env(safe-area-inset-right, 0px));
    }
  }

  @media (max-width: 389px) {
    #scroll-{{ sid }} .ps-txt {
      padding-left: max(20%, 14px, env(safe-area-inset-left, 0px));
      padding-right: max(20%, 14px, env(safe-area-inset-right, 0px));
    }
  }
</style>

<div id="scroll-{{ sid }}" class="main-section-wrapper--">
  <div class="ps-shell" data-ps-shell>
    <div class="ps-sticky">
      <div class="ps-hint" data-ps-hint>Scroll</div>
      <div class="ps-pbar" data-ps-pbar><div class="ps-pbar-fill"></div></div>

      <div class="ps-scene" data-ps-scene>
        <div class="ps-wrap" data-ps-wrap>
          <div class="ps-roller ps-top-r" data-ps-top>
            <img src="{{ img_top }}" alt="" draggable="false" loading="lazy">
          </div>

          <div class="ps-paper" data-ps-paper>
            <div class="ps-paper-inner" data-ps-pin>
              <div class="ps-txt" data-ps-txt>
                {% if heading != blank %}
                  <h2 class="ps-title">{{ heading }}</h2>
                {% endif %}

                {% if show_title_divider and heading != blank %}
