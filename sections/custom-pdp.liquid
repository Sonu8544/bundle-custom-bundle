      if (countdownEl) countdownEl.textContent = queueFormatRemaining(diff);

      if (diff <= 0) {
        clearInterval(countdownInterval);
        if (timerWrap) timerWrap.hidden = true;
        queueLockBuy();
        queueSetMessage('Your access window expired. Refresh to check availability again.');
      }
    }

    tick();
    countdownInterval = setInterval(tick, 1000);
  }

