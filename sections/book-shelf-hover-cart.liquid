{% liquid
  assign sid = 'book-shelf-' | append: section.id
%}

<section id="{{ sid }}" class="bshelf">
  <div class="bshelf__outer page-width">
    <div class="bshelf__inner">
      <div
        class="bshelf__grid"
        data-books-grid
        data-initial-desktop="{{ section.settings.initial_books_desktop }}"
        data-initial-mobile="{{ section.settings.initial_books_mobile }}"
        data-load-desktop="{{ section.settings.load_more_desktop }}"
        data-load-mobile="{{ section.settings.load_more_mobile }}"
        data-shelf-image="{% if section.settings.shelf_image != blank %}{{ section.settings.shelf_image | image_url: width: 2400 }}{% endif %}"
      >
        {% for block in section.blocks %}
          {% liquid
            assign product = block.settings.product
            assign current_variant = blank
            if product != blank
              assign current_variant = product.selected_or_first_available_variant
            endif
          %}

          <div
            class="bshelf__item{% if forloop.index > section.settings.initial_books_desktop %} is-hidden-desktop{% endif %}{% if forloop.index > section.settings.initial_books_mobile %} is-hidden-mobile{% endif %}"
            data-book-item
            data-index="{{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            <div
              class="bshelf__book bshelf__book--{{ forloop.index }}"
              style="
                --book-width-desktop: {{ block.settings.book_width_desktop }}px;
                --book-width-tablet: {{ block.settings.book_width_tablet }}px;
                --book-width-mobile: {{ block.settings.book_width_mobile }}px;
                --book-offset-y: {{ block.settings.book_offset_y }}px;
                --book-offset-y-tablet: {{ block.settings.book_offset_y_tablet }}px;
                --book-offset-y-mobile: {{ block.settings.book_offset_y_mobile }}px;
                --book-rotate: {{ block.settings.book_rotate }}deg;
                --book-hover-lift: {{ block.settings.hover_lift }}px;
                --shadow-width: {{ block.settings.shadow_width }}%;
                --shadow-height: {{ block.settings.shadow_height }}px;
                --shadow-blur: {{ block.settings.shadow_blur }}px;
                --shadow-opacity: {{ block.settings.shadow_opacity | divided_by: 100.0 }};
                --shadow-offset-y: {{ block.settings.shadow_offset_y }}px;
                --book-z: {{ block.settings.book_z_index }};
              "
            >
              <div class="bshelf__book-wrap">
                <div class="bshelf__shadow"></div>

                <div class="bshelf__media">

                  {% if product != blank %}
                    <a href="{{ product.url }}" class="bshelf__link" aria-label="{{ product.title }}">
                  {% endif %}

                  {% if block.settings.book_image != blank %}
                    {{
                      block.settings.book_image
                      | image_url: width: 1200
                      | image_tag:
                        class: 'bshelf__img',
                        loading: 'lazy',
                        widths: '240,360,480,720,960,1200'
                    }}
                  {% elsif product != blank and product.featured_image != blank %}
                    {{
                      product.featured_image
                      | image_url: width: 1200
                      | image_tag:
                        class: 'bshelf__img',
                        loading: 'lazy',
                        widths: '240,360,480,720,960,1200'
                    }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'bshelf__placeholder' }}
                  {% endif %}

                  {% if product != blank %}
                    </a>
                  {% endif %}

                  {% if product != blank and current_variant != blank %}
                    <div class="bshelf__cta">
                      <button
                        type="button"
                        class="bshelf__btn"
                        data-book-add
                        data-variant-id="{{ current_variant.id }}"
                        {% unless current_variant.available %}disabled{% endunless %}
                      >
                        {% if current_variant.available %}
                          {{ block.settings.button_text }}
                        {% else %}
                          SOLD OUT
                        {% endif %}
                      </button>
                    </div>
                  {% endif %}
                </div>

                {% if section.settings.show_product_title and product != blank %}
                  <div class="bshelf__meta">
                    <a href="{{ product.url }}" class="bshelf__title-link">
                      <div class="bshelf__title">{{ product.title }}</div>
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="bshelf__loadmore-wrap">
          <button type="button" class="bshelf__loadmore" data-load-more>
            {{ section.settings.load_more_label }}
          </button>
        </div>
      {% endif %}
    </div>
  </div>

  <style>
    #{{ sid }} {
      --bg-color: {{ section.settings.bg_color }};
      --glow-color: {{ section.settings.glow_color }};
      --content-max-width: {{ section.settings.content_max_width }}px;
      --section-pad-top-desktop: {{ section.settings.padding_top_desktop }}px;
      --section-pad-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
      --section-pad-top-mobile: {{ section.settings.padding_top_mobile }}px;
      --section-pad-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
      --books-gap-desktop: {{ section.settings.books_gap_desktop }}px;
      --books-gap-tablet: {{ section.settings.books_gap_tablet }}px;
      --books-gap-mobile: {{ section.settings.books_gap_mobile }}px;
      --row-gap-desktop: {{ section.settings.row_gap_desktop }}px;
      --row-gap-mobile: {{ section.settings.row_gap_mobile }}px;
      --books-bottom-desktop: {{ section.settings.books_bottom_desktop }}px;
      --books-bottom-tablet: {{ section.settings.books_bottom_tablet }}px;
      --books-bottom-mobile: {{ section.settings.books_bottom_mobile }}px;
      --btn-bg-1: {{ section.settings.button_bg_1 }};
      --btn-bg-2: {{ section.settings.button_bg_2 }};
      --btn-text: {{ section.settings.button_text_color }};
      --btn-radius: {{ section.settings.button_radius }}px;
      --btn-font-size: {{ section.settings.button_font_size }}px;
      --btn-py: {{ section.settings.button_padding_y }}px;
      --btn-px: {{ section.settings.button_padding_x }}px;
      --title-color: {{ section.settings.title_color }};
      --loadmore-bg: {{ section.settings.load_more_bg }};
      --loadmore-text: {{ section.settings.load_more_text }};
      --loadmore-border: {{ section.settings.load_more_border }};
    }

    #{{ sid }}.bshelf {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at 50% 35%, var(--glow-color) 0%, rgba(0, 0, 0, 0) 38%),
        var(--bg-color);
      padding-top: var(--section-pad-top-desktop);
      padding-bottom: var(--section-pad-bottom-desktop);
    }

    #{{ sid }} .bshelf__outer {
      max-width: var(--content-max-width);
      margin: 0 auto;
    }

    #{{ sid }} .bshelf__inner {
      position: relative;
    }

    #{{ sid }} .bshelf__grid {
      display: flex;
      flex-direction: column;
      gap: var(--row-gap-desktop);
    }

    #{{ sid }} .bshelf__shelf-row {
      position: relative;
      width: 100%;
    }

    #{{ sid }} .bshelf__books-row {
      position: relative;
      z-index: 5;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      column-gap: var(--books-gap-desktop);
      align-items: end;
      margin-bottom: calc(var(--books-bottom-desktop) * -1);
      min-height: 120px;
    }

    #{{ sid }} .bshelf__shelf-row-image {
      position: relative;
      z-index: 2;
      line-height: 0;
      width: 100%;
    }

    #{{ sid }} .bshelf__shelf-row-image img {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
      user-select: none;
      pointer-events: none;
    }

    #{{ sid }} .bshelf__item {
      min-width: 0;
      display: flex;
      justify-content: center;
    }

    #{{ sid }} .bshelf__item.is-hidden-desktop,
    #{{ sid }} .bshelf__item.is-hidden-mobile {
      display: none;
    }

    #{{ sid }} .bshelf__book {
      position: relative;
      width: var(--book-width-desktop);
      max-width: 100%;
      flex: 0 0 auto;
      transform: translateY(var(--book-offset-y)) rotate(var(--book-rotate));
      transition: transform 0.35s ease, z-index 0.2s ease;
      z-index: var(--book-z);
    }

    #{{ sid }} .bshelf__book:hover,
    #{{ sid }} .bshelf__book:focus-within {
      transform: translateY(calc(var(--book-offset-y) - var(--book-hover-lift))) rotate(var(--book-rotate));
      z-index: 30;
    }

    #{{ sid }} .bshelf__book-wrap {
      position: relative;
      overflow: visible;
    }

    #{{ sid }} .bshelf__shadow {
      position: absolute;
      left: 50%;
      bottom: calc(var(--shadow-offset-y) * -1);
      width: var(--shadow-width);
      height: var(--shadow-height);
      transform: translateX(-50%);
      border-radius: 999px;
      background: rgba(0, 0, 0, var(--shadow-opacity));
      filter: blur(var(--shadow-blur));
      z-index: 1;
      pointer-events: none;
      transition: all 0.35s ease;
    }

    #{{ sid }} .bshelf__book:hover .bshelf__shadow,
    #{{ sid }} .bshelf__book:focus-within .bshelf__shadow {
      transform: translateX(-50%) scale(1.08);
    }

    #{{ sid }} .bshelf__media {
      position: relative;
      z-index: 3;
      overflow: visible;
    }

    /* ── Product image link ── */
    #{{ sid }} .bshelf__link {
      display: block;
      position: relative;
      z-index: 2;
      line-height: 0;
    }



    #{{ sid }} .bshelf__img,
    #{{ sid }} .bshelf__placeholder {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
      filter: drop-shadow(0 12px 22px rgba(0, 0, 0, 0.26));
    }

    #{{ sid }} .bshelf__cta {
      position: absolute;
      left: 50%;
      bottom: 10%;
      transform: translateX(-50%) translateY(12px);
      width: calc(100% - 16px);
      max-width: 220px;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      z-index: 50;
      transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
    }

    #{{ sid }} .bshelf__book:hover .bshelf__cta,
    #{{ sid }} .bshelf__book:focus-within .bshelf__cta {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }

    #{{ sid }} .bshelf__btn {
      width: 100%;
      border: 0;
      height: 50px;
      appearance: none;
      cursor: pointer;
      border-radius: var(--btn-radius);
      padding: var(--btn-py) var(--btn-px);
      background-repeat: no-repeat;
      background-size: cover;
      background-position: center;
      background-image: url('https://cdn.shopify.com/s/files/1/0589/1719/1777/files/f89b1c50a8a368abe48fc6793fd85a8999a3c0ca.png?v=1775475634');
      color: var(--btn-text);
      font-size: var(--btn-font-size);
      line-height: 1;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-family: inherit;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.24);
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    #{{ sid }} .bshelf__btn:hover {
      transform: translateY(-1px);
    }

    #{{ sid }} .bshelf__btn[disabled] {
      opacity: 0.6;
      cursor: not-allowed;
    }

    #{{ sid }} .bshelf__meta {
      margin-top: 10px;
      text-align: center;
    }

    /* ── Product title link ── */
    #{{ sid }} .bshelf__title-link {
      display: block;
      text-decoration: none;
    }

    #{{ sid }} .bshelf__title-link:hover .bshelf__title {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    #{{ sid }} .bshelf__title {
      color: var(--title-color);
      font-size: 14px;
      line-height: 1.35;
    }

    #{{ sid }} .bshelf__loadmore-wrap {
      margin-top: 40px;
      text-align: center;
    }

    #{{ sid }} .bshelf__loadmore {
      appearance: none;
      border: 1px solid var(--loadmore-border);
      background: var(--loadmore-bg);
      color: var(--loadmore-text);
      border-radius: 999px;
      padding: 14px 28px;
      cursor: pointer;
      line-height: 1;
      font-family: inherit;
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    #{{ sid }} .bshelf__loadmore:hover {
      transform: translateY(-1px);
    }

    #{{ sid }} .bshelf__loadmore.is-hidden {
      display: none;
    }

    @media screen and (max-width: 989px) {
      #{{ sid }}.bshelf {
        padding-top: var(--section-pad-top-mobile);
        padding-bottom: var(--section-pad-bottom-mobile);
      }

      #{{ sid }} .bshelf__books-row {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        column-gap: var(--books-gap-tablet);
        margin-bottom: calc(var(--books-bottom-tablet) * -1);
      }

      #{{ sid }} .bshelf__book {
        width: var(--book-width-tablet);
        transform: translateY(var(--book-offset-y-tablet)) rotate(var(--book-rotate));
      }

      #{{ sid }} .bshelf__book:hover,
      #{{ sid }} .bshelf__book:focus-within {
        transform: translateY(calc(var(--book-offset-y-tablet) - var(--book-hover-lift))) rotate(var(--book-rotate));
      }

      #{{ sid }} .bshelf__cta {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateX(-50%) translateY(0);
        bottom: 8%;
        width: calc(100% - 12px);
      }
    }

    @media screen and (max-width: 749px) {
      #{{ sid }} .bshelf__grid {
        gap: var(--row-gap-mobile);
      }

      #{{ sid }} .bshelf__books-row {
        grid-template-columns: repeat(1, minmax(0, 1fr));
        column-gap: 0;
        margin-bottom: calc(var(--books-bottom-mobile) * -1);
      }

      #{{ sid }} .bshelf__item.is-hidden-mobile {
        display: none;
      }

      #{{ sid }} .bshelf__item.is-hidden-desktop {
        display: flex;
      }

      #{{ sid }} .bshelf__book {
        width: var(--book-width-mobile);
        transform: translateY(var(--book-offset-y-mobile)) rotate(var(--book-rotate));
      }

      #{{ sid }} .bshelf__book:hover,
      #{{ sid }} .bshelf__book:focus-within {
        transform: translateY(calc(var(--book-offset-y-mobile) - var(--book-hover-lift))) rotate(var(--book-rotate));
      }

      #{{ sid }} .bshelf__cta {
        bottom: 6%;
        width: calc(100% - 8px);
      }

      #{{ sid }} .bshelf__btn {
        font-size: 10px;
        padding: 9px 8px;
      }

      #{{ sid }} .bshelf__title {
        font-size: 12px;
      }
    }
  </style>



<script>
(function() {
  const section = document.getElementById('{{ sid }}');
  if (!section) return;

  const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root)
    ? window.Shopify.routes.root : '/';

  const grid = section.querySelector('[data-books-grid]');
  const loadMoreBtn = section.querySelector('[data-load-more]');
  const items = grid ? Array.from(grid.querySelectorAll('[data-book-item]')) : [];
  const shelfImage = grid ? (grid.dataset.shelfImage || '') : '';

  function isMobile() {
    return window.innerWidth <= 749;
  }

  function perRow() {
    return isMobile() ? 1 : 3;
  }

  function getLoadCount() {
    if (!grid) return 0;
    return isMobile()
      ? parseInt(grid.dataset.loadMobile || '10', 10)
      : parseInt(grid.dataset.loadDesktop || '9', 10);
  }

  function hiddenClass() {
    return isMobile() ? 'is-hidden-mobile' : 'is-hidden-desktop';
  }

  function visibleItems() {
    const cls = hiddenClass();
    return items.filter((item) => !item.classList.contains(cls));
  }

  function setInitialVisibility() {
    if (!grid) return;
    const desktopInitial = parseInt(grid.dataset.initialDesktop || '9', 10);
    const mobileInitial  = parseInt(grid.dataset.initialMobile  || '10', 10);
    items.forEach((item, index) => {
      item.classList.toggle('is-hidden-desktop', index >= desktopInitial);
      item.classList.toggle('is-hidden-mobile',  index >= mobileInitial);
    });
  }

  function buildRows() {
    if (!grid) return;
    const currentVisible = visibleItems();
    const columns = perRow();
    grid.querySelectorAll('.bshelf__shelf-row').forEach((row) => row.remove());

    for (let i = 0; i < currentVisible.length; i += columns) {
      const chunk = currentVisible.slice(i, i + columns);
      const row = document.createElement('div');
      row.className = 'bshelf__shelf-row';

      const booksRow = document.createElement('div');
      booksRow.className = 'bshelf__books-row';
      chunk.forEach((item) => booksRow.appendChild(item));
      row.appendChild(booksRow);

      if (shelfImage) {
        const shelf = document.createElement('div');
        shelf.className = 'bshelf__shelf-row-image';
        shelf.innerHTML = '<img src="' + shelfImage + '" alt="" loading="lazy">';
        row.appendChild(shelf);
      }

      grid.appendChild(row);
    }

    if (loadMoreBtn) {
      const cls = hiddenClass();
      const stillHidden = items.some((item) => item.classList.contains(cls));
      loadMoreBtn.classList.toggle('is-hidden', !stillHidden);
    }
  }

  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function() {
      const cls = hiddenClass();
      const count = getLoadCount();
      let revealed = 0;
      items.forEach((item) => {
        if (item.classList.contains(cls) && revealed < count) {
          item.classList.remove(cls);
          revealed += 1;
        }
      });
      buildRows();
    });
  }

  let resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(buildRows, 120);
  });

  setInitialVisibility();
  buildRows();

  // ── Cart helpers ──────────────

  // Pass sections in cart/add.js so Shopify returns rendered HTML in one request
  async function addItem(variantId) {
    const response = await fetch(root + 'cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({
        items: [{ id: Number(variantId), quantity: 1 }],
        sections: ['cart-drawer', 'cart-icon-bubble'],
        sections_url: window.location.pathname
      })
    });

    const data = await response.json();
    if (!response.ok || data.status) throw new Error(data.description || 'Failed to add to cart');
    return data;
  }

  function replaceDrawerMarkup(sectionHtml) {
    const parsed = new DOMParser().parseFromString(sectionHtml, 'text/html');
    const freshMain   = parsed.getElementById('CartDrawer');
    const currentMain = document.getElementById('CartDrawer');
    if (currentMain && freshMain) currentMain.innerHTML = freshMain.innerHTML;

    const drawer = document.querySelector('cart-drawer');
    if (drawer) {
      drawer.classList.remove('is-empty');
      const inner = drawer.querySelector('.drawer__inner');
      if (inner) inner.classList.remove('is-empty');
    }
  }

  // Dawn wraps cart-icon-bubble output in <div class="shopify-section">
  // Replace bubble innerHTML with that wrapper's contents
  function replaceBubbleMarkup(sectionHtml) {
    const parsed       = new DOMParser().parseFromString(sectionHtml, 'text/html');
    const freshSection = parsed.querySelector('.shopify-section');
    const bubble       = document.getElementById('cart-icon-bubble');
    if (bubble && freshSection) bubble.innerHTML = freshSection.innerHTML;
  }

  function openDrawer() {
    const drawer = document.querySelector('cart-drawer');
    if (!drawer) return;
    drawer.classList.remove('is-empty');
    const inner = drawer.querySelector('.drawer__inner');
    if (inner) inner.classList.remove('is-empty');
    if (typeof drawer.open === 'function') {
      drawer.open();
    } else {
      drawer.classList.add('animate', 'active');
      document.body.classList.add('overflow-hidden');
    }
  }

  async function refreshCartUI(addData) {
    const sections = addData && addData.sections;

    if (sections) {
      // Best path: rendered HTML came back inside the add response
      if (sections['cart-icon-bubble']) replaceBubbleMarkup(sections['cart-icon-bubble']);
      if (sections['cart-drawer'])      replaceDrawerMarkup(sections['cart-drawer']);
    } else {
      // Fallback: fetch sections separately
      try {
        const r1 = await fetch(root + '?section_id=cart-icon-bubble', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        replaceBubbleMarkup(await r1.text());
      } catch(e) { console.warn('[Book Shelf] bubble fetch failed:', e); }

      try {
        const r2 = await fetch(root + '?section_id=cart-drawer', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        replaceDrawerMarkup(await r2.text());
      } catch(e) { console.warn('[Book Shelf] drawer fetch failed:', e); }
    }

    setTimeout(openDrawer, 60);

    // Fire Dawn's pub/sub so cart-items and other components stay in sync
    if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined' && PUB_SUB_EVENTS.cartUpdate) {
      publish(PUB_SUB_EVENTS.cartUpdate, { source: 'book-shelf' });
    }
    document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true, detail: { source: 'book-shelf' } }));
    document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true, detail: { source: 'book-shelf' } }));
    document.dispatchEvent(new CustomEvent('dispatch:cart-update', { bubbles: true }));
  }

  async function addToCart(variantId, button) {
    if (!variantId || !button || button.disabled) return;

    const originalText = button.textContent;
    button.disabled = true;
    button.textContent = 'Adding...';

    try {
      const addData = await addItem(variantId);
      await refreshCartUI(addData);
      button.textContent = 'Added';
      setTimeout(function() {
        button.textContent = originalText;
        button.disabled = false;
      }, 1200);
    } catch (error) {
      console.error('[Book Shelf] Add to cart error:', error);
      button.textContent = 'Error';
      setTimeout(function() {
        button.textContent = originalText;
        button.disabled = false;
      }, 1400);
    }
  }

  section.addEventListener('click', function(event) {
    const btn = event.target.closest('[data-book-add]');
    if (!btn) return;
    event.preventDefault();
    event.stopPropagation();
    addToCart(btn.getAttribute('data-variant-id'), btn);
  });
})();
</script>

</section>

