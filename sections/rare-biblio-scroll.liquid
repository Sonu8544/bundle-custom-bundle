                        <linearGradient id="ps-ornament-gradient-{{ sid }}" x1="28.1426" y1="18.1437" x2="151.223" y2="18.1437" gradientUnits="userSpaceOnUse">
                          <stop stop-color="#9A7A5F"/>
                          <stop offset="0.077" stop-color="#C9A885"/>
