<style>
  .header {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }

  .section-header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
    background: transparent !important;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .rb-header {
    position: relative;
    background: transparent !important;
    background-color: transparent !important;
    border-bottom: 0 !important;
    box-shadow: none !important;
    isolation: isolate;
    transition:
      background-color .35s ease,
      backdrop-filter .35s ease,
      box-shadow .35s ease,
      border-color .35s ease,
      transform .3s ease;
  }

  /* No gradient overlay — must stay fully transparent (no tint) */
  .rb-header::before {
    content: none !important;
    display: none !important;
  }

  .rb-header .header {
    position: relative;
    z-index: 2;
    min-height: 112px;
    background: transparent !important;
    background-color: transparent !important;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    column-gap: 32px;
    padding-left: 56px !important;
    padding-right: 56px !important;
  }

  .rb-header .header__heading,
  .rb-header .header__inline-menu,
  .rb-header .header__icons {
    position: relative;
    z-index: 2;
  }

  .rb-header .header__heading {
    margin: 0;
    max-width: 170px;
  }

  .rb-header .header__heading-link {
    text-decoration: none !important;
    color: #fff !important;
  }

  .rb-header .header__heading-logo-wrapper {
    width: 86px;
    max-width: 86px;
  }

  .rb-header .header__heading-logo {
    width: 100%;
    height: auto;
    display: block;
  }

  .rb-header .header__inline-menu {
    justify-self: center;
    margin-right: 20px;
  }

  .rb-header .list-menu--inline {
    display: inline-flex;
    align-items: center;
    gap: 48px;
    flex-wrap: nowrap;
  }

  .rb-header .header__menu-item,
  .rb-header .header__menu-item span,
  .rb-header .header__active-menu-item {
    color: #fff !important;
    text-decoration: none !important;
  }

  .rb-header .header__menu-item {
    padding: 0;
    font-family: "Satoshi", var(--font-body-family);
    font-weight: 400;
    font-size: 16px;
    line-height: 1;
    letter-spacing: 0;
  }

  .rb-header .header__menu-item .icon-caret {
    display: none;
  }

  .rb-header .header__icons {
    display: inline-flex;
    align-items: center;
    justify-self: end;
    gap: 20px;
  }

  .rb-header .header__icon--search {
    display: none !important;
  }

  .rb-cart-link {
    width: 55px !important;
    min-width: 50px;
    height: 55px !important;
    border-radius: 50px;
    border: 1px solid #EBECF2;
    background: transparent !important;
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    padding: 0;
    box-shadow: none;
  }

  .rb-cart-link__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 29px;
    height: 29px;
  }

  .rb-account-link {
    width: auto !important;
    min-width: 191px;
    height: 58px !important;
    padding: 6px 24px;
    gap: 17px;
    border-radius: 50px;
    border: 1px solid #FFFFFF;
    background: transparent !important;
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    text-decoration: none !important;
    box-shadow: 0 3px 14px rgba(0,0,0,.02);
  }

  .rb-account-link__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex: 0 0 20px;
  }

  .rb-account-link__text {
    color: #FFFFFF;
    font-family: "Red Hat Display", sans-serif;
    font-weight: 700;
    font-size: 14px;
    line-height: 1;
    letter-spacing: 1.2px;
    white-space: nowrap;
  }

  .rb-header .header__icon:hover,
  .rb-header .header__menu-item:hover,
  .rb-account-link:hover,
  .rb-cart-link:hover {
    opacity: .94;
  }

  .rb-header .cart-count-bubble {
    right: 2px;
    top: 2px;
    background: #C9A646;
    color: #111;
    box-shadow: none;
  }

  .section-header.scrolled-past-header .rb-header,
  .shopify-section-header-sticky .rb-header {
    background: transparent !important;
    background-color: transparent !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    box-shadow: none !important;
  }

  .section-header.scrolled-past-header .rb-header.header-wrapper--border-bottom,
  .shopify-section-header-sticky .rb-header.header-wrapper--border-bottom {
    border-bottom-color: transparent !important;
  }

  .shopify-section-header-hidden {
    transform: translateY(-100%);
  }

  @media screen and (max-width: 989px) {
    .rb-header .header {
      min-height: 84px;
      grid-template-columns: auto 1fr auto;
      column-gap: 14px;
      padding-left: 18px !important;
      padding-right: 18px !important;
    }

    .rb-header .header__heading-logo-wrapper {
      width: 64px;
      max-width: 64px;
    }

    .rb-header .header__inline-menu {
      display: none;
    }

    .rb-cart-link,
    .rb-header .header__icon--menu {
      width: 46px !important;
      min-width: 46px;
      height: 46px !important;
      border-radius: 50px;
      border: 1px solid rgba(255,255,255,.78);
      background: transparent !important;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .rb-account-link {
      display: none !important;
    }

    .rb-header .header__icons {
      gap: 12px;
    }
  }

  /* Override: keep transparent until actually scrolled */
  .shopify-section-header-sticky:not(.scrolled-past-header) .rb-header {
    background: transparent !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    box-shadow: none !important;
  }

  /* Force the section wrapper itself to be transparent */
  .section-header,
  .section-header .shopify-section-header-sticky,
  sticky-header.rb-header,
  .header-wrapper.rb-header {
    background: transparent !important;
    background-color: transparent !important;
  }

  /*
    Defeat assets/base.css:
    .header-wrapper { background-color: rgb(var(--color-background)); }
    (loads after this block and was painting a solid white bar with light color schemes.)
  */
  .header-wrapper.rb-header,
  sticky-header.header-wrapper.rb-header,
  div.header-wrapper.rb-header {
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }

  /* Nuke Dawn's color-scheme background on the header section */
  .section-header.color-background-1,
  .section-header.color-background-2,
  .section-header.color-accent-1,
  .section-header.color-accent-2,
  .section-header.color-inverse {
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    --color-background: transparent;
    --gradient-background: transparent;
  }

  /* The sticky-header custom element itself */
  sticky-header {
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    display: block;
  }

  /* Also kill any box-shadow/border that reveals the background */
  .section-header,
  sticky-header,
  .rb-header {
    box-shadow: none !important;
    border-bottom: none !important;
  }

  /* Shopify section shell: .color-* applies background-color via theme CSS */
  #shopify-section-{{ section.id }} {
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }


</style>

{%- style -%}
  .header {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }

  .section-header {
    position: sticky; /* This is for fixing a Safari z-index issue. PR #2147 */
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'details-disclosure.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'details-modal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'search-form.js' | asset_url }}" defer="defer"></script>
