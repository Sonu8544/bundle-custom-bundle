{%- liquid
  assign pdp_bg = section.settings.background_color | default: '#0D0D0B'
  assign hero_fallback = 'https://cdn.shopify.com/s/files/1/0589/1719/1777/files/arafed-image-round-table-with-light-coming-from-it_1034560-94186_2_1.png?v=1776115204'
  if section.settings.bg_image_desktop != blank
    assign hero_desktop = section.settings.bg_image_desktop | image_url: width: 1920
  else
    assign hero_desktop = hero_fallback
  endif
  if section.settings.bg_image_mobile != blank
    assign hero_mobile = section.settings.bg_image_mobile | image_url: width: 768
  else
    assign hero_mobile = hero_desktop
  endif
-%}
<section
  id="exclusive-book-product-{{ section.id }}"
  class="exclusive-book-product exclusive-book-product--bg-{{ section.settings.background_type }}"
  style="
    --section-bg: {{ section.settings.background_color }};
    --gradient-start: {{ section.settings.gradient_start }};
    --gradient-mid: {{ section.settings.gradient_mid }};
    --gradient-end: {{ section.settings.gradient_end }};
    --gradient-angle: {{ section.settings.gradient_angle }}deg;
    --hero-bg-image: url('{{ hero_desktop }}');
    --hero-bg-image-mobile: url('{{ hero_mobile }}');
    --accent-gold: #C9A885;
    --accent-gold-deep: #8E7025;
    --text-primary: #FFFFFF;
    --text-muted: #A89880;
  "
>
  {%- comment -%} Full-bleed hero: background image only {%- endcomment -%}
  <div class="section-bg-hero" style="background-color: {{ pdp_bg }};" aria-hidden="true"></div>

  <div class="exclusive-book-product__inner">

    {%- comment %} LEFT — Product Gallery {%- endcomment %}
    <div class="product-gallery" id="productGallery-{{ section.id }}">
      <div class="product-gallery__main">

        {%- comment %} Zoom button {%- endcomment %}
        <button class="gallery-zoom-btn" aria-label="Zoom image">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35M11 8v6M8 11h6"/>
          </svg>
        </button>

        {%- comment %} Prev / Next arrows {%- endcomment %}
        <button class="gallery-nav gallery-nav--prev" aria-label="Previous image">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <button class="gallery-nav gallery-nav--next" aria-label="Next image">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>

        {%- if product != blank -%}
          {%- for image in product.images limit: 8 -%}
            <div
              class="gallery-slide {% if forloop.first %}gallery-slide--active{% endif %}"
              data-index="{{ forloop.index0 }}"
            >
              <img
                src="{{ image | image_url: width: 700 }}"
                alt="{{ image.alt | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="700"
                height="900"
              >
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- assign image_keys = 'product_image_1,product_image_2,product_image_3,product_image_4,product_image_5,product_image_6,product_image_7,product_image_8' | split: ',' -%}
          {%- for image_key in image_keys -%}
            {%- assign slide_image = section.settings[image_key] -%}
            {%- if slide_image != blank -%}
              <div class="gallery-slide {% if forloop.first %}gallery-slide--active{% endif %}" data-index="{{ forloop.index0 }}">
                <img
                  src="{{ slide_image | image_url: width: 700 }}"
                  alt="{{ section.settings.product_title | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="700"
                  height="900"
                >
              </div>
            {%- elsif forloop.first -%}
              <div class="gallery-slide gallery-slide--active" data-index="0">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        {%- comment %} Dot indicators (visible on mobile, optional on desktop) {%- endcomment %}
        <div class="gallery-dots" aria-hidden="true">
          {%- if product != blank -%}
            {%- for image in product.images limit: 8 -%}
              <span class="gallery-dot {% if forloop.first %}gallery-dot--active{% endif %}" data-dot="{{ forloop.index0 }}"></span>
            {%- endfor -%}
          {%- else -%}
            {%- assign dot_keys = 'product_image_1,product_image_2,product_image_3,product_image_4,product_image_5,product_image_6,product_image_7,product_image_8' | split: ',' -%}
            {%- assign dot_count = 0 -%}
            {%- for dot_key in dot_keys -%}
              {%- assign dot_img = section.settings[dot_key] -%}
              {%- if dot_img != blank -%}
                <span class="gallery-dot {% if forloop.first %}gallery-dot--active{% endif %}" data-dot="{{ dot_count }}"></span>
                {%- assign dot_count = dot_count | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if dot_count == 0 -%}
              <span class="gallery-dot gallery-dot--active" data-dot="0"></span>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>

      {%- comment %} Thumbnails — desktop only {%- endcomment %}
      <div class="product-gallery__thumbs" role="list">
        {%- if product != blank -%}
          {%- for image in product.images limit: 8 -%}
            <button
              class="thumb {% if forloop.first %}thumb--active{% endif %}"
              data-target="{{ forloop.index0 }}"
              aria-label="View image {{ forloop.index }}"
              role="listitem"
            >
              <img
                src="{{ image | image_url: width: 120 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="120"
                height="150"
              >
            </button>
          {%- endfor -%}
        {%- else -%}
          {%- assign thumb_keys = 'product_image_1,product_image_2,product_image_3,product_image_4,product_image_5,product_image_6,product_image_7,product_image_8' | split: ',' -%}
          {%- for thumb_key in thumb_keys -%}
            {%- assign thumb_image = section.settings[thumb_key] -%}
            {%- if thumb_image != blank -%}
              <button
                class="thumb {% if forloop.first %}thumb--active{% endif %}"
                data-target="{{ forloop.index0 }}"
                aria-label="View image {{ forloop.index }}"
                role="listitem"
              >
                <img
                  src="{{ thumb_image | image_url: width: 120 }}"
                  alt=""
                  loading="lazy"
                  width="120"
                  height="150"
                >
              </button>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment %} RIGHT — Product Info {%- endcomment %}
    <div class="product-info">

      <div class="exclusive-badge">
        <span class="exclusive-badge__text">{{ section.settings.badge_text | default: 'EXCLUSIVE' }}</span>
      </div>

      <div class="product-title-row">
        <h1 class="product-title">
          {%- if product != blank -%}
            {{ product.title }}
          {%- else -%}
            {{ section.settings.product_title | default: 'Voyage au centre de la terre' }}
          {%- endif -%}
        </h1>
      </div>

      {%- liquid
        assign author_display = section.settings.product_author
        if author_display == blank and product != blank
          assign author_display = product.vendor
        endif
        if author_display == blank
          assign author_display = 'JK Rowling'
        endif
      -%}
      <p class="product-author">{{ author_display | upcase }}</p>

      <div class="signed-copies-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M21.7497 15.75H5.9866C6.23597 15.2587 6.48628 14.7534 6.7366 14.2397C8.14285 14.3944 9.79097 13.4166 11.6735 11.3203C12.1422 12.5822 13.0282 14.22 14.5403 14.25C15.3897 14.2669 16.2382 13.7625 17.111 12.7153C17.7475 13.4766 19.0591 14.25 21.7497 14.25C21.9486 14.25 22.1394 14.171 22.2801 14.0303C22.4207 13.8897 22.4997 13.6989 22.4997 13.5C22.4997 13.3011 22.4207 13.1103 22.2801 12.9697C22.1394 12.829 21.9486 12.75 21.7497 12.75C18.8969 12.75 18.0532 11.7703 17.9997 11.2397C18.0082 11.0787 17.9623 10.9196 17.8695 10.7879C17.7766 10.6561 17.6423 10.5593 17.4878 10.5131C17.3274 10.4649 17.1556 10.4709 16.9989 10.53C16.8422 10.5891 16.7093 10.6982 16.6207 10.8403C15.4891 12.5784 14.8038 12.7556 14.5657 12.75C13.7913 12.735 13.0038 10.92 12.7338 9.61688C12.705 9.47731 12.637 9.34883 12.5378 9.2465C12.4386 9.14417 12.3123 9.07222 12.1737 9.03907C12.0351 9.00592 11.8899 9.01294 11.7552 9.05932C11.6204 9.1057 11.5017 9.18951 11.4128 9.30094C9.5191 11.6766 8.24972 12.4762 7.45941 12.6834C8.25535 10.9144 8.84972 9.36094 9.23035 8.05313C9.86972 5.85563 9.9166 4.31906 9.37191 3.35625C9.09066 2.85187 8.49628 2.25 7.30378 2.25C5.79816 2.25 4.61035 3.67313 4.0441 6.15469C3.70753 7.6275 3.65222 9.26813 3.89222 10.6547C4.13222 12.0413 4.63003 13.05 5.35378 13.6491C5.0041 14.3728 4.64785 15.0797 4.30097 15.75H2.24972C2.05081 15.75 1.86004 15.829 1.71939 15.9697C1.57874 16.1103 1.49972 16.3011 1.49972 16.5C1.49972 16.6989 1.57874 16.8897 1.71939 17.0303C1.86004 17.171 2.05081 17.25 2.24972 17.25H3.50691C2.44566 19.2188 1.62066 20.5913 1.60753 20.6138C1.55406 20.6982 1.51802 20.7925 1.50151 20.8911C1.485 20.9897 1.48837 21.0906 1.51141 21.1878C1.53445 21.2851 1.5767 21.3768 1.63568 21.4575C1.69466 21.5382 1.76918 21.6063 1.85486 21.6578C1.94053 21.7093 2.03564 21.7431 2.13458 21.7573C2.23352 21.7715 2.33431 21.7658 2.43101 21.7405C2.52772 21.7152 2.61839 21.6709 2.6977 21.61C2.77701 21.5492 2.84336 21.4731 2.89285 21.3862C2.90691 21.3619 3.94941 19.6247 5.20847 17.25H21.7497C21.9486 17.25 22.1394 17.171 22.2801 17.0303C22.4207 16.8897 22.4997 16.6989 22.4997 16.5C22.4997 16.3011 22.4207 16.1103 22.2801 15.9697C22.1394 15.829 21.9486 15.75 21.7497 15.75ZM5.5066 6.48844C5.87972 4.85063 6.60253 3.75 7.30378 3.75C7.80347 3.75 7.96941 3.92437 8.06597 4.09406C8.34722 4.59375 8.67722 6.36187 6.03535 12.1931C5.26097 11.1356 4.99753 8.71875 5.5066 6.48844Z" fill="#C9A885"/>
        </svg>
        <span class="signed-copies-badge__text">{{ section.settings.signed_copies_text | default: 'Only 250 Signed Copies' }}</span>
      </div>

      <div class="product-price">
        {%- if product != blank -%}
          {%- assign selected_variant = product.selected_or_first_available_variant -%}
          {%- if product.price_varies -%}
            <span class="price-label">From</span>
          {%- endif -%}
          <span
            class="price-amount"
            data-unit-price="{{ selected_variant.price }}"
            data-currency="{{ cart.currency.symbol | default: shop.currency }}"
          >{{ selected_variant.price | money_with_currency }}</span>
          {%- if selected_variant.compare_at_price > selected_variant.price -%}
            <span class="price-compare">{{ selected_variant.compare_at_price | money_with_currency }}</span>
          {%- endif -%}
        {%- else -%}
          <span class="price-amount">{{ section.settings.product_price | default: 'USD 129.00' }}</span>
        {%- endif -%}
      </div>

      {%- if product != blank and product.variants.size > 1 -%}
        <div class="variant-selector">
          {%- for option in product.options_with_values -%}
            <div class="variant-option">
              <label class="variant-option__label">{{ option.name }}</label>
              <div class="variant-option__values">
                {%- for value in option.values -%}
                  <button
                    class="variant-value-btn"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value | escape }}"
                  >{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="product-actions">
        <div class="quantity-control">
          <button class="qty-btn qty-btn--minus" aria-label="Decrease quantity">
            <svg width="14" height="2" viewBox="0 0 14 2" fill="none"><path d="M1 1H13" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <input
            type="number"
            class="qty-input"
            id="qty-{{ section.id }}"
            name="quantity"
            value="1"
            min="1"
            max="250"
            aria-label="Quantity"
          >
          <button class="qty-btn qty-btn--plus" aria-label="Increase quantity">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1V13M1 7H13" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </div>

        {%- if product != blank -%}
          <button
            type="button"
            class="cta-btn"
            id="addToCart-{{ section.id }}"
            data-product-id="{{ product.id }}"
            data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
          >
            {%- if product.selected_or_first_available_variant.available -%}
              {{ section.settings.cta_label | default: 'PRE ORDER NOW' }}
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        {%- else -%}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="cta-btn">
            {{ section.settings.cta_label | default: 'PRE ORDER NOW' }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>

  {%- comment %} Lightbox / Zoom overlay {%- endcomment %}
  <div class="gallery-lightbox" id="lightbox-{{ section.id }}" aria-hidden="true">
    <button class="lightbox-close" aria-label="Close zoom">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    <button class="lightbox-nav lightbox-nav--prev" aria-label="Previous image">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="lightbox-nav lightbox-nav--next" aria-label="Next image">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div class="lightbox-img-wrap">
      <img src="" alt="" class="lightbox-img" id="lightboxImg-{{ section.id }}">
    </div>
    <div class="lightbox-counter" id="lightboxCounter-{{ section.id }}"></div>
  </div>
</section>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Satoshi:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="preload" href="https://cdn.shopify.com/s/files/1/0589/1719/1777/files/Bethany_Elingston.otf" as="font" type="font/otf" crossorigin>

<style>
/* =============================================
   EXCLUSIVE BOOK PRODUCT — SECTION STYLES
   ============================================= */

@font-face {
  font-family: 'Bethany Elingston';
  src: url('https://cdn.shopify.com/s/files/1/0589/1719/1777/files/Bethany_Elingston.otf') format('opentype');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

:root {
  --font-display: 'Bethany Elingston', 'Cormorant Garamond', 'Playfair Display', Georgia, serif;
  --font-body: 'Satoshi', 'DM Sans', system-ui, sans-serif;
}

#shopify-section-{{ section.id }}.shopify-section.exclusive-book-product-section {
  background-color: transparent;
  width: 100%;
}

#exclusive-book-product-{{ section.id }} {
  position: relative;
  width: 100%;
  background-color: transparent;
  min-height: 100vh;
  min-height: -webkit-fill-available;
  min-height: 100dvh;
  overflow: hidden;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  isolation: isolate;
}

/*
  Hero: image + atmospheric overlays (matches reference — spotlights up top, readable type, soft fade to next section).
  Layer order (top → bottom): bottom vignette, uniform dim, photo.
*/
#exclusive-book-product-{{ section.id }} .section-bg-hero {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  min-height: 100%;
  pointer-events: none;
  z-index: 0;
  box-sizing: border-box;
  background-color: var(--section-bg, #0d0d0b);
  background-image:
    linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.38) 62%, rgba(0, 0, 0, 0.72) 100%),
    linear-gradient(rgba(0, 0, 0, 0.22), rgba(0, 0, 0, 0.22)),
    url({{ hero_desktop | json }});
  background-position: 0 0, 0 0, center top;
  background-size: 100% 100%, 100% 100%, cover;
  -webkit-background-size: 100% 100%, 100% 100%, cover;
  background-repeat: no-repeat;
  background-attachment: scroll;
  background-clip: border-box;
  background-origin: border-box;
  background-blend-mode: normal, normal, normal;
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}

/* Inner layout — columns top-aligned so .product-info lines up with top of gallery */
#exclusive-book-product-{{ section.id }} .exclusive-book-product__inner {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: clamp(88px, 11vh, 132px) 40px clamp(100px, 14vh, 160px);
  align-items: start;
  box-sizing: border-box;
}

/* ── Gallery ────────────────── */
.product-gallery {
  display: flex;
  flex-direction: column;
  gap: 20px;
  width: 100%;
  min-width: 0;
}

.product-gallery__main {
  position: relative;
  width: 100%;
  aspect-ratio: 0.75 / 1;
  border-radius: 12px;
  overflow: hidden;
  {% comment %} box-shadow:
    0 56px 150px 0 #00000030 inset,
    0 34px 50px 0 #341C0699,
    0 48px 80px -12px rgba(52, 28, 6, 0.55); {% endcomment %}

  /* enable touch swipe */
  touch-action: pan-y;
  user-select: none;
  -webkit-user-select: none;
}

.gallery-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}
.gallery-slide--active {
  opacity: 1;
  pointer-events: auto;
}
.gallery-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
}

.gallery-slide--active img {
  filter: drop-shadow(0 18px 36px rgba(52, 28, 6, 0.42));
}

.gallery-slide .placeholder-svg,
.thumb-placeholder {
  width: 100%;
  height: 100%;
  fill: #2A2520;
  color: #5A4A3A;
}

/* ── Zoom button ── */
.gallery-zoom-btn {
  position: absolute;
  top: 14px;
  left: 14px;
  z-index: 3;
  width: 40px;
  height: 40px;
  border-radius: 6px;
  background: rgba(255,255,255,0.92);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #222;
  transition: background 0.2s;
}
.gallery-zoom-btn:hover { background: #fff; }

/* ── Prev / Next nav arrows ── */
.gallery-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.2);
  background: rgba(13,13,11,0.55);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s, opacity 0.2s;
  opacity: 0;
}

/* show arrows on hover of the main gallery container */
.product-gallery__main:hover .gallery-nav,
.product-gallery__main:focus-within .gallery-nav {
  opacity: 1;
}

/* always show on touch devices (mobile) */
@media (hover: none) {
  .gallery-nav { opacity: 1; }
}

.gallery-nav:hover {
  background: rgba(201,168,133,0.25);
  border-color: rgba(201,168,133,0.6);
}
.gallery-nav--prev { left: 12px; }
.gallery-nav--next { right: 12px; }

.gallery-nav:disabled {
  opacity: 0.2 !important;
  cursor: default;
}

/* ── Dot indicators ── */
.gallery-dots {
  position: absolute;
  bottom: 14px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  gap: 6px;
  align-items: center;
}

.gallery-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(255,255,255,0.35);
  transition: background 0.25s, transform 0.25s;
  cursor: pointer;
  flex-shrink: 0;
}

.gallery-dot--active {
  background: var(--accent-gold, #C9A885);
  transform: scale(1.4);
}

/* hide dots when only 1 image */
.gallery-dots:has(.gallery-dot:only-child) { display: none; }

/* ── Thumbnails ── */
.product-gallery__thumbs {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.thumb {
  width: calc(25% - 8px);
  aspect-ratio: 0.78 / 1;
  border-radius: 12px;
  overflow: hidden;
  background: #111;
  border: 2px solid transparent;
  cursor: pointer;
  padding: 0;
  transition: border-color 0.25s, box-shadow 0.25s;
  flex-shrink: 0;
}
.thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.thumb--active {
  border-color: #c9a885;
  box-shadow: 0 0 0 1px rgba(201, 168, 133, 0.45), 0 8px 24px rgba(0, 0, 0, 0.35);
}
.thumb:hover:not(.thumb--active) {
  border-color: rgba(201, 168, 133, 0.45);
}

/* when more than 4 thumbs, shrink a bit so they all fit */
.product-gallery__thumbs:has(.thumb:nth-child(5)) .thumb { width: calc(20% - 8px); }
.product-gallery__thumbs:has(.thumb:nth-child(7)) .thumb { width: calc(14.28% - 8px); }

/* ── Product Info ────────────── */
.product-info {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 0;
  width: 100%;
  min-width: 0;
}

@media (min-width: 769px) {
  .product-info {
    margin-top: 100px;
  }
}

/* Exclusive badge */
.exclusive-badge {
  margin-bottom: 20px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 200px;
  min-height: 48px;
  padding: 12px 20px;
  border-radius: 4px;
  color: #fff8e7;
  background: linear-gradient(270deg, rgba(142, 112, 37, 0) 0%, rgba(142, 112, 37, 0.854796) 78.75%, rgba(142, 112, 37, 0) 100%);
  box-shadow: 0 10px 32px rgba(0, 0, 0, 0.24);
  box-sizing: border-box;
}

.exclusive-badge__text {
  font-family: var(--font-display);
  font-weight: 400;
  font-style: normal;
  font-size: 22px;
  line-height: 1.15;
  letter-spacing: 0.12em;
  color: #f5e6cf;
  text-transform: uppercase;
}

.product-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 16px;
}

.product-title {
  font-family: var(--font-display);
  font-weight: 400;
  font-style: normal;
  font-size: clamp(40px, 4.2vw, 60px);
  line-height: 1.12;
  letter-spacing: -0.02em;
  color: #f5f2eb;
  margin: 0;
  flex: 1;
  max-width: 18ch;
  text-wrap: balance;
  margin-top: 25px;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.product-author {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 14px;
  line-height: 26px;
  letter-spacing: 0.20em;
  text-transform: uppercase;
  text-decoration: underline;
  text-underline-offset: 4px;
  text-decoration-thickness: 1px;
  color: #C9A885;
  margin: 0 0 22px 0;
}

.signed-copies-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border: 1px solid rgba(201, 168, 133, 0.85);
  border-radius: 999px;
  width: fit-content;
  margin-bottom: 32px;
  background: rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.signed-copies-badge__text {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 15px;
  line-height: 1;
  color: #C9A885;
}

.product-price {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 32px;
}

.price-label {
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--text-muted);
}

.price-amount {
  font-family: var(--font-body);
  font-weight: 500;
  font-size: 36px;
  line-height: 1;
  color: #ffffff;
  letter-spacing: -0.02em;
}

.price-compare {
  font-family: var(--font-body);
  font-size: 20px;
  color: var(--text-muted);
  text-decoration: line-through;
}

.variant-selector {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 28px;
}
.variant-option__label {
  font-family: var(--font-body);
  font-size: 13px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8px;
}
.variant-option__values {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.variant-value-btn {
  padding: 8px 18px;
  border: 1px solid rgba(201,168,133,0.35);
  background: transparent;
  color: white;
  font-family: var(--font-body);
  font-size: 14px;
  cursor: pointer;
  border-radius: 3px;
  transition: border-color 0.2s, background 0.2s;
}
.variant-value-btn:hover,
.variant-value-btn.active {
  border-color: var(--accent-gold);
  background: rgba(201,168,133,0.1);
}

.product-actions {
  display: flex;
  align-items: center;
  gap: 22px;
  flex-wrap: wrap;
  margin-top: 4px;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 0;
  border-radius: 50px;
  padding: 0 6px;
  height: 54px;
}

.qty-btn {
  width: 60px;
  height: 60px;
  border-radius: 80px;
  filter: drop-shadow(0px 14px 24px rgba(255, 208, 88, 0.2));
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: #000000;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: white;
  transition: background 0.2s;
  flex-shrink: 0;
}
.qty-btn:hover { background: #1a1a1a; }

.qty-input {
  width: 42px;
  text-align: center;
  background: transparent;
  border: none;
  color: white;
  font-family: var(--font-body);
  font-size: 18px;
  font-weight: 400;
  -moz-appearance: textfield;
  outline: none;
}
.qty-input::-webkit-inner-spin-button,
.qty-input::-webkit-outer-spin-button { -webkit-appearance: none; }

.cta-btn {
  color: #ffffff;
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 220px;
  min-height: 56px;
  padding: 14px 42px;
  overflow: hidden;
  border: 1px solid rgba(232, 213, 181, 0.45);
  border-radius: 999px;
  text-decoration: none;
  font-family: var(--font-body);
  font-weight: 700;
  font-size: 14px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  background-color: transparent;
  background-image: url('https://cdn.shopify.com/s/files/1/0589/1719/1777/files/f89b1c50a8a368abe48fc6793fd85a8999a3c0ca_7991f07a-d217-4f4e-bd7a-f6113fc84bf9.png?v=1776090622');
  background-repeat: no-repeat;
  background-size: cover;
  background-position: center;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  box-shadow: 0 14px 36px rgba(52, 28, 6, 0.45), inset 0 1px 0 rgba(255, 255, 255, 0.35);
