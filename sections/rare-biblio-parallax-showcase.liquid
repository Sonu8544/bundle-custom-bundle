{% liquid
  assign section_id = 'rb-parallax-slider-' | append: section.id
%}

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<section
  id="{{ section_id }}"
  class="rbps"
  style="
    --rbps-bg-start: {{ section.settings.bg_start }};
    --rbps-bg-end: {{ section.settings.bg_end }};
    --rbps-heading-color: {{ section.settings.heading_color }};
    --rbps-text-color: {{ section.settings.text_color }};
    --rbps-overlay-opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
    --rbps-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --rbps-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --rbps-text-size-desktop: {{ section.settings.text_size_desktop }}px;
    --rbps-text-size-mobile: {{ section.settings.text_size_mobile }}px;
    --rbps-image-size-desktop: {{ section.settings.image_size_desktop }}px;
    --rbps-image-size-mobile: {{ section.settings.image_size_mobile }}px;
    --rbps-image-radius: {{ section.settings.image_radius }}px;
    --rbps-content-width: {{ section.settings.content_width }}px;
    --rbps-section-max-width: {{ section.settings.section_max_width }}px;
    --rbps-gap-desktop: {{ section.settings.desktop_gap }}px;
    --rbps-gap-mobile: {{ section.settings.mobile_gap }}px;
    --rbps-padding-top: {{ section.settings.padding_top }}px;
    --rbps-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
  data-rbps-section
>
  <div class="rbps__stack">
    {% for block in section.blocks %}
      {% liquid
        assign idx_mod = forloop.index0 | modulo: 2
        assign image_left = false
        if idx_mod == 0
          assign image_left = true
        endif

        assign show_content_grad = block.settings.enable_content_gradient | default: true
        assign rbps_img_loading = 'lazy'
        if forloop.first
          assign rbps_img_loading = 'eager'
        endif
      %}

      <article
        class="rbps__slide {% if image_left %}rbps__slide--image-left{% else %}rbps__slide--image-right{% endif %}"
        data-rbps-slide
        style="z-index: {{ forloop.index }};"
        {{ block.shopify_attributes }}
      >
        <div class="rbps__panel">
          <div class="rbps__slide-bg"></div>

          <div class="rbps__inner">
            <div class="rbps__slide-grid">
              <div class="rbps__media-wrap" data-rbps-media-wrap>
                <div class="rbps__media" data-rbps-media>
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 1800
                      | image_tag:
                        loading: rbps_img_loading,
                        widths: '400, 600, 800, 1000, 1200, 1400, 1600, 1800',
                        sizes: '(max-width: 749px) 88vw, 560px',
                        class: 'rbps__image',
                        alt: block.settings.heading | escape
                    }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'rbps__image rbps__image--placeholder' }}
                  {% endif %}
                  <div class="rbps__image-overlay"></div>
                </div>
              </div>

              <div class="rbps__content-wrap{% if show_content_grad %} rbps__content-wrap--grad{% endif %}">
                <div class="rbps__content" data-rbps-content>
                  {% if block.settings.heading != blank %}
                    <h2 class="rbps__heading" data-rbps-heading>{{ block.settings.heading }}</h2>
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <div class="rbps__text rte" data-rbps-text>
                      {{ block.settings.text }}
                    </div>
                  {% endif %}

                  {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                    <div class="rbps__button-wrap" data-rbps-button>
                      <a href="{{ block.settings.button_link }}" class="rbps__button">
                        {{ block.settings.button_label }}
                      </a>
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

<style>
  #{{ section_id }} {
    position: relative;
    overflow: visible;
    background: #050504;
    padding-top: var(--rbps-padding-top);
    padding-bottom: var(--rbps-padding-bottom);
  }

  #{{ section_id }} .rbps__stack {
    position: relative;
  }

  #{{ section_id }} .rbps__slide {
    position: sticky;
    top: 0;
    min-height: 100vh;
    overflow: hidden;
  }

  #{{ section_id }} .rbps__panel {
    position: relative;
    min-height: 100vh;
    background: #050504;
    isolation: isolate;
    overflow: hidden;
  }

  #{{ section_id }} .rbps__slide-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(77.47% 561.61% at 127.29% 73.12%, rgba(39, 29, 14, 0) 0%, #050504 100%),
      linear-gradient(180deg, var(--rbps-bg-start) 0%, var(--rbps-bg-end) 100%);
    opacity: 1;
  }

  #{{ section_id }} .rbps__inner {
    position: relative;
    z-index: 1;
    width: min(100%, var(--rbps-section-max-width));
    min-height: 100vh;
    margin: 0 auto;
    display: flex;
    align-items: center;
  }

  #{{ section_id }} .rbps__slide-grid {
    width: 100%;
    min-height: 100vh;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--rbps-gap-desktop);
    align-items: center;
    padding: 56px 32px;
  }

  #{{ section_id }} .rbps__slide--image-left .rbps__media-wrap { order: 1; }
  #{{ section_id }} .rbps__slide--image-left .rbps__content-wrap { order: 2; }

  #{{ section_id }} .rbps__slide--image-right .rbps__media-wrap { order: 2; }
  #{{ section_id }} .rbps__slide--image-right .rbps__content-wrap { order: 1; }

  #{{ section_id }} .rbps__media-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100%;
    will-change: transform;
  }

  #{{ section_id }} .rbps__media {
    position: relative;
    width: var(--rbps-image-size-desktop);
    height: var(--rbps-image-size-desktop);
    max-width: 100%;
    border-radius: var(--rbps-image-radius);
    overflow: hidden;
    background: #0a0907;
    box-shadow: 0 16px 50px rgba(0, 0, 0, 0.35);
    will-change: transform;
  }

  #{{ section_id }} .rbps__image {
    position: absolute;
    inset: -12%;
    width: 124%;
    height: 124%;
    display: block;
    object-fit: cover;
    object-position: center center;
    transform: translate3d(0, 0, 0) scale(1.08);
    will-change: transform;
  }

  {% comment %} #{{ section_id }} .rbps__image-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    border-radius: inherit;
    background: radial-gradient(
      52.48% 50% at 50% 50%,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, var(--rbps-overlay-opacity)) 100%
    );
    opacity: 0.8;
  } {% endcomment %}

#{{ section_id }} .rbps__image-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  border-radius: inherit;
  opacity: 1;
  background:
    radial-gradient(circle at center, rgba(5, 5, 4, 0) 52%, rgba(5, 5, 4, 0.18) 68%, rgba(5, 5, 4, 0.52) 82%, #050504 100%);
}

  #{{ section_id }} .rbps__content-wrap {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 100%;
    overflow: hidden;
  }

  #{{ section_id }} .rbps__slide--image-left .rbps__content-wrap {
    justify-content: flex-start;
    text-align: left;
    padding-left: 40px;
  }

  #{{ section_id }} .rbps__slide--image-right .rbps__content-wrap {
    justify-content: flex-start;
    text-align: left;
    padding-left: 80px;
  }

  #{{ section_id }} .rbps__content-wrap--grad {
    align-self: stretch;
    min-height: 100%;
    background-repeat: no-repeat;
    background-size: 100% 100%;
  }

  #{{ section_id }} .rbps__slide--image-left .rbps__content-wrap--grad {
    background-image: radial-gradient(
      ellipse 73.61% 539.32% at 127.29% 73.12%,
      #271d0e 0%,
      #050504 100%
    );
  }

  #{{ section_id }} .rbps__slide--image-right .rbps__content-wrap--grad {
    background-image: radial-gradient(
      ellipse 73.61% 539.32% at -27.29% 73.12%,
      #271d0e 0%,
      #050504 100%
    );
  }

  #{{ section_id }} .rbps__content {
    position: relative;
    z-index: 1;
    max-width: var(--rbps-content-width);
    transform: translate3d(0, 0, 0);
    will-change: transform;
  }

  #{{ section_id }} .rbps__heading {
    margin: 0 0 18px;
    color: var(--rbps-heading-color);
    font-family: "Bethany Elingston", serif;
    font-weight: 400;
    font-size: var(--rbps-heading-size-desktop);
    line-height: 1;
  }

  #{{ section_id }} .rbps__text,
  #{{ section_id }} .rbps__text p {
    margin: 0;
    color: var(--rbps-text-color);
    opacity: 0.72;
    font-family: "Satoshi", sans-serif;
    font-weight: 400;
    font-size: var(--rbps-text-size-desktop);
    line-height: 1.35;
  }

  #{{ section_id }} .rbps__text p + p {
    margin-top: 10px;
  }

  #{{ section_id }} .rbps__button-wrap {
    margin-top: 24px;
  }

  #{{ section_id }} .rbps__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 12px 22px;
    border-radius: 999px;
    text-decoration: none;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.16);
    background: rgba(255,255,255,0.06);
    transition: transform .3s ease, background .3s ease, border-color .3s ease;
  }

  #{{ section_id }} .rbps__button:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.24);
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} .rbps__slide,
    #{{ section_id }} .rbps__panel,
    #{{ section_id }} .rbps__inner,
    #{{ section_id }} .rbps__slide-grid {
      min-height: 100svh;
    }

    #{{ section_id }} .rbps__slide-grid {
      grid-template-columns: 1fr;
      gap: var(--rbps-gap-mobile);
      padding: 32px 18px;
    }

    #{{ section_id }} .rbps__slide--image-left .rbps__content-wrap,
    #{{ section_id }} .rbps__slide--image-right .rbps__content-wrap {
      order: 2;
      justify-content: center;
      text-align: center;
      padding-left: 0;
    }

    #{{ section_id }} .rbps__media-wrap {
      order: 1;
    }

    #{{ section_id }} .rbps__media {
      width: min(100%, var(--rbps-image-size-mobile));
      height: min(calc(100vw - 36px), var(--rbps-image-size-mobile));
    }

    #{{ section_id }} .rbps__heading {
      font-size: var(--rbps-heading-size-mobile);
    }

    #{{ section_id }} .rbps__text,
    #{{ section_id }} .rbps__text p {
      font-size: var(--rbps-text-size-mobile);
    }

    #{{ section_id }} .rbps__content {
      max-width: 100%;
    }
  }
</style>

<script>
(function () {
  const SECTION_ID = '{{ section_id }}';

  function init() {
    const section = document.getElementById(SECTION_ID);
    if (!section || typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    ScrollTrigger.getAll().forEach((trigger) => {
      if (trigger.trigger && trigger.trigger.closest && trigger.trigger.closest('#' + SECTION_ID)) {
        trigger.kill();
      }
    });

    const slides = section.querySelectorAll('[data-rbps-slide]');

    slides.forEach((slide) => {
      const mediaWrap = slide.querySelector('[data-rbps-media-wrap]');
      const image = slide.querySelector('.rbps__image');
      const content = slide.querySelector('[data-rbps-content]');
      const heading = slide.querySelector('[data-rbps-heading]');
      const text = slide.querySelector('[data-rbps-text]');
      const button = slide.querySelector('[data-rbps-button]');

      if (!mediaWrap || !content) return;

      gsap.set(mediaWrap, { y: 100 });
      gsap.set(content, { y: 60 });
      if (image) gsap.set(image, { y: 90, scale: 1.14 });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: slide,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1,
          invalidateOnRefresh: true
        }
      });

      tl.to(mediaWrap, {
        y: -120,
        ease: 'none'
      }, 0);

      if (image) {
        tl.to(image, {
          y: -160,
          scale: 1.03,
          ease: 'none'
        }, 0);
      }

      tl.to(content, {
        y: -55,
        ease: 'none'
      }, 0);

      if (heading) {
        tl.fromTo(heading, {
          y: 18,
          opacity: 0.82
        }, {
          y: -8,
          opacity: 1,
          ease: 'none'
        }, 0);
      }

      if (text) {
        tl.fromTo(text, {
          y: 16,
          opacity: 0.76
        }, {
          y: -6,
          opacity: 1,
          ease: 'none'
        }, 0.02);
      }

      if (button) {
        tl.fromTo(button, {
          y: 14,
          opacity: 0.76
        }, {
          y: -4,
          opacity: 1,
          ease: 'none'
        }, 0.04);
      }
    });

    ScrollTrigger.refresh();
  }

  document.addEventListener('shopify:section:load', init);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  let resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      ScrollTrigger.refresh();
    }, 150);
  });
})();
</script>

