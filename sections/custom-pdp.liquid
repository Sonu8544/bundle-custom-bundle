<script>
(function() {
  const sectionId = '{{ section.id }}';
  const section = document.getElementById('exclusive-book-product-' + sectionId);
  if (!section) return;

  // ── Gallery Thumbs ──────────────
  const slides = section.querySelectorAll('.gallery-slide');
  const thumbs = section.querySelectorAll('.thumb');

  function activateSlide(index) {
    slides.forEach((s, i) => s.classList.toggle('gallery-slide--active', i === index));
    thumbs.forEach((t, i) => t.classList.toggle('thumb--active', i === index));
  }

  thumbs.forEach((thumb, index) => {
    thumb.addEventListener('click', () => activateSlide(index));
  });

  // ── Zoom / Lightbox ──────────────
  const lightbox = document.getElementById('lightbox-' + sectionId);
  const lightboxImg = document.getElementById('lightboxImg-' + sectionId);
  const zoomBtn = section.querySelector('.gallery-zoom-btn');
  const closeBtn = section.querySelector('.lightbox-close');

  function openLightbox() {
    const activeSlide = section.querySelector('.gallery-slide--active img');
    if (activeSlide && lightbox && lightboxImg) {
      lightboxImg.src = activeSlide.src;
      lightboxImg.alt = activeSlide.alt;
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeLightbox() {
    if (lightbox) {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  }

  if (zoomBtn) zoomBtn.addEventListener('click', openLightbox);
  if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
  if (lightbox) {
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  }
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

  // ── Quantity + Live Price Update ──────────────
  const qtyInput  = section.querySelector('.qty-input');
  const minusBtn  = section.querySelector('.qty-btn--minus');
  const plusBtn   = section.querySelector('.qty-btn--plus');
  const priceEl   = section.querySelector('.price-amount');

  // Store the unit price in cents from the data attribute set in Liquid
  const unitPriceCents = parseInt(priceEl ? (priceEl.dataset.unitPrice || '0') : '0', 10);
  const currencySymbol = priceEl ? (priceEl.dataset.currency || '') : '';

  function formatMoney(cents) {
    // Use Shopify's built-in formatter if available, otherwise format manually
    if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
      return window.Shopify.formatMoney(cents, window.Shopify.money_format || '{{amount}}');
    }
    // Fallback: prefix + amount with 2 decimal places
    const amount = (cents / 100).toFixed(2);
    return currencySymbol + amount;
  }

  function updatePrice() {
    if (!priceEl || !unitPriceCents) return;
    const qty = parseInt(qtyInput ? qtyInput.value : '1', 10) || 1;
    priceEl.textContent = formatMoney(unitPriceCents * qty);
  }

  if (qtyInput) {
    if (minusBtn) {
      minusBtn.addEventListener('click', () => {
        const v = parseInt(qtyInput.value, 10);
        if (v > 1) { qtyInput.value = v - 1; updatePrice(); }
      });
    }
    if (plusBtn) {
      plusBtn.addEventListener('click', () => {
        qtyInput.value = parseInt(qtyInput.value, 10) + 1;
        updatePrice();
      });
    }
    qtyInput.addEventListener('change', () => {
      if (parseInt(qtyInput.value, 10) < 1) qtyInput.value = 1;
      updatePrice();
    });
  }

  // ── Wishlist toggle ──────────────
  const wishlistBtn = section.querySelector('.wishlist-btn');
  if (wishlistBtn) {
    wishlistBtn.addEventListener('click', () => wishlistBtn.classList.toggle('active'));
  }

  // ── Variant selection ──────────────
  const variantBtns = section.querySelectorAll('.variant-value-btn');
  variantBtns.forEach(btn => {
    btn.addEventListener('click', function () {
      const optionIndex = this.dataset.optionIndex;
      section.querySelectorAll(`.variant-value-btn[data-option-index="${optionIndex}"]`)
        .forEach(b => b.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // ── Cart helpers (proven pattern) ──────────────
  function getCartDrawer()      { return document.querySelector('cart-drawer'); }
  function getCartDrawerMain()  { return document.getElementById('CartDrawer'); }
  function getCartBubble()      { return document.getElementById('cart-icon-bubble'); }

  async function addItem(variantId, quantity) {
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root)
      ? window.Shopify.routes.root
      : '/';
    const response = await fetch(root + 'cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ items: [{ id: Number(variantId), quantity: quantity }] })
    });
    const data = await response.json();
    if (!response.ok || data.status) {
      throw new Error(data.description || 'Failed to add to cart');
    }
    return data;
  }

  async function fetchSection(sectionId) {
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root)
      ? window.Shopify.routes.root
      : '/';
    const res = await fetch(root + '?section_id=' + sectionId, {
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    if (!res.ok) throw new Error('Failed to fetch section: ' + sectionId);
    return res.text();
  }

  function replaceDrawerMarkup(html) {
    const parsed        = new DOMParser().parseFromString(html, 'text/html');
    const freshMain     = parsed.getElementById('CartDrawer');
    const currentMain   = getCartDrawerMain();
    if (currentMain && freshMain) {
      currentMain.innerHTML = freshMain.innerHTML;
    }
    const drawer = getCartDrawer();
    if (drawer) {
      drawer.classList.remove('is-empty');
      const inner = drawer.querySelector('.drawer__inner');
      if (inner) inner.classList.remove('is-empty');
    }
  }

  function replaceBubbleMarkup(html) {
    const parsed        = new DOMParser().parseFromString(html, 'text/html');
    const freshBubble   = parsed.getElementById('cart-icon-bubble');
    const currentBubble = getCartBubble();
    if (currentBubble && freshBubble) {
      currentBubble.innerHTML = freshBubble.innerHTML;
    }
  }

  function openDrawer() {
    const drawer = getCartDrawer();
    if (!drawer) return;
    drawer.classList.remove('is-empty');
    const inner = drawer.querySelector('.drawer__inner');
    if (inner) inner.classList.remove('is-empty');
    if (typeof drawer.open === 'function') {
      drawer.open();
    } else {
      drawer.classList.add('animate', 'active');
      document.body.classList.add('overflow-hidden');
    }
  }

  async function refreshCartUI() {
    const [drawerHtml, bubbleHtml] = await Promise.all([
      fetchSection('cart-drawer'),
      fetchSection('cart-icon-bubble')
    ]);
    replaceDrawerMarkup(drawerHtml);
    replaceBubbleMarkup(bubbleHtml);
    setTimeout(openDrawer, 60);

    // Fire Dawn pub/sub if available
    if (typeof window.publish === 'function' && window.PUB_SUB_EVENTS && window.PUB_SUB_EVENTS.cartUpdate) {
      window.publish(window.PUB_SUB_EVENTS.cartUpdate, { source: 'exclusive-book-product' });
    }
    // Fallback custom events
    document.dispatchEvent(new CustomEvent('cart:refresh', { detail: { source: 'exclusive-book-product' } }));
    document.dispatchEvent(new CustomEvent('cart:updated', { detail: { source: 'exclusive-book-product' } }));
  }

  // ── Add to Cart ──────────────
  const cartBtn = section.querySelector('#addToCart-' + sectionId);

  if (cartBtn) {
    cartBtn.addEventListener('click', async function () {
      const btn         = this;
      const variantId   = btn.dataset.variantId;
      const qty         = qtyInput ? parseInt(qtyInput.value, 10) || 1 : 1;
      const originalText = btn.textContent.trim();

      if (!variantId || btn.disabled) return;

      btn.disabled     = true;
      btn.textContent  = 'Adding...';

      // Clear any previous error
      const prevErr = section.querySelector('.atc-error');
      if (prevErr) prevErr.textContent = '';

      try {
        await addItem(variantId, qty);
        await refreshCartUI();
        btn.textContent = 'Added ✓';
        setTimeout(() => {
          btn.textContent = originalText;
          btn.disabled    = false;
        }, 1200);
      } catch (err) {
        console.error('[Exclusive Book] Add to cart error:', err);
        // Show error beneath actions row
        let errEl = section.querySelector('.atc-error');
        if (!errEl) {
          errEl = document.createElement('p');
          errEl.className = 'atc-error';
          errEl.style.cssText = 'color:#e07070;font-size:13px;margin-top:10px;font-family:var(--font-body)';
          section.querySelector('.product-actions').after(errEl);
        }
        errEl.textContent = err.message || 'Could not add item. Please try again.';
        btn.textContent = 'Error';
        setTimeout(() => {
          btn.textContent = originalText;
          btn.disabled    = false;
          if (errEl) errEl.textContent = '';
        }, 1400);
      }
    });
  }
})();
</script>

