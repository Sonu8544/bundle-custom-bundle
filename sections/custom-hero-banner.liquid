{% liquid
  assign sid = 'chs-' | append: section.id
  assign autoplay_enabled = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed | times: 1000
%}

<section
  id="{{ sid }}"
  class="chs{% if section.settings.enable_text_animation %} chs--text-anim{% endif %}"
  data-autoplay="{% if autoplay_enabled %}true{% else %}false{% endif %}"
  data-autoplay-speed="{{ autoplay_speed }}"
  style="
    --chs-height-desktop: {{ section.settings.height_desktop }}px;
    --chs-height-mobile: {{ section.settings.height_mobile }}px;
    --chs-header-offset-desktop: {{ section.settings.header_offset_desktop }}px;
    --chs-header-offset-mobile: {{ section.settings.header_offset_mobile }}px;
    --chs-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --chs-content-max: {{ section.settings.content_max_width }}px;
    --chs-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --chs-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --chs-subheading-size-desktop: {{ section.settings.subheading_size_desktop }}px;
    --chs-subheading-size-mobile: {{ section.settings.subheading_size_mobile }}px;
    --chs-btn-font-size-desktop: {{ section.settings.button_font_size_desktop }}px;
    --chs-btn-font-size-mobile: {{ section.settings.button_font_size_mobile }}px;
    --chs-scroll-label-size-desktop: {{ section.settings.scroll_text_size_desktop }}px;
    --chs-scroll-label-size-mobile: {{ section.settings.scroll_text_size_mobile }}px;
    --chs-content-padding-x-desktop: {{ section.settings.content_padding_x_desktop }}px;
    --chs-content-padding-x-mobile: {{ section.settings.content_padding_x_mobile }}px;
    --chs-content-padding-bottom-desktop: {{ section.settings.content_padding_bottom_desktop }}px;
    --chs-content-padding-bottom-mobile: {{ section.settings.content_padding_bottom_mobile }}px;
    --chs-text-color: {{ section.settings.text_color }};
    --chs-highlight-color: {{ section.settings.highlight_color }};
    --chs-subtext-color: {{ section.settings.subtext_color }};
    --chs-button-text-color: {{ section.settings.button_text_color }};
    --chs-scroll-color: {{ section.settings.scroll_color }};
    --chs-nav-color: {{ section.settings.nav_color }};
    --chs-dot-color: {{ section.settings.dot_color }};
    --chs-dot-active-color: {{ section.settings.dot_active_color }};
    --chs-btn-radius: {{ section.settings.button_radius }}px;
    --chs-btn-padding-y-desktop: {{ section.settings.button_padding_y_desktop }}px;
    --chs-btn-padding-x-desktop: {{ section.settings.button_padding_x_desktop }}px;
    --chs-btn-padding-y-mobile: {{ section.settings.button_padding_y_mobile }}px;
    --chs-btn-padding-x-mobile: {{ section.settings.button_padding_x_mobile }}px;
    --chs-title-accent-gradient: linear-gradient(270.6deg, #A87E0A 9.74%, #FFFFFF 100%);
    --chs-overlay-top: {{ section.settings.overlay_top }};
    --chs-overlay-bottom: {{ section.settings.overlay_bottom }};
    --chs-overlay-solid: {{ section.settings.overlay_solid }};
  "
>
  <div class="chs__slider" aria-roledescription="carousel">
    <div class="chs__track" data-track>
      {% for block in section.blocks %}
        {% liquid
          assign desktop_media_type = block.settings.desktop_media_type
          assign mobile_media_type = block.settings.mobile_media_type
          assign desktop_image = block.settings.desktop_image
          assign mobile_image = block.settings.mobile_image
          assign desktop_video = block.settings.desktop_video
          assign mobile_video = block.settings.mobile_video
          assign slide_link = block.settings.slide_link
          assign enable_overlay = block.settings.enable_overlay
          assign custom_overlay_opacity = block.settings.overlay_opacity | divided_by: 100.0
        %}
        <div
          class="chs__slide{% if forloop.first %} is-active{% endif %}"
          data-slide
          data-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
          {% if block.settings.heading != blank %}aria-label="{{ block.settings.heading | strip_html | escape }}"{% endif %}
        >
          {% if slide_link != blank %}
            <a class="chs__slide-link" href="{{ slide_link }}" aria-label="{{ block.settings.heading | strip_html | escape }}"></a>
          {% endif %}

          <div class="chs__media">
            <div class="chs__media-desktop">
              {% if desktop_media_type == 'video' and desktop_video != blank %}
                {{
                  desktop_video
                  | video_tag:
                    autoplay: true,
                    loop: true,
                    muted: true,
                    controls: false,
                    playsinline: true,
                    class: 'chs__video'
                }}
              {% elsif desktop_image != blank %}
                {{
                  desktop_image
                  | image_url: width: 2400
                  | image_tag:
                    widths: '1200, 1400, 1600, 1800, 2200, 2400',
                    sizes: '100vw',
                    loading: 'lazy',
                    class: 'chs__image',
                    alt: block.settings.heading
                }}
              {% endif %}
            </div>

            <div class="chs__media-mobile">
              {% if mobile_media_type == 'video' and mobile_video != blank %}
                {{
                  mobile_video
                  | video_tag:
                    autoplay: true,
                    loop: true,
                    muted: true,
                    controls: false,
                    playsinline: true,
                    class: 'chs__video'
                }}
              {% elsif mobile_image != blank %}
                {{
                  mobile_image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '480, 640, 750, 900, 1200',
                    sizes: '100vw',
                    loading: 'lazy',
                    class: 'chs__image',
                    alt: block.settings.heading
                }}
              {% elsif desktop_image != blank %}
                {{
                  desktop_image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '480, 640, 750, 900, 1200',
                    sizes: '100vw',
                    loading: 'lazy',
                    class: 'chs__image',
                    alt: block.settings.heading
                }}
              {% endif %}
            </div>

            <div
              class="chs__overlay"
              {% if enable_overlay %}
                style="--chs-slide-overlay-opacity: {{ custom_overlay_opacity }};"
              {% endif %}
            ></div>
          </div>

          <div class="chs__inner page-width">
            <div class="chs__content chs__content--{{ block.settings.content_alignment }}">
              {% if block.settings.eyebrow != blank %}
                <div class="chs__eyebrow{% if section.settings.enable_text_animation %} chs-animate chs-animate--eyebrow{% endif %}">{{ block.settings.eyebrow }}</div>
              {% endif %}

              {% if block.settings.heading != blank %}
                <h1 class="chs__heading{% if section.settings.enable_text_animation %} chs-animate chs-animate--heading{% endif %}">
                  {% if block.settings.highlight_text != blank %}
                    <span class="chs__heading-first">{{ block.settings.heading }}</span><span class="chs__highlight">{{ block.settings.highlight_text }}</span>
                  {% else %}
                    {{ block.settings.heading }}
                  {% endif %}
                </h1>
              {% endif %}

              {% if block.settings.subheading != blank %}
                <div class="chs__subheading rte{% if section.settings.enable_text_animation %} chs-animate chs-animate--sub{% endif %}">{{ block.settings.subheading }}</div>
              {% endif %}

              {% if block.settings.primary_button_label != blank or block.settings.secondary_button_label != blank %}
                <div class="chs__buttons{% if section.settings.enable_text_animation %} chs-animate chs-animate--buttons{% endif %}">
                  {% if block.settings.primary_button_label != blank %}
                    <a
                      href="{{ block.settings.primary_button_link | default: '#' }}"
                      class="chs__button chs__button--primary"
                    >
                      {{ block.settings.primary_button_label }}
                    </a>
                  {% endif %}

                  {% if block.settings.secondary_button_label != blank %}
                    <a
                      href="{{ block.settings.secondary_button_link | default: '#' }}"
                      class="chs__button chs__button--secondary"
                    >
                      {{ block.settings.secondary_button_label }}
                    </a>
                  {% endif %}
                </div>
              {% endif %}

              {% if block.settings.show_scroll_indicator %}
                <div class="chs__scroll-wrap{% if section.settings.enable_text_animation %} chs-animate chs-animate--scroll{% endif %}">
                  <button
                    type="button"
                    class="chs__scroll-button"
                    data-scroll-next
                    aria-label="{{ block.settings.scroll_text | default: 'Scroll to discover' }}"
                  >
                    {% comment %} <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg> {% endcomment %}

                    <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <g clip-path="url(#clip0_150_1464)">
                      <path d="M19.9999 6.24994V33.7499" stroke="white" stroke-width="3.81544" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M8.75 22.5L20 33.75L31.25 22.5" stroke="white" stroke-width="3.81544" stroke-linecap="round" stroke-linejoin="round"/>
                      </g>
                      <defs>
                      <clipPath id="clip0_150_1464">
                      <rect width="40" height="40" fill="white"/>
                      </clipPath>
                      </defs>
                    </svg>

                  </button>
                  {% if block.settings.scroll_text != blank %}
                    <div class="chs__scroll-label">{{ block.settings.scroll_text }}</div>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.blocks.size > 1 and section.settings.show_arrows %}
      <button class="chs__nav chs__nav--prev" type="button" data-prev aria-label="Previous slide">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 5L8 12L15 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <button class="chs__nav chs__nav--next" type="button" data-next aria-label="Next slide">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {% endif %}

    {% if section.blocks.size > 1 and section.settings.show_dots %}
      <div class="chs__dots" data-dots>
        {% for block in section.blocks %}
          <button
            type="button"
            class="chs__dot{% if forloop.first %} is-active{% endif %}"
            data-dot="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <style>
    #{{ sid }} {
    position: relative;
    overflow: hidden;
    background: #000;
    margin-top: calc(var(--spacing-sections-mobile) * -1);
    }

    @media screen and (min-width: 750px) {
    #{{ sid }} {
        margin-top: calc(var(--spacing-sections-desktop) * -1);
    }
    }

    #{{ sid }} .page-width {
      max-width: 100%;
      padding-left: 0;
      padding-right: 0;
    }

    #{{ sid }} .chs__slider,
    #{{ sid }} .chs__track,
    #{{ sid }} .chs__slide {
      position: relative;
      width: 100%;
      height: var(--chs-height-desktop);
    }

    #{{ sid }} .chs__track {
      overflow: hidden;
    }

    #{{ sid }} .chs__slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      visibility: hidden;
      transition: opacity .7s ease, visibility .7s ease;
      pointer-events: none;
    }

    #{{ sid }} .chs__slide.is-active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      z-index: 2;
    }

    #{{ sid }} .chs__slide-link {
      position: absolute;
      inset: 0;
      z-index: 1;
    }

    #{{ sid }} .chs__media,
    #{{ sid }} .chs__media-desktop,
    #{{ sid }} .chs__media-mobile {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    #{{ sid }} .chs__media-mobile {
      display: none;
    }

    #{{ sid }} .chs__image,
    #{{ sid }} .chs__video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    #{{ sid }} .chs__overlay {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 85% 75% at 50% 38%, rgba(0,0,0,.18) 0%, rgba(0,0,0,.55) 58%, rgba(0,0,0,.72) 100%),
        linear-gradient(to bottom, rgba(0,0,0,.12) 0%, rgba(0,0,0,.22) 35%, rgba(0,0,0,.5) 100%),
        linear-gradient(to bottom, var(--chs-overlay-top) 0%, transparent 38%, transparent 68%, var(--chs-overlay-bottom) 100%),
        linear-gradient(to bottom, var(--chs-overlay-solid), var(--chs-overlay-solid));
      opacity: var(--chs-overlay-opacity);
      z-index: 0;
    }

    #{{ sid }} .chs__slide[style*="--chs-slide-overlay-opacity"] .chs__overlay,
    #{{ sid }} .chs__slide .chs__overlay[style*="--chs-slide-overlay-opacity"] {
      opacity: var(--chs-slide-overlay-opacity);
    }

    #{{ sid }} .chs__inner {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding-left: var(--chs-content-padding-x-desktop);
    padding-right: var(--chs-content-padding-x-desktop);
    padding-top: calc(var(--rb-header-height, 110px) + var(--chs-header-offset-desktop) + min(10vh, 120px));
    padding-bottom: var(--chs-content-padding-bottom-desktop);
    box-sizing: border-box;
    }

    #{{ sid }} .chs__content {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: var(--chs-content-max);
      color: var(--chs-text-color);
      text-align: center;
      margin-inline: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1 1 auto;
      min-height: 0;
    }

    #{{ sid }} .chs__content--left {
      text-align: left;
      margin-left: 0;
      margin-right: auto;
    }

    #{{ sid }} .chs__content--center {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
    }

    #{{ sid }} .chs__content--right {
      text-align: right;
      margin-left: auto;
      margin-right: 0;
    }

    #{{ sid }} .chs__eyebrow {
      font-size: 14px;
      line-height: 1;
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-bottom: 14px;
      color: var(--chs-subtext-color);
    }

    #{{ sid }} .chs__heading {
        margin: 0;
        color: var(--chs-text-color);
        font-family: "Bethany Elingston", var(--font-heading-family);
        font-size: var(--chs-heading-size-desktop);
        /* line-height: 1.06; */
        font-weight: 400;
        /* letter-spacing: -0.02em; */
        font-size: 100px;
    }

    @media screen and (min-width: 750px) and (max-width: 1150px) {
      #{{ sid }} .chs__heading {
        font-size: 75px;
      }

      #{{ sid }} .chs__subheading {
        font-size: 30px !important;
      }
    }

    #{{ sid }} .chs__heading-first {
      color: #FFFFFF;
    }

    #{{ sid }} .chs__heading-first + .chs__highlight {
      margin-left: 0.28em;
    }

    #{{ sid }} .chs__highlight {
      display: inline-block;
      vertical-align: baseline;
      background: var(--chs-title-accent-gradient);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }

    #{{ sid }} .chs__subheading {
    margin-top: 12px;
    max-width: min(38em, 100%);
    margin-left: auto;
    margin-right: auto;
    text-align: center;
    color: var(--chs-subtext-color);
    font-family: "Satoshi", var(--font-body-family);
    font-size: var(--chs-subheading-size-desktop);
    line-height: 1.65;
    font-weight: 400;
    letter-spacing: 0.07em;
    text-wrap: balance;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.45);
    }

    #{{ sid }} .chs__content--left .chs__subheading {
      margin-left: 0;
      margin-right: auto;
      text-align: left;
    }

    #{{ sid }} .chs__content--right .chs__subheading {
      margin-left: auto;
      margin-right: 0;
      text-align: right;
    }

    #{{ sid }} .chs__subheading,
    #{{ sid }} .chs__subheading p {
      color: var(--chs-subtext-color);
    }

    #{{ sid }} .chs__subheading p {
      margin: 0;
      font-size: inherit;
      font-weight: inherit;
      letter-spacing: inherit;
      line-height: inherit;
    }

    #{{ sid }} .chs__subheading > *:first-child {
      margin-top: 0;
    }

    #{{ sid }} .chs__subheading > *:last-child {
      margin-bottom: 0;
    }

    #{{ sid }} .chs__buttons {
      margin-top: 55px;
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      justify-content: center;
      align-items: center;
    }

    #{{ sid }} .chs__content--left .chs__buttons {
      justify-content: flex-start;
    }

    #{{ sid }} .chs__content--right .chs__buttons {
      justify-content: flex-end;
    }

    #{{ sid }} .chs__button {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 0;
      padding: var(--chs-btn-padding-y-desktop) var(--chs-btn-padding-x-desktop);
      text-decoration: none;
      border-radius: var(--chs-btn-radius);
      font-size: var(--chs-btn-font-size-desktop);
      font-weight: 700;
      line-height: 1.05;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      transition: transform .25s ease, opacity .25s ease, box-shadow .28s ease, filter .28s ease;
    }

    #{{ sid }} .chs__button:hover {
      transform: translateY(-2px);
    }

    #{{ sid }} .chs__button--primary {
      font-family: "Satoshi", var(--font-body-family);
      font-weight: 700;
      font-size: var(--chs-btn-font-size-desktop);
      line-height: 1;
      letter-spacing: 0.14em;
      text-align: center;
      min-width: min(100%, 280px);
      padding: var(--chs-btn-padding-y-desktop) var(--chs-btn-padding-x-desktop);
      border: 1px solid rgba(255, 255, 255, 0.22);
      border-radius: 999px;
      color: var(--chs-button-text-color);
      background-color: #6b5214;
      background-image: url('https://cdn.shopify.com/s/files/1/0589/1719/1777/files/f89b1c50a8a368abe48fc6793fd85a8999a3c0ca_7991f07a-d217-4f4e-bd7a-f6113fc84bf9.png?v=1776090622');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      text-shadow:
        0 1px 2px rgba(0, 0, 0, 0.45),
        0 0 14px rgba(0, 0, 0, 0.35);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.28),
        inset 0 -2px 0 rgba(0, 0, 0, 0.2),
        0 6px 22px rgba(0, 0, 0, 0.4);
    }

    #{{ sid }} .chs__button--primary:hover {
      filter: brightness(1.04);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.34),
        inset 0 -2px 0 rgba(0, 0, 0, 0.16),
        0 10px 30px rgba(0, 0, 0, 0.45);
    }

    #{{ sid }} .chs__button--secondary {
      color: var(--chs-text-color);
      border: 1px solid rgba(255,255,255,.7);
      background: rgba(255,255,255,.05);
      backdrop-filter: blur(6px);
    }

    #{{ sid }} .chs__scroll-wrap {
      margin-top: 85px;
      padding-top: 0px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
    }
#{{ sid }} .chs__scroll-button {
  width: 100px;
  height: 100px;
  border-radius: 999px;
  border: 1.8px solid #FFFFFF66;

  /* 👇 ADD THIS */
  background: rgba(255, 255, 255, 0.08); /* must not be fully transparent */
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);

  color: var(--chs-scroll-color);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform .25s ease, background .25s ease, border-color .25s ease;
  animation: chs-bounce 2.2s ease-in-out infinite;
}

    #{{ sid }} .chs__scroll-button:hover {
      transform: translateY(2px);
      background: rgba(255, 255, 255, 0.06);
      border-color: rgba(255, 255, 255, 0.9);
    }

    #{{ sid }} .chs__scroll-label {
      font-family: "Satoshi", var(--font-body-family);
      color: var(--chs-scroll-color);
      font-size: var(--chs-scroll-label-size-desktop);
      line-height: 1.3;
      letter-spacing: 0.28em;
      text-transform: uppercase;

      font-weight: 400;
      font-style: Regular;
      line-height: 100%;
      letter-spacing: 0%;
      text-align: center;
      margin-top: 20px;
    }

    #{{ sid }} .chs__nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 4;
      width: 48px;
      height: 48px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.35);
      background: rgba(0,0,0,.24);
      color: var(--chs-nav-color);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background .25s ease, transform .25s ease, opacity .25s ease;
    }

    #{{ sid }} .chs__nav:hover {
      background: rgba(0,0,0,.45);
    }

    #{{ sid }} .chs__nav--prev {
      left: 24px;
    }

    #{{ sid }} .chs__nav--next {
      right: 24px;
    }

    #{{ sid }} .chs__dots {
      position: absolute;
      left: 50%;
      bottom: 26px;
      transform: translateX(-50%);
      z-index: 4;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    #{{ sid }} .chs__dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      border: 0;
      padding: 0;
      background: var(--chs-dot-color);
      opacity: .55;
      cursor: pointer;
      transition: transform .25s ease, opacity .25s ease, background .25s ease;
    }

    #{{ sid }} .chs__dot.is-active {
      opacity: 1;
      background: var(--chs-dot-active-color);
      transform: scale(1.15);
    }

    /* Scroll-in text (Rare Biblio heading pattern: fade + slide, staggered) */
    #{{ sid }}.chs--text-anim:not(.is-visible) .chs__slide.is-active .chs-animate,
    #{{ sid }}.chs--text-anim.is-visible .chs__slide.is-active:not(.chs-text-reveal) .chs-animate {
      opacity: 0;
      transform: translate3d(0, 28px, 0);
      will-change: transform, opacity;
    }

    #{{ sid }}.chs--text-anim:not(.is-visible) .chs__slide.is-active .chs-animate--eyebrow,
    #{{ sid }}.chs--text-anim.is-visible .chs__slide.is-active:not(.chs-text-reveal) .chs-animate--eyebrow {
      transform: translate3d(0, -18px, 0);
    }

    #{{ sid }}.chs--text-anim.is-visible .chs__slide.is-active.chs-text-reveal .chs-animate {
      opacity: 1;
      transform: translate3d(0, 0, 0);
      transition:
        opacity 1.88s cubic-bezier(0.22, 1, 0.36, 1),
        transform 1.88s cubic-bezier(0.22, 1, 0.36, 1);
    }

    #{{ sid }}.chs--text-anim.is-visible .chs__slide.is-active.chs-text-reveal .chs-animate--eyebrow {
      transition-delay: 0ms;
    }

    #{{ sid }}.chs--text-anim.is-visible .chs__slide.is-active.chs-text-reveal .chs-animate--heading {
      transition-delay: 0.24s;
    }

    #{{ sid }}.chs--text-anim.is-visible .chs__slide.is-active.chs-text-reveal .chs-animate--sub {
      transition-delay: 0.24s;
    }

    #{{ sid }}.chs--text-anim.is-visible .chs__slide.is-active.chs-text-reveal .chs-animate--buttons {
      transition-delay: 0.70s;
    }

    #{{ sid }}.chs--text-anim.is-visible .chs__slide.is-active.chs-text-reveal .chs-animate--scroll {
      transition-delay: 0.32s;
    }

    @media (prefers-reduced-motion: reduce) {
      #{{ sid }}.chs--text-anim .chs__slide .chs-animate {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
    }

    @keyframes chs-bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(8px); }
    }

    @media screen and (max-width: 989px) {
      #{{ sid }} .chs__slider,
      #{{ sid }} .chs__track,
      #{{ sid }} .chs__slide {
        height: var(--chs-height-mobile);
      }

      #{{ sid }} .chs__media-desktop {
        display: none;
      }

      #{{ sid }} .chs__media-mobile {
        display: block;
      }

        #{{ sid }} .chs__inner {
        align-items: center;
        padding-left: var(--chs-content-padding-x-mobile);
        padding-right: var(--chs-content-padding-x-mobile);
        padding-top: calc(var(--rb-header-height, 80px) + var(--chs-header-offset-mobile) + min(6vh, 64px));
        padding-bottom: var(--chs-content-padding-bottom-mobile);
        }

      #{{ sid }} .chs__content {
        max-width: 100%;
      }

      #{{ sid }} .chs__heading {
        font-size: var(--chs-heading-size-mobile);
        /* line-height: .98; */
      }

      #{{ sid }} .chs__subheading {
        margin-top: 16px;
        font-size: var(--chs-subheading-size-mobile);
        line-height: 1.58;
        letter-spacing: 0.06em;
      }

      #{{ sid }} .chs__buttons {
        margin-top: 24px;
      }

      #{{ sid }} .chs__button {
        min-width: min(100%, 280px);
        padding: var(--chs-btn-padding-y-mobile) var(--chs-btn-padding-x-mobile);
        font-size: var(--chs-btn-font-size-mobile);
      }

      #{{ sid }} .chs__scroll-wrap {
        padding-top: 28px;
      }

      #{{ sid }} .chs__scroll-button {
        width: 48px;
        height: 48px;
      }

      #{{ sid }} .chs__scroll-label {
        font-size: var(--chs-scroll-label-size-mobile);
      }

      #{{ sid }} .chs__nav {
        width: 40px;
        height: 40px;
        top: auto;
        bottom: 18px;
        transform: none;
      }

      #{{ sid }} .chs__nav--prev {
        left: 16px;
      }

      #{{ sid }} .chs__nav--next {
        right: 16px;
