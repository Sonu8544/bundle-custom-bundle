      "max": 80,
      "step": 2,
      "default": 38
    },
    {
      "type": "range",
      "id": "heading_bottom_spacing_mobile",
      "label": "Heading bottom spacing mobile",
      "min": 8,
      "max": 50,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "columns_desktop",
