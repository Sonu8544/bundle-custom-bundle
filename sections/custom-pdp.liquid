      if (!isDragging || zoomScale <= 1 || e.touches.length !== 1) return;
      zoomX = startZoomX + (e.touches[0].clientX - dragStartX);
      zoomY = startZoomY + (e.touches[0].clientY - dragStartY);
      applyZoom();
    }, { passive: true });

    lightboxImg.addEventListener('touchend', function() {
      isDragging = false;
      lightboxImg.classList.remove('is-dragging');
    });

