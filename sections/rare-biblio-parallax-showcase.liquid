      "label": "Heading color",
      "default": "#F5EFE6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#D7D0C6"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "paragraph",
          "content": "Slides alternate automatically: 1st = image left / text right, 2nd = text left / image right, then repeat."
        },
        {
          "type": "checkbox",
          "id": "enable_content_gradient",
          "label": "Content column gradient",
          "default": true,
          "info": "Warm radial behind the text column (#271D0E → #050504). Turn off for a flat background."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Leather Selection"
        },
        {
